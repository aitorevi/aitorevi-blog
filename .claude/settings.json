{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)",
      "Read(**/*token*)",
      "Read(**/*.key)",
      "Read(**/*api_key*)",
      "Read(**/*apikey*)",
      "Read(**/*password*)",
      "Read(**/.aws/**)",
      "Read(**/.gcp/**)",
      "Read(**/.google/**)",
      "Read(**/.azure/**)",
      "Read(**/.kube/**)",
      "Read(**/.docker/**)",
      "Read(**/.vault/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/kubectl/**)",
      "Read(~/.config/helm/**)",
      "Read(~/.config/azure/**)",
      "Read(~/.config/vercel/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)",
      "Read(~/.npm/**)",
      "Read(~/.npmrc)",
      "Read(~/.m2/**)",
      "Read(~/.gradle/**)",
      "Read(~/.gem/**)",
      "Read(~/.cargo/**)",
      "Read(~/.rustup/**)",
      "Read(~/.go/**)",
      "Read(~/.jdk/**)",
      "Read(~/.java/**)",
      "Read(~/.python/**)",
      "Read(~/.pip/**)",
      "Read(~/.venv/**)",
      "Read(~/.env*)",
      "Read(~/.netrc)",
      "Read(~/.pgpass)",
      "Read(~/.db_password)",
      "Read(~/.passwd*)",
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Read(/etc/group)",
      "Read(/etc/sudoers)",
      "Read(/etc/ssl/private/**)",
      "Read(**/.github/workflows/secrets.yml)",
      "Read(**/.circleci/config.yml)",
      "Read(**/.travis.yml)",
      "Read(**/.gitlab-ci.yml)",
      "Bash(cat ~/.ssh/**)",
      "Bash(cat ~/.config/vercel/**)",
      "Bash(cat ~/.aws/**)",
      "Bash(cat ~/.gcp/**)",
      "Bash(cat ~/.kube/**)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(set)",
      "Bash(declare -p)",
      "Bash(export *)",
      "Bash(source *env*)",
      "Bash(. *env*)",
      "Bash(cat .env*)",
      "Bash(cat *secret*)",
      "Bash(cat *credentials*)",
      "Bash(cat *token*)",
      "Bash(cat *key*)",
      "Bash(cat *password*)",
      "Bash(cat *api_key*)",
      "Bash(node -e *process.env*)",
      "Bash(python* -c *os.environ*)",
      "Bash(grep -r *secret* *)",
      "Bash(grep -r *api_key* *)",
      "Bash(grep -r *token* *)",
      "Bash(grep -r *password* *)"
    ]
  }
}
