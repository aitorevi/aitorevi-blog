{
  "name": "aitorevi",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/optimize-images.mjs",
    "build": "astro check && astro build && node scripts/generate-og-image.mjs && node scripts/generate-og-katas.mjs && node scripts/generate-cv-pdf.mjs",
    "prevercel-build": "node scripts/optimize-images.mjs",
    "vercel-build": "astro check && astro build && node scripts/generate-og-image.mjs && node scripts/generate-og-katas.mjs && node scripts/generate-cv-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:a11y": "playwright test tests/a11y/",
    "test:a11y:ci": "pa11y-ci --config .pa11yci.json",
    "test:a11y:axe": "node scripts/axe-check.mjs",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "og:generate": "node scripts/generate-og-image.mjs",
    "og:katas": "node scripts/generate-og-katas.mjs",
    "check:katas": "node scripts/check-kata-links.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "optimize:images:dry": "node scripts/optimize-images.mjs --dry-run",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,jsx,css,json,md}\" \"scripts/**/*.{mjs,js,ts}\" \"*.{json,md,cjs,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,jsx,css,json,md}\" \"scripts/**/*.{mjs,js,ts}\" \"*.{json,md,cjs,mjs}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^10.0.5",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@sparticuz/chromium": "^143.0.4",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.9",
    "astro-icon": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.12.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "svix": "^1.92.2"
  },
  "devDependencies": {
    "@iconify-json/simple-icons": "^1.2.79",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "axe-core": "^4.11.4",
    "axe-playwright": "^2.2.2",
    "pa11y": "^9.1.1",
    "pa11y-ci": "^4.1.0",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "satori": "^0.26.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "vitest": "^4.1.5"
  }
}
