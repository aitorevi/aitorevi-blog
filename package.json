{
  "name": "aitorevi",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/optimize-images.mjs",
    "build": "astro check && astro build && node scripts/generate-og-image.mjs && node scripts/generate-og-katas.mjs && node scripts/generate-cv-pdf.mjs",
    "prevercel-build": "node scripts/optimize-images.mjs",
    "vercel-build": "astro check && astro build && node scripts/generate-og-image.mjs && node scripts/generate-og-katas.mjs && node scripts/generate-cv-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "og:generate": "node scripts/generate-og-image.mjs",
    "og:katas": "node scripts/generate-og-katas.mjs",
    "check:katas": "node scripts/check-kata-links.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "optimize:images:dry": "node scripts/optimize-images.mjs --dry-run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.2",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@sparticuz/chromium": "^143.0.4",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.16.6",
    "astro-icon": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.10.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@iconify-json/simple-icons": "^1.2.79",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "playwright-core": "^1.59.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "vitest": "^1.1.1"
  }
}
