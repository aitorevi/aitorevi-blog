---
/**
 * Blog Index Page
 *
 * Displays all published blog posts in a grid layout.
 *
 * Astro 5 Features:
 * - Content Layer API with getCollection()
 * - Static generation (SSG)
 * - View Transitions for navigation
 *
 * Performance Optimizations:
 * - Zero JavaScript
 * - Priority loading for first 3 cards (above-the-fold)
 * - Lazy loading for remaining cards
 * - Optimized layout with CSS Grid
 *
 * SEO:
 * - Semantic HTML structure
 * - Proper meta tags
 * - Schema.org Blog markup
 */

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/molecules/PostCard.astro';
import { sortPostsByDate, filterDrafts } from '../../lib/utils';
import { t, getBlogSlugFromId } from '../../i18n/utils';

const lang = 'es';

const DOT_COUNT = 60;
const dots = Array.from({ length: DOT_COUNT }, (_, i) => ({
  x: ((i * 37) % 100) + Math.random() * 2,
  y: ((i * 53) % 95) + Math.random() * 2,
  size: 1 + ((i * 13) % 4) * 0.6,
  opacity: 0.12 + ((i * 7) % 10) * 0.025,
}));

// Astro 5: Fetch all blog posts using Content Layer API
const allPosts = await getCollection('blog');

// Filter drafts, language and sort by date (newest first)
const publishedPosts = sortPostsByDate(filterDrafts(allPosts)).filter((post) => post.id.startsWith('es/'));

// Separate featured posts
const featuredPosts = publishedPosts.filter((post) => post.data.featured);
const regularPosts = publishedPosts.filter((post) => !post.data.featured);
---

<Layout
  title="Blog | aitorevi"
  description="Technical articles, tutorials, and insights on web development, Astro, TypeScript, and modern web technologies."
>
  <!-- SEO: Additional metadata -->
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blog | aitorevi" />
    <meta property="og:description" content="Technical articles and insights on web development" />
    <link rel="canonical" href={new URL('/blog', Astro.site).href} />

    <!-- Schema.org JSON-LD for Blog -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "aitorevi Blog",
      "description": "Technical articles, tutorials, and insights on web development",
      "url": new URL('/blog', Astro.site).href,
      "author": {
        "@type": "Person",
        "name": "aitorevi",
      },
      "blogPost": publishedPosts.slice(0, 10).map(post => ({
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.description,
        "datePublished": post.data.publishDate.toISOString(),
        "url": new URL(`/blog/${getBlogSlugFromId(post.id)}`, Astro.site).href,
      })),
    })} />
  </Fragment>

  <div class="relative isolate min-h-screen">
    <!-- Dark-mode-only dot field -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 hidden dark:block text-accent-blue">
      {dots.map((d) => (
        <span
          class="absolute rounded-full bg-current"
          style={`left:${d.x}%;top:${d.y}%;width:${d.size}px;height:${d.size}px;opacity:${d.opacity};`}
        />
      ))}
    </div>

  <!-- Main Content -->
  <main class="blog-page mx-auto max-w-7xl mt-16 md:mt-24 mb-2 md:mb-4 p-6 sm:p-7 md:p-8 lg:p-20">
    <!-- Page Header -->
    <header class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-display font-bold tracking-tight text-ink-900 dark:text-slate-100 sm:text-5xl lg:text-6xl">
        Blog
      </h1>
      <p class="mx-auto max-w-3xl text-2xl font-ibm font-bold text-secondary sm:text-3xl">
        {t(lang, 'blog.subtitle')}
      </p>
    </header>

    <!-- Featured Posts Section -->
    {featuredPosts.length > 0 && (
      <section class="mb-16" aria-labelledby="featured-heading">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {featuredPosts.slice(0, 3).map((post, index) => (
            <PostCard
              post={post}
              priority={index < 2}
              showFeaturedBadge={true}
            />
          ))}
        </div>
      </section>
    )}

    <!-- All Posts Section (only shown if there are regular posts) -->
    {regularPosts.length > 0 && (
      <section aria-labelledby="all-posts-heading">
        <h2
          id="all-posts-heading"
          class="mb-6 text-2xl font-display font-bold tracking-tight text-ink-900 dark:text-slate-100"
        >
          {featuredPosts.length > 0 ? t(lang, 'blog.allPosts') : t(lang, 'blog.latestPosts')}
        </h2>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {regularPosts.map((post, index) => (
            <PostCard
              post={post}
              priority={featuredPosts.length === 0 && index < 3}
              showFeaturedBadge={false}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Empty State (only shown if there are NO posts at all) -->
    {publishedPosts.length === 0 && (
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-12 text-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="mx-auto mb-4 h-12 w-12 text-slate-400"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
          />
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-slate-900">
          No posts yet
        </h3>
        <p class="text-slate-600">
          Check back soon for new articles!
        </p>
      </div>
    )}

    <!-- Optional: Newsletter Signup CTA -->
    <!-- Uncomment when ready to add newsletter functionality
    <section class="mt-16 rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 p-8 text-center text-white sm:p-12">
      <h2 class="mb-4 text-3xl font-bold">Subscribe to the Newsletter</h2>
      <p class="mb-6 text-lg opacity-90">
        Get the latest articles and insights delivered to your inbox.
      </p>
      <form class="mx-auto flex max-w-md gap-3">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 rounded-lg px-4 py-3 text-slate-900"
          required
        />
        <button
          type="submit"
          class="rounded-lg bg-white px-6 py-3 font-semibold text-blue-600 transition-transform hover:scale-105"
        >
          Subscribe
        </button>
      </form>
    </section>
    -->
  </main>
  </div>
  <style is:global>
    body:has(.blog-page) {
      background-color: #f8fafc;
      background-image: none;
    }
    html.dark body:has(.blog-page),
    html.dark body:has(.blog-page) main {
      background-color: #020617;
      background-image: radial-gradient(ellipse at 30% 20%, #0f172a 0%, #020617 55%, #000 100%);
      background-attachment: fixed;
      background-size: cover;
    }
  </style>
</Layout>

<style>
  /**
   * Grid auto-fill ensures responsive layout without media queries
   * Prevents layout shift with explicit gaps
   */
  @supports (grid-template-columns: repeat(auto-fill, minmax(300px, 1fr))) {
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    }
  }
</style>
