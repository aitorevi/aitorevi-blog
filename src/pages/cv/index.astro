---
import Layout from '../../layouts/Layout.astro';
import CvHeader from '../../components/cv/CvHeader.astro';
import CvProfile from '../../components/cv/CvProfile.astro';
import CvExperience from '../../components/cv/CvExperience.astro';
import CvSkills from '../../components/cv/CvSkills.astro';
import CvEducation from '../../components/cv/CvEducation.astro';
import CvCertifications from '../../components/cv/CvCertifications.astro';
import CvPdfDownload from '../../components/cv/CvPdfDownload.astro';
import CvScrollReveal from '../../components/cv/CvScrollReveal.astro';
import { getCvData, getPdfPath, getJsonPath } from '../../data/cv';
import type { Lang } from '../../data/cv';

const lang: Lang = 'es';
const data = getCvData(lang);
const pdfPath = getPdfPath(lang);
const jsonPath = getJsonPath(lang);

const DOT_COUNT = 60;
const dots = Array.from({ length: DOT_COUNT }, (_, i) => ({
  x: ((i * 37) % 100) + Math.random() * 2,
  y: ((i * 53) % 95) + Math.random() * 2,
  size: 1 + ((i * 13) % 4) * 0.6,
  opacity: 0.12 + ((i * 7) % 10) * 0.025,
}));
---

<Layout
  title={data.labels.pageTitle}
  lang={lang}
  description={data.labels.pageDescription}
>
  <!-- Ambient wrapper: stays neutral in light mode, becomes dark-ink in dark mode
       to bridge smoothly with the home's visual language. -->
  <div class="relative isolate min-h-[calc(100vh-3.5rem)] md:min-h-[calc(100vh-5rem)]">
    <!-- Dark-mode-only dot field — same logic as home hero -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 hidden dark:block text-accent-blue">
      {dots.map((d) => (
        <span
          class="absolute rounded-full bg-current"
          style={`left:${d.x}%;top:${d.y}%;width:${d.size}px;height:${d.size}px;opacity:${d.opacity};`}
        />
      ))}
    </div>

    <section class="cv-page mx-auto max-w-screen-xl mb-2 md:mb-4 p-6 pt-16 sm:p-7 sm:pt-16 md:p-8 md:pt-24 lg:p-16 lg:pt-24 pb-8 sm:pb-10 md:pb-12 lg:pb-12 rounded-2xl font-ibm
                    "">
      <CvScrollReveal />
      <CvHeader contact={data.contact} />
      <CvProfile label={data.labels.profile} summary={data.summary} />
      <CvExperience label={data.labels.experience} entries={data.experience} />
      <CvEducation label={data.labels.education} entries={data.education} />
      <CvCertifications label={data.labels.certifications} entries={data.certifications} />
      <CvSkills label={data.labels.skills} categories={data.skills} />
      <CvPdfDownload pdfPath={pdfPath} jsonPath={jsonPath} label={data.labels.downloadPdf} />
    </section>
  </div>
  <style is:global>
    body:has(.cv-page) {
      background-color: #f8fafc;
      background-image: none;
    }
    html.dark body:has(.cv-page),
    html.dark body:has(.cv-page) main {
      background-color: #020617;
      background-image: radial-gradient(ellipse at 30% 20%, #0f172a 0%, #020617 55%, #000 100%);
      background-attachment: fixed;
      background-size: cover;
    }
  </style>
</Layout>
