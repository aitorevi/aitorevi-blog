---
import Layout from '@/layouts/Layout.astro';
import { t, getLocalePath } from '@/i18n/utils';
import Breadcrumb from '@/components/shared/Breadcrumb.astro';

const lang = 'en';

const featureKeys = ['dashboard', 'installations', 'measurements', 'quotes', 'suppliers', 'roles', 'pwa', 'responsive'] as const;

const secondaryScreenshots = [
  { src: '/images/portfolio/ims/installations-list.webp', key: 'portfolio.ims.gallery.installations', url: 'app.ims.dev/installations' },
  { src: '/images/portfolio/ims/installation-detail.webp', key: 'portfolio.ims.gallery.detail', url: 'app.ims.dev/installations/42' },
  { src: '/images/portfolio/ims/measurements.webp', key: 'portfolio.ims.gallery.measurements', url: 'app.ims.dev/measurements' },
  { src: '/images/portfolio/ims/quotes.webp', key: 'portfolio.ims.gallery.quotes', url: 'app.ims.dev/quotes' },
  { src: '/images/portfolio/ims/suppliers.webp', key: 'portfolio.ims.gallery.suppliers', url: 'app.ims.dev/suppliers' },
  { src: '/images/portfolio/ims/dashboard-installer.webp', key: 'portfolio.ims.gallery.installer', url: 'app.ims.dev/dashboard' },
];

const stack = {
  frontend: ['Astro 5 (SSR)', 'TypeScript', 'Tailwind CSS'],
  backend: ['Supabase (PostgreSQL)', 'Row Level Security', 'Edge Functions', 'Google OAuth'],
  infra: ['Vercel', 'PWA / Service Worker', 'Push Notifications (VAPID)'],
  testing: ['Vitest (678 unit tests)', 'Playwright (E2E)', 'Integration tests', '80%+ coverage'],
};
---

<Layout
  title="IMS — Installation Management System"
  description={t(lang, 'portfolio.ims.subtitle')}
>
  <div class="relative bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">
    <div class="mx-auto max-w-5xl px-6 pt-24 sm:pt-28">
      <Breadcrumb
        lang={lang}
        items={[
          { label: t(lang, 'nav.home'), href: getLocalePath('/', lang) },
          { label: t(lang, 'nav.work'), href: getLocalePath('/work', lang) },
          { label: t(lang, 'portfolio.ims.title') },
        ]}
      />
    </div>
    <!-- Hero -->
    <section class="relative overflow-hidden py-8 sm:py-12">
      <div class="absolute inset-0 bg-gradient-to-b from-secondary/5 to-transparent dark:from-accent-blue/5" aria-hidden="true" />
      <div class="relative mx-auto max-w-5xl px-6 text-center">
        <span class="inline-flex items-center rounded-full border border-secondary/20 bg-secondary/10 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.15em] text-secondary dark:border-accent-violet/30 dark:bg-accent-violet/20 dark:text-accent-violet">
          SaaS
        </span>
        <h1 class="mt-6 font-display text-4xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-5xl">
          {t(lang, 'portfolio.ims.title')}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.ims.intro')}
        </p>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-white py-20 dark:bg-ink-900/50 sm:py-24" aria-labelledby="features-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="features-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.features.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {featureKeys.map((key) => (
            <li class="rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-white/10 dark:bg-white/[0.04]">
              <h3 class="font-display text-base font-semibold text-ink-900 dark:text-slate-100">
                {t(lang, `portfolio.ims.feat.${key}.title`)}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                {t(lang, `portfolio.ims.feat.${key}`)}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20 sm:py-24" aria-labelledby="stack-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="stack-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.stack.title')}
        </h2>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {Object.entries(stack).map(([category, items]) => (
            <div class="rounded-xl border border-slate-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.04]">
              <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.15em] text-secondary dark:text-accent-blue">
                {t(lang, `portfolio.ims.stack.${category}`)}
              </h3>
              <ul class="mt-3 space-y-2">
                {items.map((item) => (
                  <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
                    <span class="h-1.5 w-1.5 rounded-full bg-secondary/40 dark:bg-accent-violet/40" aria-hidden="true" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section class="bg-white py-20 dark:bg-ink-900/50 sm:py-24" aria-labelledby="gallery-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="gallery-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.gallery.title')}
        </h2>
        <p class="mt-3 text-center font-mono text-xs text-slate-500 dark:text-slate-500">
          // {t(lang, 'portfolio.ims.gallery.hint')}
        </p>

        <!-- Zone 1: Hero — Admin Dashboard -->
        <div class="mt-12">
          <button
            type="button"
            class="group relative block w-full overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-lg transition-all duration-300 motion-safe:hover:scale-[1.01] hover:border-secondary/30 hover:shadow-xl dark:border-white/10 dark:bg-ink-800 dark:hover:border-accent-violet/30 dark:hover:shadow-accent-blue/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary dark:focus-visible:outline-accent-violet"
            data-lightbox-trigger
            data-lightbox-src="/images/portfolio/ims/dashboard-admin.webp"
            data-lightbox-caption={t(lang, 'portfolio.ims.gallery.dashboard')}
            aria-label={`${t(lang, 'portfolio.ims.gallery.dashboard')} — ${t(lang, 'portfolio.ims.gallery.open')}`}
          >
            <div class="flex items-center gap-1.5 border-b border-slate-200/80 bg-slate-100 px-3 py-2 dark:border-white/5 dark:bg-ink-800" aria-hidden="true">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
              <div class="mx-auto flex h-5 w-64 items-center rounded-full bg-slate-200/80 px-3 dark:bg-white/5">
                <span class="truncate font-mono text-[9px] text-slate-400 dark:text-slate-500">app.ims.dev/dashboard</span>
              </div>
            </div>
            <img
              src="/images/portfolio/ims/dashboard-admin.webp"
              alt={t(lang, 'portfolio.ims.gallery.dashboard')}
              loading="eager"
              width="1248"
              height="731"
              class="w-full"
            />
            <div class="absolute inset-x-0 bottom-0 translate-y-full bg-gradient-to-t from-ink-900/90 to-transparent px-4 pb-4 pt-8 transition-transform duration-300 group-hover:translate-y-0" aria-hidden="true">
              <p class="font-mono text-xs text-slate-300">{t(lang, 'portfolio.ims.gallery.dashboard')}</p>
            </div>
          </button>
        </div>

        <!-- Zone 2: Secondary grid -->
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {secondaryScreenshots.map((img) => (
            <button
              type="button"
              class="group relative block overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-sm transition-all duration-300 motion-safe:hover:scale-[1.02] hover:border-secondary/30 hover:shadow-md dark:border-white/10 dark:bg-ink-800 dark:hover:border-accent-violet/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary dark:focus-visible:outline-accent-violet"
              data-lightbox-trigger
              data-lightbox-src={img.src}
              data-lightbox-caption={t(lang, img.key)}
              aria-label={`${t(lang, img.key)} — ${t(lang, 'portfolio.ims.gallery.open')}`}
            >
              <div class="flex items-center gap-1.5 border-b border-slate-200/80 bg-slate-100 px-3 py-1.5 dark:border-white/5 dark:bg-ink-800" aria-hidden="true">
                <span class="h-2 w-2 rounded-full bg-red-400/80"></span>
                <span class="h-2 w-2 rounded-full bg-yellow-400/80"></span>
                <span class="h-2 w-2 rounded-full bg-green-400/80"></span>
                <div class="mx-auto flex h-4 w-40 items-center rounded-full bg-slate-200/80 px-2 dark:bg-white/5">
                  <span class="truncate font-mono text-[8px] text-slate-400 dark:text-slate-500">{img.url}</span>
                </div>
              </div>
              <img
                src={img.src}
                alt={t(lang, img.key)}
                loading="lazy"
                class="w-full"
              />
              <div class="absolute inset-x-0 bottom-0 translate-y-full bg-gradient-to-t from-ink-900/90 to-transparent px-3 pb-3 pt-6 transition-transform duration-300 group-hover:translate-y-0" aria-hidden="true">
                <p class="font-mono text-[10px] text-slate-300">{t(lang, img.key)}</p>
              </div>
            </button>
          ))}
        </div>

        <!-- Zone 3: Mobile spotlight -->
        <div class="mt-4 flex flex-col items-center gap-8 rounded-xl border border-slate-200 bg-slate-50 p-8 sm:flex-row sm:justify-center dark:border-white/10 dark:bg-white/[0.04]">
          <div class="max-w-xs text-center sm:text-left">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-accent-violet/20 bg-accent-violet/10 px-2.5 py-1 font-mono text-[9px] uppercase tracking-[0.15em] text-accent-violet" aria-hidden="true">
              PWA
            </span>
            <h3 class="mt-3 font-display text-xl font-bold text-ink-900 dark:text-slate-200">
              {t(lang, 'portfolio.ims.gallery.mobileTitle')}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {t(lang, 'portfolio.ims.gallery.mobileDesc')}
            </p>
          </div>
          <button
            type="button"
            class="group relative shrink-0 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-secondary dark:focus-visible:outline-accent-violet"
            data-lightbox-trigger
            data-lightbox-src="/images/portfolio/ims/mobile-view.webp"
            data-lightbox-caption={t(lang, 'portfolio.ims.gallery.mobile')}
            aria-label={`${t(lang, 'portfolio.ims.gallery.mobile')} — ${t(lang, 'portfolio.ims.gallery.open')}`}
          >
            <div class="overflow-hidden rounded-[2rem] border-[5px] border-slate-700 bg-slate-900 shadow-xl shadow-slate-900/40 transition-all duration-300 motion-safe:group-hover:scale-[1.03] group-hover:shadow-2xl group-hover:shadow-accent-violet/20 dark:border-slate-600">
              <div class="flex h-6 items-center justify-center bg-slate-900" aria-hidden="true">
                <div class="h-1.5 w-16 rounded-full bg-slate-700"></div>
              </div>
              <img
                src="/images/portfolio/ims/mobile-view.webp"
                alt={t(lang, 'portfolio.ims.gallery.mobile')}
                loading="lazy"
                width="481"
                height="826"
                class="w-48 sm:w-52"
              />
              <div class="flex h-5 items-center justify-center bg-slate-900" aria-hidden="true">
                <div class="h-1 w-20 rounded-full bg-slate-700"></div>
              </div>
            </div>
          </button>
        </div>
      </div>
    </section>

    <!-- Lightbox -->
    <dialog
      id="ims-lightbox"
      class="fixed inset-0 m-auto max-h-[90vh] max-w-[90vw] overflow-hidden rounded-xl border border-white/10 bg-ink-900 p-0 shadow-2xl shadow-black/60 backdrop:bg-black/75 backdrop:backdrop-blur-sm"
    >
      <button
        type="button"
        id="lightbox-close"
        class="absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-slate-300 transition-colors hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-white"
        aria-label={t(lang, 'portfolio.ims.gallery.close')}
      >
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path d="M3.72 3.72a.75.75 0 0 1 1.06 0L8 6.94l3.22-3.22a.75.75 0 1 1 1.06 1.06L9.06 8l3.22 3.22a.75.75 0 1 1-1.06 1.06L8 9.06l-3.22 3.22a.75.75 0 0 1-1.06-1.06L6.94 8 3.72 4.78a.75.75 0 0 1 0-1.06Z"/>
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" aria-hidden="true" class="block max-h-[calc(90vh-3rem)] max-w-full object-contain" />
      <p id="lightbox-caption" class="bg-ink-900 px-4 py-2.5 text-center font-mono text-xs text-slate-400"></p>
    </dialog>

  </div>
</Layout>

<script>
  function initLightbox() {
    const dialog = document.getElementById('ims-lightbox') as HTMLDialogElement;
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption') as HTMLElement;
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
    if (!dialog || !img || !caption || !closeBtn) return;

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        img.src = btn.dataset.lightboxSrc ?? '';
        img.alt = btn.dataset.lightboxCaption ?? '';
        img.removeAttribute('aria-hidden');
        caption.textContent = btn.dataset.lightboxCaption ?? '';
        dialog.showModal();
      });
    });

    closeBtn.addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener('close', () => { img.src = ''; img.setAttribute('aria-hidden', 'true'); });
  }

  document.addEventListener('astro:page-load', initLightbox);
</script>
