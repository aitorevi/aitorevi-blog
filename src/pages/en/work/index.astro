---
import Layout from '@/layouts/Layout.astro';
import WorkCinematic from '@/components/work/WorkCinematic.astro';
import { t } from '@/i18n/utils';

const lang = 'en';
const title = `${t(lang, 'home.portfolio.title')} - Aitor Reviriego`;
const description = 'Real-world projects: SaaS, tools and case studies focused on architecture, accessibility and performance.';
---

<Layout title={title} lang={lang} description={description} variant="dark-radial">
  <main class="min-h-[calc(100vh-3.5rem)] md:min-h-[calc(100vh-5rem)]">
    <WorkCinematic lang={lang} />
  </main>
</Layout>
