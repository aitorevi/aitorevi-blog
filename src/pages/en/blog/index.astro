---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import PostCard from '../../../components/molecules/PostCard.astro';
import { sortPostsByDate, filterDrafts } from '../../../lib/utils';
import { t, getBlogSlugFromId } from '../../../i18n/utils';

const lang = 'en';

const allPosts = await getCollection('blog');
const publishedPosts = sortPostsByDate(filterDrafts(allPosts)).filter((post) => post.id.startsWith('en/'));

const featuredPosts = publishedPosts.filter((post) => post.data.featured);
const regularPosts = publishedPosts.filter((post) => !post.data.featured);
---

<Layout
  title="Blog | aitorevi"
  description={t(lang, 'blog.description')}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blog | aitorevi" />
    <meta property="og:description" content={t(lang, 'blog.description')} />
    <link rel="canonical" href={new URL('/en/blog', Astro.site).href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "aitorevi Blog",
      "description": t(lang, 'blog.description'),
      "url": new URL('/en/blog', Astro.site).href,
      "author": {
        "@type": "Person",
        "name": "aitorevi",
      },
      "blogPost": publishedPosts.slice(0, 10).map(post => ({
        "@type": "BlogPosting",
        "headline": post.data.title,
        "description": post.data.description,
        "datePublished": post.data.publishDate.toISOString(),
        "url": new URL(`/en/blog/${getBlogSlugFromId(post.id)}`, Astro.site).href,
      })),
    })} />
  </Fragment>

  <main class="blog-page mx-auto max-w-7xl mt-16 md:mt-24 mb-2 md:mb-4 p-6 sm:p-7 md:p-8 lg:p-20">
    <header class="mb-12 text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight text-slate-900 dark:text-[#f1f5f9] sm:text-5xl lg:text-6xl">
        Blog
      </h1>
      <p class="mx-auto max-w-3xl text-2xl font-ibm font-bold text-secondary sm:text-3xl">
        {t(lang, 'blog.subtitle')}
      </p>
    </header>

    {featuredPosts.length > 0 && (
      <section class="mb-16" aria-labelledby="featured-heading">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {featuredPosts.slice(0, 3).map((post, index) => (
            <PostCard post={post} priority={index < 2} showFeaturedBadge={true} lang="en" />
          ))}
        </div>
      </section>
    )}

    {regularPosts.length > 0 && (
      <section aria-labelledby="all-posts-heading">
        <h2 id="all-posts-heading" class="mb-6 text-2xl font-bold text-slate-900">
          {featuredPosts.length > 0 ? t(lang, 'blog.allPosts') : t(lang, 'blog.latestPosts')}
        </h2>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {regularPosts.map((post, index) => (
            <PostCard post={post} priority={featuredPosts.length === 0 && index < 3} showFeaturedBadge={false} lang="en" />
          ))}
        </div>
      </section>
    )}

    {publishedPosts.length === 0 && (
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="mx-auto mb-4 h-12 w-12 text-slate-400" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-slate-900">{t(lang, 'blog.noPosts')}</h3>
        <p class="text-slate-600">{t(lang, 'blog.noPostsDescription')}</p>
      </div>
    )}
  </main>
  <style is:global>
    body:has(.blog-page) {
      background-color: #f8fafc;
      background-image: none;
    }
    html.dark body:has(.blog-page),
    html.dark body:has(.blog-page) main {
      background-color: #020617;
    }
  </style>
</Layout>

<style>
  @supports (grid-template-columns: repeat(auto-fill, minmax(300px, 1fr))) {
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    }
  }
</style>
