---
/**
 * Base Layout
 *
 * Astro 5 Features:
 * - View Transitions for SPA-like navigation
 * - Semantic HTML structure
 * - Proper meta tags for SEO
 *
 * Performance:
 * - Zero JavaScript by default (View Transitions use CSS)
 * - Minimal layout shifts
 * - Optimized scrollbar styles
 */
import { ViewTransitions } from 'astro:transitions';
import Nav from "../components/Nav/Nav.astro";
import Footer from "../components/Footer/Footer.astro";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Astro description" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!--
			ASTRO 5 VIEW TRANSITIONS
			Enable SPA-like navigation without full page reloads
			fallback="swap" ensures compatibility with browsers that don't support View Transitions API
		-->
		<ViewTransitions fallback="swap" />

		<slot name="head" />
	</head>
	<body class="flex flex-col bg-white bg-custom bg-fixed text-primary scrollbar scrollbar-thumb-primary scrollbar-w-2 scrollbar-corner-rounded-xl">
		<Nav />

		<!-- Main content with transition name for smooth animations -->
		<main class="min-h-screen" transition:animate="slide">
			<slot/>
		</main>

		<Footer />
	</body>
</html>

<style is:global>
	/**
	 * Custom Scrollbar Styles
	 */
	::-webkit-scrollbar {
		height: .6rem;
		width: .5rem;
	}

	::-webkit-scrollbar-track {
		background: rgba(33, 39, 55, .6);
	}

	::-webkit-scrollbar-track:hover {
		background: rgba(33, 39, 55, .6);
	}

	::-webkit-scrollbar-thumb {
		background: rgba(94, 58, 238);
		border-radius: 0.25rem;
	}

	::-webkit-scrollbar-thumb:hover {
		background: rgba(118, 85, 249);
		border-radius: 0.25rem;
	}

	/**
	 * View Transitions Custom Animations
	 *
	 * Astro 5 provides default transitions, but we can customize them
	 * using ::view-transition-* pseudo-elements
	 */

	@media (prefers-reduced-motion: no-preference) {
		/* Smooth fade for page transitions - MÁS VISIBLE */
		::view-transition-old(root),
		::view-transition-new(root) {
			animation-duration: 0.5s;
			animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
		}

		/* Slide animation for main content - MÁS PRONUNCIADO */
		@keyframes slide-in {
			from {
				opacity: 0;
				transform: translateY(30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@keyframes slide-out {
			from {
				opacity: 1;
				transform: translateY(0);
			}
			to {
				opacity: 0;
				transform: translateY(-30px);
			}
		}

		::view-transition-old(main) {
			animation: slide-out 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		}

		::view-transition-new(main) {
			animation: slide-in 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		}
	}

	/* Respeta la preferencia de movimiento reducido */
	@media (prefers-reduced-motion: reduce) {
		::view-transition-old(root),
		::view-transition-new(root),
		::view-transition-old(main),
		::view-transition-new(main) {
			animation: none;
		}
	}
</style>
