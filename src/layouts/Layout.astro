---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import GoogleAnalytics from '@/components/analytics/GoogleAnalytics.astro';
import CookieConsent from '@/components/analytics/CookieConsent.astro';
import Nav from "@/components/nav/Nav.astro";
import Footer from "@/components/footer/Footer.astro";
import { getLangFromUrl, getAlternateUrl, t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';
import '@/styles/tokens.css';

interface Props {
	title: string;
	lang?: Lang;
	description?: string;
	alternateUrl?: string;
	alternateLang?: Lang;
	ogImage?: string;
	/**
	 * Override the canonical URL. Defaults to the current page's URL on aitorevi.dev.
	 * Pass an external URL for republished/syndicated content where the source of truth
	 * lives elsewhere. This value is used for both `<link rel="canonical">` and `<meta property="og:url">`.
	 */
	canonicalUrl?: string;
	/** Background variant. `dark-radial` applies the slate palette + radial gradient used on content pages (cv, blog, katas). `flat` applies slate-50/ink-900 with no gradient (case study pages). */
	variant?: 'default' | 'dark-radial' | 'flat';
}

const currentLang = getLangFromUrl(Astro.url);
const {
	title,
	lang = currentLang,
	description = t(lang, 'site.description'),
	alternateUrl = `https://www.aitorevi.dev${getAlternateUrl(Astro.url.pathname, lang)}`,
	alternateLang = lang === 'es' ? 'en' : 'es',
	ogImage = '/og/og-image.png',
	canonicalUrl: canonicalUrlProp,
	variant = 'default',
} = Astro.props;

const alternatePath = alternateUrl.replace('https://www.aitorevi.dev', '');
const internalUrl = `https://www.aitorevi.dev${Astro.url.pathname}`;
const canonicalUrl = canonicalUrlProp ?? internalUrl;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `https://www.aitorevi.dev${ogImage}`;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<!-- Self-hosted fonts: JetBrains Mono (code/accents) + Outfit (display).
		     Preload only the three above-the-fold weights (hero h1, hero paragraph,
		     role label). The remaining weights are declared via @font-face below and
		     load on demand — no blocking link to fonts.css in the request chain. -->
		<link rel="preload" href="/fonts/outfit-900-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/outfit-600-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/jetbrains-mono-400-latin.woff2" as="font" type="font/woff2" crossorigin />
		<style>
			/* Self-hosted font subsets — inlined to remove fonts.css from the critical request chain. */
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/jetbrains-mono-400-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/jetbrains-mono-600-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/jetbrains-mono-700-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:400;font-display:swap;src:url(/fonts/jetbrains-mono-400-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/jetbrains-mono-600-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
			@font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/jetbrains-mono-700-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/outfit-600-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/outfit-700-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:900;font-display:swap;src:url(/fonts/outfit-900-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:600;font-display:swap;src:url(/fonts/outfit-600-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:700;font-display:swap;src:url(/fonts/outfit-700-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
			@font-face{font-family:'Outfit';font-style:normal;font-weight:900;font-display:swap;src:url(/fonts/outfit-900-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
		</style>
		<link rel="canonical" href={canonicalUrl} />
		{alternateUrl && alternateLang && (
			<>
				<link rel="alternate" hreflang={lang} href={internalUrl} />
				<link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
				<link rel="alternate" hreflang="x-default" href={lang === 'es' ? internalUrl : alternateUrl} />
			</>
		)}
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="aitorevi.dev" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<title>{title}</title>
		<!-- WCAG 2.3.3: apply motion preference before first paint to avoid flicker -->
		<script is:inline>
			(function(){var m=localStorage.getItem('motion-preference');if(m==='reduce')document.documentElement.setAttribute('data-motion-reduce','');})();
		</script>
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.documentElement.classList.add('dark');
				}
				})();
			// Swallow the benign race condition from Chrome's View Transitions
			// API. When navigations overlap (quick clicks, back/forward during
			// animation) the .finished promise rejects with InvalidStateError.
			// Astro ClientRouter doesn't catch it, so it surfaces as noisy
			// "Uncaught (in promise)" with no functional effect. Registered
			// inline so it runs before any ClientRouter navigation.
			window.addEventListener('unhandledrejection', function(event) {
				var reason = event.reason;
				if (reason && reason.name === 'InvalidStateError' &&
					typeof reason.message === 'string' &&
					reason.message.indexOf('Transition was aborted') !== -1) {
					event.preventDefault();
				}
			});
			// Gate Vercel Analytics behind consent. The Analytics component
			// reads window.webAnalyticsBeforeSend before sending any event;
			// returning null cancels it. Must be set before the custom element
			// mounts (end of body), which is why it lives here in the head.
			window.webAnalyticsBeforeSend = function(event) {
				var m = document.cookie.match(/(?:^|; )aitorevi_consent=(granted|denied)/);
				return m && m[1] === 'granted' ? event : null;
			};
		</script>
		<!-- retro.css (~19 KiB) is only loaded when the Konami mode is active.
		     On first activation window.__loadRetroCss() is called; on subsequent
		     visits it is loaded only when localStorage retro === '1'. -->
		<script is:inline>
			(function () {
				function loadRetro() {
					if (document.getElementById('retro-css')) return;
					var l = document.createElement('link');
					l.id = 'retro-css';
					l.rel = 'stylesheet';
					l.href = '/retro.css';
					document.head.appendChild(l);
				}
				if (localStorage.getItem('retro') === '1') {
					document.documentElement.setAttribute('data-retro', '');
					loadRetro();
				}
				window.__loadRetroCss = loadRetro;
			})();
		</script>
		<ClientRouter />
		{import.meta.env.PUBLIC_GSC_VERIFICATION && (
			<meta name="google-site-verification" content={import.meta.env.PUBLIC_GSC_VERIFICATION} />
		)}
		<slot name="head" />
		<GoogleAnalytics />
	</head>
	<body
		class="flex flex-col min-h-dvh bg-white dark:bg-page text-primary dark:text-fg scrollbar scrollbar-thumb-primary scrollbar-w-2 scrollbar-corner-rounded-xl"
		data-bg={variant}
	>
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-4 focus:left-4 focus:rounded focus:bg-white dark:focus:bg-ink-900 focus:px-4 focus:py-2 focus:text-secondary focus:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary"
		>
			{t(lang, 'misc.skipToContent')}
		</a>
		<Nav alternateUrl={alternatePath} />
		<main id="main-content" class="flex-1 relative z-0">
			<slot/>
		</main>
		<Footer />
		<Analytics />
		<CookieConsent />
	</body>
</html>
<style is:global>
	/* WCAG 2.4.12 Focus Not Obscured (Enhanced, AAA): keep focused elements
	   clear of the fixed navigation bar. Mobile nav: h-14 (56px); desktop: h-20 (80px). */
	html {
		scroll-padding-top: 56px;
	}
	@media (min-width: 768px) {
		html {
			scroll-padding-top: 80px;
		}
	}

	body[data-bg="dark-radial"] {
		background-color: #f8fafc;
		background-image: none;
	}
	html.dark body[data-bg="dark-radial"],
	html.dark body[data-bg="dark-radial"] main {
		background-color: theme(colors.ink.900);
		background-image: radial-gradient(ellipse at 30% 20%, theme(colors.ink.700) 0%, theme(colors.ink.900) 55%, #000 100%);
		background-size: cover;
	}

	body[data-bg="flat"] {
		background-color: rgb(var(--color-bg-content));
	}
	html.dark body[data-bg="flat"] {
		background-color: rgb(var(--color-bg-content));
	}

	::-webkit-scrollbar {
		height: .6rem;
		width: .5rem;
	}

	::-webkit-scrollbar-track {
		background: rgb(var(--color-scrollbar-track) / 0.6);
	}

	::-webkit-scrollbar-track:hover {
		background: rgb(var(--color-scrollbar-track) / 0.6);
	}

	::-webkit-scrollbar-thumb {
		background: rgb(var(--color-scrollbar-thumb));
		border-radius: 0.25rem;
	}

	::-webkit-scrollbar-thumb:hover {
		background: rgb(var(--color-scrollbar-thumb-hover));
		border-radius: 0.25rem;
	}
</style>
<script>
	function applyTheme() {
		const theme = localStorage.getItem('theme');
		if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
			document.documentElement.classList.add('dark');
		} else {
			document.documentElement.classList.remove('dark');
		}
	}

	function applyRetro() {
		if (localStorage.getItem('retro') === '1') {
			document.documentElement.dataset.retro = '';
		} else {
			delete document.documentElement.dataset.retro;
		}
	}

	// astro:before-swap fires while the incoming document is still off-DOM,
	// so we can stamp data-retro / dark on its <html> *before* the swap is
	// painted. Without this, the new page briefly renders without the
	// retro/dark attributes (only set in after-swap), causing flickers like
	// the retro toggle changing width during ES↔EN navigation.
	document.addEventListener('astro:before-swap', (event) => {
		const incoming = event.newDocument.documentElement;
		const theme = localStorage.getItem('theme');
		if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
			incoming.classList.add('dark');
		} else {
			incoming.classList.remove('dark');
		}
		if (localStorage.getItem('retro') === '1') {
			incoming.dataset.retro = '';
		} else {
			delete incoming.dataset.retro;
		}
	});

	document.addEventListener('astro:after-swap', applyTheme);
	document.addEventListener('astro:after-swap', applyRetro);
	document.addEventListener('astro:after-swap', () => {
		const main = document.getElementById('main-content');
		if (!main) return;
		main.setAttribute('tabindex', '-1');
		main.focus();
		main.removeAttribute('tabindex');
	});

	window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
		if (!localStorage.getItem('theme')) applyTheme();
	});
</script>
<script>
	// Secret shortcut: press G then A within 1s to open Keystatic
	let lastKey = '';
	let lastTime = 0;
	document.addEventListener('keydown', (e) => {
		if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
		const now = Date.now();
		if (e.key === 'g') { lastKey = 'g'; lastTime = now; return; }
		if (e.key === 'a' && lastKey === 'g' && now - lastTime < 1000) {
			window.location.href = '/keystatic';
		} else {
			lastKey = '';
		}
	});

	// Hidden retro mode trigger.
	// Desktop: classic Konami code (↑↑↓↓←→←→BA).
	// Anywhere (incl. mobile): three rapid taps on any element marked
	// with [data-retro-tap] — currently the cassette tile in the
	// case-study stack section.
	function toggleRetro() {
		const html = document.documentElement;
		if (html.hasAttribute('data-retro')) {
			html.removeAttribute('data-retro');
			localStorage.removeItem('retro');
		} else {
			(window as Window & { __loadRetroCss?: () => void }).__loadRetroCss?.();
			html.setAttribute('data-retro', '');
			localStorage.setItem('retro', '1');
		}
	}

	const KONAMI = [
		'ArrowUp','ArrowUp','ArrowDown','ArrowDown',
		'ArrowLeft','ArrowRight','ArrowLeft','ArrowRight',
		'b','a',
	];
	let konamiIdx = 0;
	document.addEventListener('keydown', (e) => {
		if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
		const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
		if (key === KONAMI[konamiIdx]) {
			konamiIdx++;
			if (konamiIdx === KONAMI.length) {
				toggleRetro();
				konamiIdx = 0;
			}
		} else {
			konamiIdx = key === KONAMI[0] ? 1 : 0;
		}
	});

	let retroTaps: number[] = [];
	document.addEventListener('click', (e) => {
		const target = e.target instanceof Element ? e.target.closest('[data-retro-tap]') : null;
		if (!target) return;
		const now = Date.now();
		retroTaps = retroTaps.filter((t) => now - t < 1200);
		retroTaps.push(now);
		if (retroTaps.length >= 3) {
			toggleRetro();
			retroTaps = [];
		}
	});
</script>
