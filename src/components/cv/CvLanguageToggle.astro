---
import type { Lang } from '../../data/cv';

interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;
---

<div class="flex gap-2">
  <a
    href="/cv"
    class:list={[
      'px-3 py-1 rounded text-sm font-bold transition ease-linear duration-150',
      currentLang === 'es'
        ? 'bg-secondary text-white'
        : 'border border-secondary text-secondary hover:bg-secondary hover:text-white',
    ]}
  >
    ES
  </a>
  <a
    href="/cv/en"
    class:list={[
      'px-3 py-1 rounded text-sm font-bold transition ease-linear duration-150',
      currentLang === 'en'
        ? 'bg-secondary text-white'
        : 'border border-secondary text-secondary hover:bg-secondary hover:text-white',
    ]}
  >
    EN
  </a>
</div>
