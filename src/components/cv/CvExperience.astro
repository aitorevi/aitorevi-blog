---
import type { ExperienceEntry } from '../../data/cv';
import CvExperienceItem from './CvExperienceItem.astro';
import Tag from '../atoms/Tag.astro';

interface Props {
  label: string;
  entries: ExperienceEntry[];
}

const { label, entries } = Astro.props;

// Flatten all bullets with their parent entry info for zigzag layout
const items = entries.flatMap((entry) =>
  entry.bullets.map((bullet) => ({
    company: entry.company,
    role: entry.role,
    heading: bullet.heading,
    text: bullet.text,
    period: bullet.period,
    tags: bullet.tags,
  }))
);
---

<section class="mb-8 md:mb-10">
  <h2 class="text-2xl font-bold mb-8 border-b-2 border-secondary pb-2">{label}</h2>

  <!-- Mobile: linear timeline (same as before) -->
  <div class="md:hidden">
    {entries.map((entry, i) => (
      <CvExperienceItem
        entry={entry}
        isFirst={i === 0}
        isLast={i === entries.length - 1}
      />
    ))}
  </div>

  <!-- Desktop: zigzag timeline -->
  <div class="hidden md:block relative">
    <!-- Center line -->
    <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-0.5 bg-secondary/25 dark:bg-secondary/35 shadow-[0_0_4px_rgba(94,58,238,0.15)] dark:shadow-[0_0_6px_rgba(94,58,238,0.25)]"></div>

    {items.map((item, i) => {
      const isLeft = i % 2 === 0;
      const isFirst = i === 0;
      const isLast = i === items.length - 1;

      return (
        <div class="relative flex items-start mb-10 last:mb-0">
          <!-- Center dot -->
          <div class="absolute left-1/2 -translate-x-1/2 top-1 z-10">
            <div class:list={[
              "rounded-full",
              isFirst
                ? "h-4 w-4 border-2 border-secondary bg-secondary shadow-[0_0_10px_rgba(94,58,238,0.5)]"
                : "h-3 w-3 border-2 border-secondary/50 bg-white dark:bg-[#1a1f2e]"
            ]}>
              {isFirst && (
                <span class="absolute -inset-1 rounded-full bg-secondary/20 animate-pulse"></span>
              )}
            </div>
          </div>

          {/* Left side */}
          <div class:list={["w-[calc(50%-24px)]", isLeft ? "text-right pr-4" : "pr-4"]}>
            {isLeft ? (
              /* Content on the left */
              <div>
                <div class="flex flex-col items-end">
                  <span class="text-xs text-secondary/70 dark:text-secondary/80 font-semibold uppercase tracking-wider mb-1">{item.company} · {item.role}</span>
                  <strong class="text-[0.95rem] leading-snug">{item.heading}</strong>
                </div>
                {item.text && (
                  <p class="text-sm text-slate-600 dark:text-slate-300 mt-1.5 leading-relaxed">{item.text}</p>
                )}
                {item.tags && item.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2 justify-end">
                    {item.tags.map((tag) => (
                      <Tag label={tag} variant="accent" />
                    ))}
                  </div>
                )}
              </div>
            ) : (
              /* Period on the left */
              <div class="flex items-start justify-end h-full pt-0.5">
                {item.period && (
                  <span class="text-sm text-slate-500 dark:text-slate-400 font-mono tracking-tight">{item.period}</span>
                )}
              </div>
            )}
          </div>

          {/* Center gap */}
          <div class="w-12 shrink-0"></div>

          {/* Right side */}
          <div class:list={["w-[calc(50%-24px)]", !isLeft ? "text-left pl-4" : "pl-4"]}>
            {!isLeft ? (
              /* Content on the right */
              <div>
                <div class="flex flex-col items-start">
                  <span class="text-xs text-secondary/70 dark:text-secondary/80 font-semibold uppercase tracking-wider mb-1">{item.company} · {item.role}</span>
                  <strong class="text-[0.95rem] leading-snug">{item.heading}</strong>
                </div>
                {item.text && (
                  <p class="text-sm text-slate-600 dark:text-slate-300 mt-1.5 leading-relaxed">{item.text}</p>
                )}
                {item.tags && item.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    {item.tags.map((tag) => (
                      <Tag label={tag} variant="accent" />
                    ))}
                  </div>
                )}
              </div>
            ) : (
              /* Period on the right */
              <div class="flex items-start h-full pt-0.5">
                {item.period && (
                  <span class="text-sm text-slate-500 dark:text-slate-400 font-mono tracking-tight">{item.period}</span>
                )}
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>
</section>
