---
import { Icon } from 'astro-icon/components';

interface Props {
  pdfPath: string;
  label: string;
}

const { pdfPath, label } = Astro.props;
---

<div class="flex justify-end mt-6">
  <a
    href={pdfPath}
    download
    class="flex items-center gap-2 text-quaternary hover:text-secondary transition ease-linear duration-150 text-sm font-bold"
  >
    <Icon name="download" class="w-5 h-5" />
    <span>{label}</span>
  </a>
</div>
