---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="flex items-center gap-4 mb-8 reveal-fade">
  <div class="h-px flex-1 bg-gradient-to-r from-transparent to-secondary/30 dark:to-accent-violet/50"></div>
  <h2 class="text-2xl font-display font-bold tracking-tight whitespace-nowrap dark:text-slate-100">
    {label}
  </h2>
  <div class="h-px flex-1 bg-gradient-to-l from-transparent to-secondary/30 dark:to-accent-violet/50"></div>
</div>
