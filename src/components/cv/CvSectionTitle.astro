---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="flex items-center gap-4 mb-8">
  <div class="h-px flex-1 bg-gradient-to-r from-transparent to-secondary/30 dark:to-secondary/40"></div>
  <h2 class="text-2xl font-bold whitespace-nowrap">
    {label}
  </h2>
  <div class="h-px flex-1 bg-gradient-to-l from-transparent to-secondary/30 dark:to-secondary/40"></div>
</div>
