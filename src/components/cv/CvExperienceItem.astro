---
import type { ExperienceEntry } from '@/data/cv';
import Tag from '@/components/shared/Tag.astro';

interface Props {
  entry: ExperienceEntry;
  isFirst?: boolean;
  isLast?: boolean;
}

const { entry, isFirst = false, isLast = false } = Astro.props;
const bullets = entry.bullets;
---

<!-- Company header row -->
<div class="flex gap-3 md:gap-5">
  <!-- Timeline track -->
  <div class="flex flex-col items-center shrink-0 w-4">
    <div class:list={[
      "relative mt-1 h-4 w-4 rounded-full border-2 shrink-0 z-10",
      isFirst
        ? "border-accent bg-accent shadow-glow-accent-dot"
        : "border-accent/50 bg-white dark:bg-ink-800"
    ]}>
      {isFirst && (
        <span class="absolute -inset-1 rounded-full bg-accent/20 animate-pulse"></span>
      )}
    </div>
    <div class="w-0.5 flex-1 bg-accent/25 shadow-glow-accent-line"></div>
  </div>
  <!-- Company content -->
  <div class="flex-1 pb-4">
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between">
      <div>
        <h3 class="text-xl font-bold leading-tight text-accent">{entry.company}</h3>
        <p class="text-accent font-semibold text-sm">{entry.role}</p>
      </div>
      {entry.period && (
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 md:mt-0 font-mono tracking-tight">{entry.period}</p>
      )}
    </div>
  </div>
</div>

<!-- Bullet rows -->
{bullets.map((bullet, i) => {
  const isLastBullet = isLast && i === bullets.length - 1;
  return (
    <div class="flex gap-3 md:gap-5">
      <!-- Timeline track -->
      <div class="flex flex-col items-center shrink-0 w-4">
        <div class:list={[
          "mt-1 h-2.5 w-2.5 rounded-full shrink-0 z-10 transition-colors",
          isFirst && i === 0
            ? "bg-accent shadow-glow-accent-bullet"
            : "bg-accent/30 border border-accent/40"
        ]}></div>
        {!isLastBullet && (
          <div class="w-0.5 flex-1 bg-accent/20 shadow-glow-accent-line"></div>
        )}
      </div>
      <!-- Bullet content -->
      <div class:list={["flex-1", isLastBullet ? "pb-0" : "pb-5"]}>
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
          <strong class="text-[0.95rem] leading-snug">{bullet.heading}</strong>
          {bullet.period && (
            <span class="text-xs text-slate-500 dark:text-slate-400 font-mono tracking-tight whitespace-nowrap">{bullet.period}</span>
          )}
        </div>
        {bullet.text && (
          <p class="text-sm text-slate-600 dark:text-slate-300 mt-1.5 leading-relaxed">{bullet.text}</p>
        )}
        {bullet.tags && bullet.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-2">
            {bullet.tags.map((tag) => (
              <Tag label={tag} variant="accent" />
            ))}
          </div>
        )}
      </div>
    </div>
  );
})}
