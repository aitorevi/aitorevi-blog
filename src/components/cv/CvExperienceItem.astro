---
import type { ExperienceEntry } from '../../data/cv';
import Tag from '../atoms/Tag.astro';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<div class="mb-8 last:mb-0">
  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-3">
    <div>
      <h3 class="text-xl font-bold">{entry.company}</h3>
      <p class="text-secondary font-semibold">{entry.role}</p>
    </div>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 md:mt-0">{entry.period}</p>
  </div>
  <ul class="space-y-3 ml-1">
    {entry.bullets.map((bullet) => (
      <li class="flex gap-2">
        <span class="text-secondary mt-1 shrink-0">*</span>
        <div>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <strong>{bullet.heading}</strong>
            {bullet.period && <span class="text-sm text-slate-500 dark:text-slate-400">{bullet.period}</span>}
          </div>
          {bullet.text && <p class="text-sm text-slate-600 dark:text-slate-300 mt-1">{bullet.text}</p>}
          {bullet.tags && bullet.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-1.5">
              {bullet.tags.map((tag) => (
                <Tag label={tag} variant="accent" />
              ))}
            </div>
          )}
        </div>
      </li>
    ))}
  </ul>
</div>
