---
import type { EducationEntry } from '../../data/cv';

interface Props {
  label: string;
  entries: EducationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <h2 class="text-2xl font-bold mb-6 border-b-2 border-secondary pb-2">{label}</h2>

  <!-- Mobile: linear timeline -->
  <div class="md:hidden">
    {entries.map((entry, i) => {
      const isLast = i === entries.length - 1;
      return (
        <div class="flex gap-3">
          <div class="flex flex-col items-center shrink-0 w-4">
            <div class="mt-[9px] h-2.5 w-2.5 rounded-full bg-secondary/30 dark:bg-secondary/40 border border-secondary/40 dark:border-secondary/50 shrink-0 z-10"></div>
            {!isLast && (
              <div class="flex-1 w-0 border-l-2 border-dotted border-secondary/20 dark:border-secondary/30"></div>
            )}
          </div>
          <div class:list={["flex-1", isLast ? "pb-0" : "pb-5"]}>
            <h3 class="text-lg font-bold">{entry.degree}</h3>
            <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
            <span class="text-xs text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Desktop: mini zigzag -->
  <div class="hidden md:block relative">
    <!-- Center line -->
    <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-0 border-l-2 border-dotted border-secondary/20 dark:border-secondary/30"></div>

    {entries.map((entry, i) => {
      const isLeft = i % 2 === 0;
      return (
        <div class="relative flex items-start mb-8 last:mb-0">
          <!-- Center dot -->
          <div class="absolute left-1/2 -translate-x-1/2 top-1 z-10">
            <div class="h-3 w-3 rounded-full border-2 border-secondary/50 bg-white dark:bg-[#1a1f2e]"></div>
          </div>

          {/* Left side */}
          <div class:list={["w-[calc(50%-24px)]", isLeft ? "text-right pr-4" : "pr-4"]}>
            {isLeft ? (
              <div>
                <h3 class="text-lg font-bold">{entry.degree}</h3>
                <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
              </div>
            ) : (
              <div class="flex items-start justify-end pt-0.5">
                <span class="text-sm text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
              </div>
            )}
          </div>

          {/* Center gap */}
          <div class="w-12 shrink-0"></div>

          {/* Right side */}
          <div class:list={["w-[calc(50%-24px)]", !isLeft ? "text-left pl-4" : "pl-4"]}>
            {!isLeft ? (
              <div>
                <h3 class="text-lg font-bold">{entry.degree}</h3>
                <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
              </div>
            ) : (
              <div class="flex items-start pt-0.5">
                <span class="text-sm text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>
</section>
