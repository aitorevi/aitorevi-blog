---
import type { EducationEntry } from '../../data/cv';
import CvSectionTitle from './CvSectionTitle.astro';

interface Props {
  label: string;
  entries: EducationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <CvSectionTitle label={label} />

  <!-- Mobile: linear timeline -->
  <div class="md:hidden">
    {entries.map((entry, i) => {
      const isLast = i === entries.length - 1;
      return (
        <div class="flex gap-3">
          <div class="flex flex-col items-center shrink-0 w-4">
            <div class="mt-[9px] h-2.5 w-2.5 rounded-full bg-secondary/30 dark:bg-secondary/40 border border-secondary/40 dark:border-secondary/50 shrink-0 z-10"></div>
            {!isLast && (
              <div class="flex-1 w-0 border-l-2 border-dotted border-secondary/20 dark:border-secondary/30"></div>
            )}
          </div>
          <div class:list={["flex-1", isLast ? "pb-0" : "pb-5"]}>
            <h3 class="text-lg font-bold">{entry.degree}</h3>
            <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
            <span class="text-xs text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Desktop: dates left | dot | content right -->
  <div class="hidden md:block relative">
    {entries.map((entry, i) => {
      const isLast = i === entries.length - 1;
      return (
        <div class="flex items-stretch">
          {/* Date column */}
          <div class="w-44 shrink-0 text-right pr-6 pt-1">
            <span class="text-sm text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
          </div>

          {/* Timeline track */}
          <div class="flex flex-col items-center shrink-0 w-5">
            <div class="mt-0.5 h-3 w-3 rounded-full border-2 border-secondary/50 bg-white dark:bg-[#1a1f2e] shrink-0 z-10"></div>
            {!isLast && (
              <div class="flex-1 w-0 border-l-2 border-dotted border-secondary/20 dark:border-secondary/30"></div>
            )}
          </div>

          {/* Content column */}
          <div class:list={["flex-1 pl-6", isLast ? "pb-0" : "pb-6"]}>
            <h3 class="text-lg font-bold">{entry.degree}</h3>
            <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
          </div>
        </div>
      );
    })}
  </div>
</section>
