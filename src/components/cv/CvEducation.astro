---
import type { EducationEntry } from '../../data/cv';

interface Props {
  label: string;
  entries: EducationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <h2 class="text-2xl font-bold mb-4 border-b-2 border-secondary pb-2">{label}</h2>
  {entries.map((entry, i) => {
    const isLast = i === entries.length - 1;
    return (
      <div class="flex gap-3 md:gap-5">
        {/* Timeline track */}
        <div class="flex flex-col items-center shrink-0 w-4">
          <div class="mt-1 h-2.5 w-2.5 rounded-full bg-secondary/30 dark:bg-secondary/40 border border-secondary/40 dark:border-secondary/50 shrink-0 z-10"></div>
          {!isLast && (
            <div class="w-0.5 flex-1 bg-gradient-to-b from-secondary/20 to-secondary/10 dark:from-secondary/30 dark:to-secondary/15"></div>
          )}
        </div>
        {/* Content */}
        <div class:list={["flex-1", isLast ? "pb-0" : "pb-5"]}>
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-1">
            <h3 class="text-lg font-bold">{entry.degree}</h3>
            <span class="text-xs text-slate-500 dark:text-slate-400 font-mono tracking-tight">{entry.period}</span>
          </div>
          <p class="text-secondary font-semibold text-sm">{entry.institution}</p>
        </div>
      </div>
    );
  })}
</section>
