---
import type { EducationEntry } from '../../data/cv';

interface Props {
  label: string;
  entries: EducationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <h2 class="text-2xl font-bold mb-4 border-b-2 border-secondary pb-2">{label}</h2>
  {entries.map((entry) => (
    <div class="mb-4 last:mb-0">
      <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-1">
        <h3 class="text-lg font-bold">{entry.degree}</h3>
        <p class="text-sm text-quaternary mt-1 md:mt-0">{entry.period}</p>
      </div>
      <p class="text-secondary font-semibold">{entry.institution}</p>
    </div>
  ))}
</section>
