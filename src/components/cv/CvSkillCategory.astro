---
import type { SkillCategoryData } from '../../data/cv';
import Tag from '../atoms/Tag.astro';

interface Props {
  category: SkillCategoryData;
}

const { category } = Astro.props;
---

<div class="reveal-fade group relative rounded-xl p-4 border border-secondary/15 bg-slate-50/30 dark:border-white/10 dark:bg-white/[0.04] dark:backdrop-blur-sm hover:border-secondary/30 dark:hover:border-accent-blue/40 dark:hover:bg-white/[0.06] dark:hover:shadow-[0_0_30px_rgba(96,165,250,0.1)] transition-all duration-300">
  <h3 class="font-display font-bold mb-3 text-base text-secondary dark:text-accent-violet tracking-tight">{category.name}</h3>
  <div class="flex flex-wrap gap-1.5">
    {category.skills.map((skill) => (
      <Tag label={skill} variant="accent" />
    ))}
  </div>
</div>
