---
/**
 * CvPrintLayout — standalone ATS-optimised PDF layout.
 *
 * Does NOT import any web CV components. All content is rendered directly
 * from the CvData prop so there are no Tailwind class overrides, no timeline
 * dots, no dark-mode styles, and no responsive variants to fight against.
 *
 * Design goals:
 * - Single page A4
 * - Single color (#1e293b) — ATS-friendly, readable by bots and humans
 * - Zero decorative elements: no dots, borders, shadows, icons
 * - Skills rendered as inline comma-separated lists to save vertical space
 */
import type { CvData } from '@/data/cv';
import type { Lang } from '@/i18n/types';

interface Props {
  data: CvData;
  lang: Lang;
}

const { data, lang } = Astro.props;
const { contact } = data;

const contactItems = [
  contact.location,
  ...contact.links.map((l) =>
    l.url.startsWith('mailto:') ? l.url.replace('mailto:', '') : l.url.replace('https://', '')
  ),
];
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{data.labels.pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="cv">

      <!-- HEADER -->
      <header>
        <h1>{contact.name}</h1>
        <p class="title">{contact.title}</p>
        <p class="contact">{contactItems.join(' · ')}</p>
      </header>

      <!-- PERFIL -->
      <section>
        <h2>{data.labels.profile}</h2>
        <p>{data.summary}</p>
      </section>

      <!-- EXPERIENCIA -->
      <section>
        <h2>{data.labels.experience}</h2>
        {data.experience.map((entry) =>
          entry.bullets.map((bullet) => (
            <div class="entry">
              <div class="entry-header">
                <span class="entry-company">{entry.company} · {entry.role}</span>
                {bullet.period && <span class="entry-period">{bullet.period}</span>}
              </div>
              <strong class="entry-heading">{bullet.heading}</strong>
              {bullet.text && <p class="entry-text">{bullet.text}</p>}
              {bullet.tags && bullet.tags.length > 0 && (
                <p class="entry-tags">{bullet.tags.join(' · ')}</p>
              )}
            </div>
          ))
        )}
      </section>

      <!-- FORMACIÓN -->
      <section>
        <h2>{data.labels.education}</h2>
        {data.education.map((entry) => (
          <div class="entry">
            <div class="entry-header">
              <strong class="entry-heading">{entry.degree}</strong>
              {entry.period && <span class="entry-period">{entry.period}</span>}
            </div>
            <span class="entry-company">{entry.institution}</span>
          </div>
        ))}
      </section>

      <!-- CERTIFICACIONES -->
      <section>
        <h2>{data.labels.certifications}</h2>
        <div class="cert-grid">
          {data.certifications.map((cert) => (
            <div class="cert">
              <strong>{cert.name}</strong>
              <span class="entry-company">{cert.institution}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- APTITUDES -->
      <section>
        <h2>{data.labels.skills}</h2>
        <div class="skills">
          {data.skills.map((cat) => (
            <div class="skill-row">
              <span class="skill-cat">{cat.name}:</span>
              <span>{cat.skills.join(' · ')}</span>
            </div>
          ))}
        </div>
      </section>

    </div>
  </body>
</html>

<style>
  @page {
    size: A4;
    margin: 9mm 14mm;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8.5pt;
    line-height: 1.35;
    color: #1e293b;
    background: white;
  }

  .cv {
    max-width: 100%;
  }

  /* HEADER */
  header {
    text-align: center;
    margin-bottom: 10pt;
    padding-bottom: 8pt;
    border-bottom: 1pt solid #1e293b;
  }

  h1 {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0f172a;
    margin-bottom: 2pt;
  }

  .title {
    font-size: 9.5pt;
    font-weight: 600;
    margin-bottom: 3pt;
  }

  .contact {
    font-size: 7.5pt;
    color: #475569;
  }

  /* SECTIONS */
  section {
    margin-bottom: 8pt;
  }

  h2 {
    font-size: 9pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 0.5pt solid #1e293b;
    padding-bottom: 2pt;
    margin-bottom: 5pt;
    color: #0f172a;
  }

  /* ENTRIES (experience & education) */
  .entry {
    margin-bottom: 5pt;
    page-break-inside: avoid;
  }

  .entry:last-child {
    margin-bottom: 0;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8pt;
  }

  .entry-company {
    font-size: 7.5pt;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .entry-period {
    font-size: 7.5pt;
    color: #64748b;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-heading {
    display: block;
    font-size: 9pt;
    font-weight: 700;
    color: #0f172a;
    margin-top: 1pt;
  }

  .entry-text {
    font-size: 8pt;
    color: #334155;
    margin-top: 2pt;
    line-height: 1.4;
  }

  .entry-tags {
    font-size: 7pt;
    color: #64748b;
    margin-top: 2pt;
  }

  /* CERTIFICATIONS */
  .cert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3pt 16pt;
  }

  .cert {
    display: flex;
    flex-direction: column;
  }

  .cert strong {
    font-size: 8pt;
    font-weight: 700;
    color: #0f172a;
  }

  /* SKILLS */
  .skills {
    display: flex;
    flex-direction: column;
    gap: 3pt;
  }

  .skill-row {
    font-size: 8pt;
    line-height: 1.4;
  }

  .skill-cat {
    font-weight: 700;
    color: #0f172a;
    margin-right: 4pt;
  }
</style>
