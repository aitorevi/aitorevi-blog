---
import type { SkillCategoryData } from '@/data/cv';
import CvSkillCategory from './CvSkillCategory.astro';
import CvSectionTitle from './CvSectionTitle.astro';
import type { Lang } from '@/i18n/types';

interface Props {
  label: string;
  categories: SkillCategoryData[];
  lang: Lang;
}

const { label, categories, lang } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <CvSectionTitle label={label} />
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal-group">
    {categories.map((cat) => (
      <CvSkillCategory category={cat} lang={lang} />
    ))}
  </div>
</section>
