---
import type { SkillCategoryData } from '../../data/cv';
import CvSkillCategory from './CvSkillCategory.astro';

import CvSectionTitle from './CvSectionTitle.astro';

interface Props {
  label: string;
  categories: SkillCategoryData[];
}

const { label, categories } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <CvSectionTitle label={label} />
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {categories.map((cat) => (
      <CvSkillCategory category={cat} />
    ))}
  </div>
</section>
