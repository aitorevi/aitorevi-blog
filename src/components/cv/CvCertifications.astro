---
import type { CertificationEntry } from '../../data/cv';

interface Props {
  label: string;
  entries: CertificationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <h2 class="text-2xl font-bold mb-6 border-b-2 border-secondary pb-2">{label}</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {entries.map((entry) => (
      <div class="group relative border border-secondary/15 dark:border-secondary/20 rounded-lg p-4 bg-slate-50/30 dark:bg-slate-800/20 hover:border-secondary/40 dark:hover:border-secondary/40 hover:shadow-[0_0_12px_rgba(94,58,238,0.08)] dark:hover:shadow-[0_0_12px_rgba(94,58,238,0.15)] transition-all duration-200">
        <div class="flex items-start gap-3">
          <div class="mt-1 h-2.5 w-2.5 rounded-full bg-secondary/30 dark:bg-secondary/40 border border-secondary/40 dark:border-secondary/50 shrink-0"></div>
          <div>
            <h3 class="text-base font-bold leading-snug">{entry.name}</h3>
            <p class="text-secondary font-semibold text-sm mt-0.5">{entry.institution}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
