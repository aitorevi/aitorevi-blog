---
import type { CertificationEntry } from '../../data/cv';
import CvSectionTitle from './CvSectionTitle.astro';

interface Props {
  label: string;
  entries: CertificationEntry[];
}

const { label, entries } = Astro.props;
---

<section class="mb-8 md:mb-10">
  <CvSectionTitle label={label} />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal-group">
    {entries.map((entry) => (
      <div class="reveal-fade group relative rounded-xl p-4 border border-secondary/15 bg-slate-50/30 dark:border-white/10 dark:bg-white/[0.04] dark:backdrop-blur-sm hover:border-secondary/40 dark:hover:border-accent-blue/40 dark:hover:bg-white/[0.06] hover:shadow-[0_0_12px_rgba(94,58,238,0.08)] dark:hover:shadow-[0_0_30px_rgba(96,165,250,0.12)] transition-all duration-300">
        <div class="flex items-start gap-3">
          <div class="mt-1 h-2.5 w-2.5 rounded-full bg-secondary/30 dark:bg-accent-violet/50 border border-secondary/40 dark:border-accent-violet/60 shrink-0 group-hover:dark:bg-accent-blue/60 group-hover:dark:border-accent-blue/70 transition-colors"></div>
          <div>
            <h3 class="text-base font-display font-bold leading-snug tracking-tight dark:text-slate-100">{entry.name}</h3>
            <p class="text-secondary dark:text-accent-violet font-semibold text-sm mt-0.5">{entry.institution}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
