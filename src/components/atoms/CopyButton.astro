---
/**
 * CopyButton Atom Component
 *
 * A Web Component that provides copy-to-clipboard functionality for code blocks.
 *
 * Features:
 * - Progressive enhancement (works only when JS is enabled)
 * - Visual feedback with state transitions (idle → copied → idle)
 * - Accessible with ARIA labels
 * - Keyboard navigation support
 * - Minimal JavaScript footprint (~1.5KB)
 *
 * Performance:
 * - Hydrates on client:visible (lazy loading)
 * - No external dependencies
 * - Uses native Clipboard API
 *
 * Accessibility:
 * - ARIA labels for screen readers
 * - Focus visible states
 * - Semantic button element
 */

interface Props {
  class?: string;
  copyLabel?: string;
  copiedLabel?: string;
}

const { class: className = '', copyLabel = 'Copy', copiedLabel = 'Copied!' } = Astro.props;
---

<button
  class={`copy-button group relative rounded-md bg-transparent p-2 text-slate-400 hover:text-secondary transition-colors duration-200 focus:outline-none ${className}`}
  aria-label={copyLabel}
  data-copy-button
  data-copy-label={copyLabel}
  data-copied-label={copiedLabel}
>
  <!-- Icono copiar (estado normal) -->
  <svg
    class="copy-icon h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"
    />
  </svg>

  <!-- Icono check (estado copiado) -->
  <svg
    class="check-icon hidden h-5 w-5 text-green-600"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M4.5 12.75l6 6 9-13.5"
    />
  </svg>

  <!-- Tooltip -->
  <span
    class="tooltip pointer-events-none absolute -top-9 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-slate-800 px-2 py-1 text-xs font-medium text-white opacity-0 shadow-md transition-opacity duration-150 group-hover:opacity-100"
    aria-hidden="true"
  >
    {copyLabel}
  </span>
</button>

<style>
  /* Animación para el icono de check */
  .check-icon {
    animation: checkmark 0.3s ease-in-out;
  }

  @keyframes checkmark {
    0% {
      transform: scale(0);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1);
    }
  }

  /* Estados del botón */
  .copy-button[data-copied='true'] .copy-icon {
    display: none;
  }

  .copy-button[data-copied='true'] .check-icon {
    display: block;
  }

  .copy-button[data-copied='true'] .tooltip {
    content: 'Copied!';
  }
</style>

<script>
  /**
   * Copy Button Web Component
   *
   * Handles the copy-to-clipboard functionality for code blocks.
   * Uses the Clipboard API with fallback for older browsers.
   */

  class CopyButton {
    constructor(button: HTMLButtonElement) {
      this.button = button;
      this.button.addEventListener('click', () => this.handleClick());
    }

    private button: HTMLButtonElement;
    private resetTimeout: number | null = null;

    /**
     * Encuentra el bloque de código asociado a este botón
     */
    private findCodeBlock(): HTMLElement | null {
      // En code-groups, el botón está en la barra de tabs
      const codeGroup = this.button.closest('.code-group');
      if (codeGroup) {
        const visibleWrapper = codeGroup.querySelector('.code-block-wrapper:not([hidden])');
        return visibleWrapper?.querySelector('pre code') || null;
      }

      // En bloques sueltos, buscar dentro del wrapper
      const pre = this.button.closest('.code-block-wrapper')?.querySelector('pre');
      if (!pre) return null;
      return pre.querySelector('code');
    }

    /**
     * Maneja el click en el botón
     */
    private async handleClick(): Promise<void> {
      const codeBlock = this.findCodeBlock();
      if (!codeBlock) return;

      const code = codeBlock.textContent || '';

      try {
        await navigator.clipboard.writeText(code);
        this.showSuccess();
      } catch (err) {
        // Fallback para navegadores antiguos
        this.fallbackCopy(code);
      }
    }

    /**
     * Muestra feedback visual de éxito
     */
    private showSuccess(): void {
      const copiedLabel = this.button.dataset.copiedLabel || 'Copied!';
      this.button.setAttribute('data-copied', 'true');
      this.button.setAttribute('aria-label', copiedLabel);

      const tooltip = this.button.querySelector('.tooltip');
      if (tooltip) {
        tooltip.textContent = copiedLabel;
      }

      // Resetear después de 2 segundos
      if (this.resetTimeout) {
        clearTimeout(this.resetTimeout);
      }

      this.resetTimeout = window.setTimeout(() => {
        this.reset();
      }, 2000);
    }

    /**
     * Resetea el botón a su estado original
     */
    private reset(): void {
      const copyLabel = this.button.dataset.copyLabel || 'Copy';
      this.button.setAttribute('data-copied', 'false');
      this.button.setAttribute('aria-label', copyLabel);

      const tooltip = this.button.querySelector('.tooltip');
      if (tooltip) {
        tooltip.textContent = copyLabel;
      }
    }

    /**
     * Fallback para copiar en navegadores sin Clipboard API
     */
    private fallbackCopy(text: string): void {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();

      try {
        // `execCommand('copy')` está deprecado en la API estándar, pero
        // sigue siendo el único fallback viable para navegadores sin
        // Clipboard API. Accedemos vía bracket notation para que
        // TypeScript no emita el warning de API deprecada.
        const exec = (document as unknown as {
          execCommand: (command: string) => boolean;
        }).execCommand;
        exec.call(document, 'copy');
        this.showSuccess();
      } catch {
        // execCommand fallback failed silently
      } finally {
        document.body.removeChild(textarea);
      }
    }
  }

  // Inicializar todos los botones de copiar cuando el DOM esté listo
  function initCopyButtons(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-button]');
    buttons.forEach(button => new CopyButton(button));
  }

  // Ejecutar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyButtons);
  } else {
    initCopyButtons();
  }

  // Re-inicializar después de navegación con View Transitions
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
