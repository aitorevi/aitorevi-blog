---
/**
 * HomeContent — orchestrator for the redesigned home page.
 *
 * Composes the home sections in order and wraps everything in a single
 * dark container so the page has a continuous background regardless of
 * the site-wide light/dark theme toggle. Individual sections handle
 * their own animations, parallax and IntersectionObservers.
 */
import type { Lang } from '../data/cv';
import HeroParallax from './home/HeroParallax.astro';
import WhatIDo from './home/WhatIDo.astro';
import StatsCounter from './home/StatsCounter.astro';
import TechStack from './home/TechStack.astro';
import LatestPosts from './home/LatestPosts.astro';
import ContactSection from './home/ContactSection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="home-redesign relative isolate bg-ink-900 text-slate-100">
  <HeroParallax lang={lang} />
  <WhatIDo lang={lang} />
  <StatsCounter lang={lang} />
  <TechStack lang={lang} />
  <LatestPosts lang={lang} />
  <ContactSection lang={lang} />
</div>

<style is:global>
  /* Keep the page background dark under the home, even when the site is
     in light mode. This is intentional: the home has its own dark aesthetic. */
  body:has(.home-redesign) {
    background-color: #020617;
    background-image: none;
  }
  body:has(.home-redesign) main {
    background-color: #020617;
  }
  /* Make the fixed Nav blend with the dark home (both in light and dark site themes). */
  body:has(.home-redesign) header {
    background-color: rgba(2, 6, 23, 0.75) !important;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  body:has(.home-redesign) header a,
  body:has(.home-redesign) header button {
    color: #e2e8f0;
  }
  body:has(.home-redesign) header a:hover,
  body:has(.home-redesign) header button:hover {
    color: #a78bfa;
  }
</style>
