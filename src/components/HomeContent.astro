---
import { Image } from "astro:assets";
import type { Lang } from '../data/cv';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="mx-auto max-w-screen-xl bg-grayLight bg-opacity-70 dark:bg-[#1a1f2e] dark:bg-opacity-70 flex mt-16 md:mt-24 mb-2 md:mb-4 p-6 p-6 sm:p-7 md:p-8 lg:p-20 items-center md:justify-start lg:gap-6 rounded">
    <div class="flex flex-col lg:flex-row gap-4 md:gap-8">
        <div class="flex flex-col w-full text-center items-center justify-center font-ibm lg:hidden">
            <div class="items-center gap-10">
                <h1 class="text-3xl sm:text-5xl font-bold mb-2">{lang === 'es' ? '👋' : '👋'}{t(lang, 'home.greeting')}</h1>
                <h1 class="text-3xl sm:text-5xl font-bold mb-2">{t(lang, 'home.name')}</h1>
                <h2 class="text-secondary text-2xl font-bold">{t(lang, 'home.role')}</h2>
            </div>
            <Image
                src="/retrato.webp"
                alt="aitorevi-blog"
                width={64}
                height={64}
                class="w-1/2 lg:hidden"
            />
        </div>
        <article class="w-full lg:w-1/2 text-center lg:text-start font-ibm ">
            <div class="hidden lg:block">
                <h1 class="text-6xl font-bold mb-4">👋{t(lang, 'home.greeting')}</h1>
                <h2 class="text-6xl font-bold mb-4">{t(lang, 'home.name')}</h2>
                <h2 class="text-secondary text-2xl font-bold mb-4 ">{t(lang, 'home.role')}</h2>
            </div>
            <p class="mb-4">{t(lang, 'home.p1')}</p>
            <p class="mb-4">{t(lang, 'home.p2')}</p>
            <p class="mb-4">{t(lang, 'home.p3')}</p>
        </article>
        <Image
                src="/retrato.webp"
                alt="aitorevi-blog"
                width={64}
                height={64}
                class="w-full object-cover md:w-1/2 hidden lg:block"
        />
        </div>
</section>
