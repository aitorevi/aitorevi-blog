---
/**
 * PostCard Molecule Component
 *
 * Displays a blog post preview card with image, metadata, and excerpt.
 *
 * Atomic Composition:
 * - Atoms: Tag, DateDisplay, ReadingTime
 * - Native: HTML5 semantic elements, Astro Image component
 *
 * Accessibility Features:
 * - Semantic HTML5 (article, header, footer)
 * - Heading hierarchy maintained
 * - Image optimization with proper alt text
 * - High contrast ratios (WCAG AA)
 * - Keyboard navigation support
 * - Focus visible states
 *
 * Performance Optimizations:
 * - Zero JavaScript (no hydration)
 * - Astro Image component for automatic optimization
 * - Lazy loading for below-the-fold images
 * - Aspect ratio boxes prevent layout shift (CLS)
 * - Minimal CSS via Tailwind utilities
 *
 * LCP Strategy:
 * - Priority loading for first 2-3 cards
 * - Lazy loading for remainder
 * - Optimized image formats (WebP/AVIF)
 */

import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Tag from '../atoms/Tag.astro';
import DateDisplay from '../atoms/DateDisplay.astro';
import ReadingTime from '../atoms/ReadingTime.astro';
import { calculateReadingTime } from '../../lib/blog';
import { formatDate } from '../../lib/date';
import { t, getBlogSlugFromId } from '../../i18n/utils';

interface Props {
  /**
   * Blog post entry from Content Collection
   */
  post: CollectionEntry<'blog'>;

  /**
   * Priority loading for above-the-fold images
   * Set to true for first 2-3 cards on page
   * @default false
   */
  priority?: boolean;

  /**
   * Show featured badge
   * @default true
   */
  showFeaturedBadge?: boolean;

  /**
   * Language for locale-aware URLs
   * @default 'es'
   */
  lang?: 'es' | 'en';

  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  post,
  priority = false,
  showFeaturedBadge = true,
  lang = 'es',
  class: className = '',
} = Astro.props;

const { data, id, body = '' } = post;
const readingTime = calculateReadingTime(body, lang);

// Generate post URL - strip language prefix from content ID
const slug = getBlogSlugFromId(id);
const postUrl = lang === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;

---

<article
  class={`group relative flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-ink-800 shadow-sm transition-all duration-300 hover:shadow-lg ${className}`}
  itemscope
  itemtype="https://schema.org/BlogPosting"
>
  <!-- Featured Badge (conditionally rendered) -->
  {data.featured && showFeaturedBadge && (
    <div
      class="absolute left-4 top-4 z-[1] rounded-full bg-secondary px-3 py-1 text-xs font-semibold text-white shadow-md"
      aria-label={t(lang, 'blog.featured')}
    >
      {t(lang, 'blog.featured')}
    </div>
  )}

  <!-- Draft Badge (dev only) -->
  {data.draft && import.meta.env.DEV && (
    <div
      class="absolute right-4 top-4 z-[1] rounded-full bg-amber-400 px-3 py-1 text-xs font-semibold text-amber-900 shadow-md"
      aria-label="Draft"
    >
      Draft
    </div>
  )}

  <!-- Cover Image -->
  <a
    href={postUrl}
    class="relative aspect-video w-full overflow-hidden bg-grayLight"
    aria-label={`Read full post: ${data.title}`}
  >
    {data.coverImage ? (
      <Image
        src={data.coverImage}
        alt={data.coverImageAlt || data.title}
        width={800}
        height={450}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        itemprop="image"
      />
    ) : (
      <div
        class="flex h-full w-full items-center justify-center bg-home-radial transition-transform duration-500 group-hover:scale-105"
        role="img"
        aria-label={data.coverImageAlt || data.title}
        itemprop="image"
      >
        <span class="select-none font-display text-4xl font-black tracking-tight text-white md:text-5xl">
          aitorevi<span class="text-accent-violet">.</span>
        </span>
      </div>
    )}
  </a>

  <!-- Card Content -->
  <div class="flex flex-1 flex-col p-6">
    <!-- Header: Tags -->
    <header class="mb-3">
      <div class="flex flex-wrap gap-2" role="list" aria-label="Post tags">
        {data.tags.slice(0, 3).map((tag) => (
          <Tag label={tag} variant="accent" />
        ))}
      </div>
    </header>

    <!-- Main Content -->
    <div class="flex-1 overflow-hidden">
      <h2
        class="mb-3 text-xl font-display font-bold leading-tight text-ink-900 dark:text-slate-100 sm:text-2xl"
        itemprop="headline"
      >
        <a
          href={postUrl}
          class="block hover:text-secondary focus:text-secondary focus:outline-none focus-visible:underline transition-colors duration-200"
        >
          {data.title}
        </a>
      </h2>

      <p
        class="mb-4 line-clamp-5 text-sm text-quaternary sm:text-base"
        itemprop="description"
      >
        {data.description}
      </p>
    </div>

    <!-- Footer: Metadata -->
    <footer
      class="flex items-center justify-between border-t border-slate-200 dark:border-slate-700 pt-4 text-sm"
    >
      <DateDisplay
        date={data.publishDate}
        showIcon={true}
        short={true}
        lang={lang}
      />

      <ReadingTime text={readingTime.text} />

      {data.updatedDate && (
        <>
          <span class="text-gray-300" aria-hidden="true">•</span>
          <span class="text-xs text-quaternary">
            {t(lang, 'blog.updated')} {formatDate(data.updatedDate, lang === 'es' ? 'es-ES' : 'en-US')}
          </span>
        </>
      )}
    </footer>

    <!-- Schema.org metadata (invisible, for SEO) -->
    <meta itemprop="datePublished" content={data.publishDate.toISOString()} />
    {data.updatedDate && (
      <meta itemprop="dateModified" content={data.updatedDate.toISOString()} />
    )}
    <meta itemprop="author" content={data.author.name} />
  </div>
</article>

<style>
  /**
   * line-clamp utility for description truncation
   * Provides graceful degradation for browsers without -webkit-line-clamp
   */
  .line-clamp-5 {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /**
   * Ensure focus states are visible for keyboard navigation
   * Following WCAG 2.1 Focus Visible guidelines
   */
  a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
</style>
