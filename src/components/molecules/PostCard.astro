---
/**
 * PostCard Molecule Component
 *
 * Displays a blog post preview card with image, metadata, and excerpt.
 *
 * Atomic Composition:
 * - Atoms: Tag, DateDisplay, ReadingTime
 * - Native: HTML5 semantic elements, Astro Image component
 *
 * Accessibility Features:
 * - Semantic HTML5 (article, header, footer)
 * - Heading hierarchy maintained
 * - Image optimization with proper alt text
 * - High contrast ratios (WCAG AA)
 * - Keyboard navigation support
 * - Focus visible states
 *
 * Performance Optimizations:
 * - Zero JavaScript (no hydration)
 * - Astro Image component for automatic optimization
 * - Lazy loading for below-the-fold images
 * - Aspect ratio boxes prevent layout shift (CLS)
 * - Minimal CSS via Tailwind utilities
 *
 * LCP Strategy:
 * - Priority loading for first 2-3 cards
 * - Lazy loading for remainder
 * - Optimized image formats (WebP/AVIF)
 */

import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Tag from '../atoms/Tag.astro';
import DateDisplay from '../atoms/DateDisplay.astro';
import ReadingTime from '../atoms/ReadingTime.astro';
import { calculateReadingTime } from '../../lib/utils';

interface Props {
  /**
   * Blog post entry from Content Collection
   */
  post: CollectionEntry<'blog'>;

  /**
   * Priority loading for above-the-fold images
   * Set to true for first 2-3 cards on page
   * @default false
   */
  priority?: boolean;

  /**
   * Show featured badge
   * @default true
   */
  showFeaturedBadge?: boolean;

  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  post,
  priority = false,
  showFeaturedBadge = true,
  class: className = '',
} = Astro.props;

const { data, id, body = '' } = post;
const readingTime = calculateReadingTime(body);

// Generate post URL (Astro 5 uses 'id' instead of 'slug')
const postUrl = `/blog/${id}`;
---

<article
  class={`group relative flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:shadow-lg ${className}`}
  itemscope
  itemtype="https://schema.org/BlogPosting"
>
  <!-- Featured Badge (conditionally rendered) -->
  {data.featured && showFeaturedBadge && (
    <div
      class="absolute left-4 top-4 z-10 rounded-full bg-secondary px-3 py-1 text-xs font-semibold text-white shadow-md"
      aria-label="Featured post"
    >
      Featured
    </div>
  )}

  <!-- Cover Image -->
  <a
    href={postUrl}
    class="relative aspect-video w-full overflow-hidden bg-grayLight"
    aria-label={`Read full post: ${data.title}`}
  >
    <Image
      src={data.coverImage}
      alt={data.coverImageAlt}
      width={1200}
      height={630}
      widths={[400, 600, 800]}
      sizes="(min-width: 1024px) 400px, (min-width: 768px) 50vw, 100vw"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      itemprop="image"
    />
  </a>

  <!-- Card Content -->
  <div class="flex flex-1 flex-col p-6">
    <!-- Header: Tags -->
    <header class="mb-3">
      <div class="flex flex-wrap gap-2" role="list" aria-label="Post tags">
        {data.tags.slice(0, 3).map((tag) => (
          <Tag label={tag} variant="accent" />
        ))}
      </div>
    </header>

    <!-- Main Content -->
    <div class="flex-1">
      <h2
        class="mb-3 text-xl font-bold leading-tight text-primary sm:text-2xl"
        itemprop="headline"
      >
        <a
          href={postUrl}
          class="hover:text-secondary focus:text-secondary focus:outline-none focus-visible:underline"
        >
          {data.title}
        </a>
      </h2>

      <p
        class="mb-4 line-clamp-3 text-sm text-quaternary sm:text-base"
        itemprop="description"
      >
        {data.description}
      </p>
    </div>

    <!-- Footer: Metadata -->
    <footer
      class="flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-gray-200 pt-4 text-sm"
    >
      <DateDisplay
        date={data.publishDate}
        showIcon={true}
      />

      <span class="text-gray-300" aria-hidden="true">•</span>

      <ReadingTime text={readingTime.text} />

      {data.updatedDate && (
        <>
          <span class="text-gray-300" aria-hidden="true">•</span>
          <span class="text-xs text-quaternary">
            Updated {new Date(data.updatedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </span>
        </>
      )}
    </footer>

    <!-- Schema.org metadata (invisible, for SEO) -->
    <meta itemprop="datePublished" content={data.publishDate.toISOString()} />
    {data.updatedDate && (
      <meta itemprop="dateModified" content={data.updatedDate.toISOString()} />
    )}
    <meta itemprop="author" content={data.author.name} />
  </div>
</article>

<style>
  /**
   * line-clamp utility for description truncation
   * Provides graceful degradation for browsers without -webkit-line-clamp
   */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /**
   * Ensure focus states are visible for keyboard navigation
   * Following WCAG 2.1 Focus Visible guidelines
   */
  a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
</style>
