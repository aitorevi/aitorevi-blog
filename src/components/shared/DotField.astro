---
interface Props {
  position?: 'fixed' | 'absolute';
}

const { position = 'absolute' } = Astro.props;

const DOT_COUNT = 60;
const dots = Array.from({ length: DOT_COUNT }, (_, i) => ({
  x: Math.min(((i * 37) % 100) + Math.random() * 2, 97),
  y: Math.min(((i * 53) % 95) + Math.random() * 2, 97),
  size: 1 + ((i * 13) % 4) * 0.6,
  opacity: 0.12 + ((i * 7) % 10) * 0.025,
}));
---

<div
  aria-hidden="true"
  class:list={[
    'retro-hide pointer-events-none inset-0 hidden dark:block text-accent-blue overflow-hidden',
    position === 'fixed' ? 'fixed' : 'absolute',
  ]}
>
  {dots.map((d) => (
    <span
      class="absolute rounded-full bg-current"
      style={`left:${d.x}%;top:${d.y}%;width:${d.size}px;height:${d.size}px;opacity:${d.opacity};`}
    />
  ))}
</div>
