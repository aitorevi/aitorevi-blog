---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<span
  class:list={[
    'inline-flex w-fit items-center rounded-full border border-accent/20 bg-accent/10 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.15em] text-accent',
    className,
  ]}
>
  {label}
</span>
