---
/**
 * DateDisplay Atom Component
 *
 * Displays a formatted date with proper semantic HTML.
 * Uses <time> element with datetime attribute for accessibility and SEO.
 *
 * Zero JavaScript - Server-rendered at build time.
 *
 * Accessibility:
 * - <time> element provides semantic meaning
 * - datetime attribute enables machine-readable dates
 * - aria-label can be customized for screen readers
 *
 * Performance: Pure static HTML
 */

import { formatDate, formatDateISO } from '@/lib/date';
import { getLangLocale, t } from '@/i18n/utils';

interface Props {
  /**
   * Date to display (Date object or ISO string)
   */
  date: Date | string;

  /**
   * Optional locale for formatting
   * @default 'en-US'
   */
  locale?: string;

  /**
   * Language for localised aria-label
   * @default 'en'
   */
  lang?: 'es' | 'en';

  /**
   * Use short month format (e.g., "abr" instead of "abril")
   * @default false
   */
  short?: boolean;

  /**
   * Show icon before date
   * @default false
   */
  showIcon?: boolean;

  /**
   * Additional CSS classes
   */
  class?: string;

  /**
   * Custom aria-label for screen readers
   */
  ariaLabel?: string;
}

const {
  date,
  locale,
  lang = 'en',
  short = false,
  showIcon = false,
  class: className = '',
  ariaLabel,
} = Astro.props;

const resolvedLocale = locale ?? getLangLocale(lang);
const formattedDate = formatDate(date, resolvedLocale, short);
const isoDate = formatDateISO(date);
const label = ariaLabel || `${t(lang, 'blog.publishedOn')} ${formattedDate}`;
---

<time
  datetime={isoDate}
  aria-label={label}
  class={`inline-flex items-center gap-1.5 text-sm text-quaternary ${className}`}
>
  {showIcon && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-4 h-4"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
      />
    </svg>
  )}
  {formattedDate}
</time>
