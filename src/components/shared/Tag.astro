---
interface Props {
  label: string;
  variant?: 'default' | 'accent' | 'muted' | 'crosspost' | 'raw';
  class?: string;
}

const { label, variant = 'default', class: className = '' } = Astro.props;

const variantStyles = {
  default: 'bg-grayLight text-quaternary',
  accent: 'bg-accent/10 text-accent border border-accent/20',
  muted: 'bg-slate-50 text-slate-700 border border-slate-200 dark:bg-white/[0.03] dark:text-slate-400 dark:border-white/10',
  crosspost: 'bg-slate-100 text-slate-600 border border-slate-300 dark:bg-slate-800/40 dark:text-slate-400 dark:border-slate-600',
  raw: 'border',
};

const baseStyles = 'inline-flex w-fit items-center px-2.5 py-0.5 rounded-full font-mono text-[10px] 2xl:text-[12px] uppercase tracking-[0.15em]';
const combinedClasses = `${baseStyles} ${variantStyles[variant]} ${className}`;
---

<span class={combinedClasses}>
  {label}
</span>
