---
import { scoreTone } from './scoreBadgeStyles';

interface Props {
  value: number;
  label: string;
}

const { value, label } = Astro.props;

const circumference = 2 * Math.PI * 42;
const tone = scoreTone(value);
---

<li class="group flex flex-col items-center text-center">
  <div class="relative h-36 w-36" aria-hidden="true">
    <div
      class:list={[
        'pointer-events-none absolute inset-0 rounded-full bg-gradient-to-br to-transparent blur-2xl opacity-80 transition-opacity duration-500 group-hover:opacity-100',
        tone.glow,
      ]}
      aria-hidden="true"
    />
    <svg class="relative h-full w-full -rotate-90" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="42" class="stroke-slate-200/80 dark:stroke-white/10" stroke-width="6" fill="none" />
      <circle
        cx="50"
        cy="50"
        r="42"
        stroke={`url(#${tone.gradId})`}
        stroke-width="8"
        stroke-linecap="round"
        fill="none"
        stroke-dasharray={circumference}
        stroke-dashoffset={circumference}
        style={`filter: drop-shadow(0 0 6px ${tone.shadow});`}
        data-score-ring
        data-score-target={value}
        data-score-circumference={circumference}
      />
    </svg>
    <span
      class:list={[
        'absolute inset-0 flex items-center justify-center font-display text-4xl font-black tabular-nums leading-none tracking-tight',
        tone.text,
      ]}
      data-score-value
      data-score-target={value}
      aria-hidden="true"
    >
      0
    </span>
    <span class="sr-only">{value}</span>
  </div>
  <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.25em] text-slate-600 dark:text-slate-400">
    {label}
  </p>
</li>
