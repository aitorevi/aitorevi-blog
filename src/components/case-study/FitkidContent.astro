---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/shared/Button.astro';
import Tag from '@/components/shared/Tag.astro';
import StackCard from '@/components/case-study/StackCard.astro';
import FeatureCard from '@/components/case-study/FeatureCard.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';
import PhoneMockup from './PhoneMockup.astro';
import LightboxImage from '@/components/shared/LightboxImage.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const repoUrl = 'https://github.com/aitorevi/fitkid-schedule';

const solutionKeys = ['search', 'filters', 'highlight', 'pwa'] as const;

const stack = {
  frontend: ['Astro 5 (SSR)', 'TypeScript', 'CSS puro', 'React islands'],
  infra: ['Vercel', 'PWA / Service Worker', 'Middleware Astro'],
  data: ['Markdown + Git', 'Zod (Content Collections)', 'Scripts TS (PDF → MD)'],
};

const decisions = ['noDb', 'auth', 'highlight'] as const;

type Screenshot = { img: string; flip: boolean; mockup?: boolean; num: string; titleEs: string; titleEn: string; descEs: string; descEn: string };

const screenshots: Screenshot[] = [
  {
    img: 'overview', flip: false, num: '01',
    titleEs: 'Horario completo de un vistazo', titleEn: 'Full schedule at a glance',
    descEs: 'Todos los turnos y categorías del día en una sola página, sin paginación. Diseñado para que el árbitro o el coordinador pueda escanear el horario rápidamente.',
    descEn: 'Every time slot and category of the day on a single page, no pagination. Designed so the referee or coordinator can scan the schedule at a glance.',
  },
  {
    img: 'participant', flip: true, num: '02',
    titleEs: 'Búsqueda por nombre', titleEn: 'Search by name',
    descEs: 'Escribe un nombre y el sistema lo resalta al instante en toda la vista. Los padres pueden encontrar el turno de su hijo sin leer fila por fila.',
    descEn: "Type a name and the system highlights it instantly across the full view. Parents can find their child's slot without reading row by row.",
  },
  {
    img: 'club-highlight', flip: false, num: '03',
    titleEs: 'Tu club siempre visible', titleEn: 'Your club always visible',
    descEs: 'Configura tu club con una variable de entorno y todos sus deportistas aparecen en cian automáticamente. Sin tocar el código, sin redeployar.',
    descEn: 'Set your club via an environment variable and all its athletes appear in cyan automatically. No code changes, no redeploy needed.',
  },
  {
    img: 'mobile', flip: true, mockup: true, num: '04',
    titleEs: 'Pensado para el móvil', titleEn: 'Mobile-first',
    descEs: 'Los deportistas y sus familias consultan el horario desde el teléfono en el propio pabellón. Sin app que instalar, funciona como PWA.',
    descEn: 'Athletes and families check the schedule from their phone right at the venue. No app to install — it works as a PWA.',
  },
];
---

<Layout
  title={t(lang, 'portfolio.fitkid.title')}
  description={t(lang, 'portfolio.fitkid.subtitle')}
  lang={lang}
>
  <div class="relative bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">

    <!-- Hero -->
    <section class="relative overflow-hidden py-8 pt-24 sm:py-12 sm:pt-28" aria-labelledby="fitkid-hero">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-500/5 to-transparent dark:from-blue-400/5" aria-hidden="true" />
      <div class="relative mx-auto max-w-5xl px-6 text-center">
        <Tag variant="raw" label={t(lang, 'portfolio.fitkid.tag')} class="border-blue-500/20 bg-blue-500/10 text-blue-700 dark:border-blue-400/30 dark:bg-blue-400/10 dark:text-blue-400" />
        <h1 id="fitkid-hero" class="mt-6 font-display text-4xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-5xl">
          {t(lang, 'portfolio.fitkid.title')}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.fitkid.hero.intro')}
        </p>
        <div class="mt-8 flex justify-center">
          <Button href={repoUrl} target="_blank" tone="blue">
            <Icon name="github" class="h-4 w-4" aria-hidden="true" />
            <span>{t(lang, 'portfolio.fitkid.hero.cta.repo')}</span>
          </Button>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-problem">
      <div class="mx-auto max-w-3xl px-6">
        <h2
          id="fitkid-problem"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.fitkid.problem.title')}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-center text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.fitkid.problem.text')}
        </p>
      </div>
    </section>

    <!-- Solution -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-solution">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="fitkid-solution"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.fitkid.solution.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {solutionKeys.map((key) => (
            <FeatureCard
              title={t(lang, `portfolio.fitkid.solution.${key}`)}
              text={t(lang, `portfolio.fitkid.solution.${key}.desc`)}
            />
          ))}
        </ul>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-stack">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="fitkid-stack"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.fitkid.stack.title')}
        </h2>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {Object.entries(stack).map(([category, items]) => (
            <StackCard
              title={t(lang, `portfolio.fitkid.stack.${category}`)}
              items={items}
              titleClass="text-blue-700 dark:text-blue-400"
              tagClass="border-blue-500/20 bg-blue-500/10 text-blue-700 dark:border-blue-400/30 dark:bg-blue-400/10 dark:text-blue-400"
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Technical Decisions -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-decisions">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="fitkid-decisions"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.fitkid.decisions.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {decisions.map((key) => (
            <FeatureCard
              title={t(lang, `portfolio.fitkid.decisions.${key}.heading`)}
              text={t(lang, `portfolio.fitkid.decisions.${key}.text`)}
            />
          ))}
        </ul>
      </div>
    </section>

    <!-- Open Source & GDPR -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-opensource">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="fitkid-opensource"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.fitkid.opensource.title')}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-center text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.fitkid.opensource.text')}
        </p>

        <div class="mt-16 space-y-20">
          {screenshots.map(({ img, flip, mockup, num, titleEs, titleEn, descEs, descEn }) => (
            <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
              {mockup ? (
                <div class={`group flex justify-center${flip ? ' md:order-2' : ''}`}>
                  <PhoneMockup
                    src={`/images/portfolio/fitkid/${img}.webp`}
                    alt={lang === 'es' ? titleEs : titleEn}
                    glowClass="group-hover:shadow-blue-400/20"
                  />
                </div>
              ) : (
                <LightboxImage
                  src={`/images/portfolio/fitkid/${img}.webp`}
                  alt={lang === 'es' ? titleEs : titleEn}
                  caption={lang === 'es' ? titleEs : titleEn}
                  closeLabel={t(lang, 'misc.close')}
                  class={`overflow-hidden rounded-2xl border border-slate-200 shadow-lg dark:border-white/10${flip ? ' md:order-2' : ''}`}
                />
              )}
              <div class={flip ? 'md:order-1' : ''}>
                <span class="font-mono text-[10px] 2xl:text-[12px] uppercase tracking-[0.2em] text-blue-600 dark:text-blue-400">{num}</span>
                <h3 class="mt-2 font-display text-xl font-bold tracking-tight text-ink-900 dark:text-slate-100">
                  {lang === 'es' ? titleEs : titleEn}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                  {lang === 'es' ? descEs : descEn}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 sm:py-24" aria-labelledby="fitkid-cta">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 id="fitkid-cta" class="font-display text-2xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-3xl">
          {t(lang, 'portfolio.fitkid.cta.title')}
        </h2>
        <p class="mx-auto mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.fitkid.cta.text')}
        </p>
        <div class="mt-8 flex justify-center">
          <Button href={repoUrl} target="_blank" tone="blue">
            <Icon name="github" class="h-4 w-4" aria-hidden="true" />
            <span>{t(lang, 'portfolio.fitkid.cta.repo')}</span>
          </Button>
        </div>
      </div>
    </section>

  </div>
</Layout>
