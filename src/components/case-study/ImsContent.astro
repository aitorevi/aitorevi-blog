---
import Layout from '@/layouts/Layout.astro';
import { t } from '@/i18n/utils';
import Tag from '@/components/shared/Tag.astro';
import StackCard from '@/components/case-study/StackCard.astro';
import FeatureCard from '@/components/case-study/FeatureCard.astro';
import PhoneMockup from './PhoneMockup.astro';
import LightboxImage from '@/components/shared/LightboxImage.astro';

const lang = 'es';

const featureKeys = ['dashboard', 'installations', 'measurements', 'quotes', 'suppliers', 'roles', 'pwa', 'responsive'] as const;

const secondaryScreenshots = [
  { src: '/images/portfolio/ims/installations-list.webp', key: 'portfolio.ims.gallery.installations', url: 'app.ims.dev/installations' },
  { src: '/images/portfolio/ims/installation-detail.webp', key: 'portfolio.ims.gallery.detail', url: 'app.ims.dev/installations/42' },
  { src: '/images/portfolio/ims/measurements.webp', key: 'portfolio.ims.gallery.measurements', url: 'app.ims.dev/measurements' },
  { src: '/images/portfolio/ims/quotes.webp', key: 'portfolio.ims.gallery.quotes', url: 'app.ims.dev/quotes' },
  { src: '/images/portfolio/ims/suppliers.webp', key: 'portfolio.ims.gallery.suppliers', url: 'app.ims.dev/suppliers' },
  { src: '/images/portfolio/ims/dashboard-installer.webp', key: 'portfolio.ims.gallery.installer', url: 'app.ims.dev/dashboard' },
];

const stack = {
  frontend: ['Astro 5 (SSR)', 'TypeScript', 'Tailwind CSS'],
  backend: ['Supabase (PostgreSQL)', 'Row Level Security', 'Edge Functions', 'Google OAuth'],
  infra: ['Vercel', 'PWA / Service Worker', 'Push Notifications (VAPID)'],
  testing: ['Vitest (678 unit tests)', 'Playwright (E2E)', 'Integration tests', '80%+ coverage'],
};
---

<Layout
  title="IMS — Installation Management System"
  description={t(lang, 'portfolio.ims.subtitle')}
>
  <div class="relative bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">
    <!-- Hero -->
    <section class="relative overflow-hidden py-8 pt-24 sm:py-12 sm:pt-28">
      <div class="absolute inset-0 bg-gradient-to-b from-secondary/5 to-transparent dark:from-accent-blue/5" aria-hidden="true" />
      <div class="relative mx-auto max-w-5xl px-6 text-center">
        <Tag variant="accent" label="SaaS" />
        <h1 class="mt-6 font-display text-4xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-5xl">
          {t(lang, 'portfolio.ims.title')}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.ims.intro')}
        </p>
      </div>
    </section>

    <!-- Features -->
    <section class="py-20 sm:py-24" aria-labelledby="features-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="features-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.features.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {featureKeys.map((key) => (
            <FeatureCard
              title={t(lang, `portfolio.ims.feat.${key}.title`)}
              text={t(lang, `portfolio.ims.feat.${key}`)}
            />
          ))}
        </ul>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20 sm:py-24" aria-labelledby="stack-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="stack-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.stack.title')}
        </h2>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {Object.entries(stack).map(([category, items]) => (
            <StackCard
              title={t(lang, `portfolio.ims.stack.${category}`)}
              items={items}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section class="py-20 sm:py-24" aria-labelledby="gallery-heading">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="gallery-heading"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.ims.gallery.title')}
        </h2>
        <p class="mt-3 text-center font-mono text-xs text-slate-500 dark:text-slate-500">
          // {t(lang, 'portfolio.ims.gallery.hint')}
        </p>

        <!-- Zone 1: Hero — Admin Dashboard -->
        <div class="mt-12">
          <LightboxImage
            src="/images/portfolio/ims/dashboard-admin.webp"
            alt={t(lang, 'portfolio.ims.gallery.dashboard')}
            caption={t(lang, 'portfolio.ims.gallery.dashboard')}
            label={`${t(lang, 'portfolio.ims.gallery.dashboard')} — ${t(lang, 'portfolio.ims.gallery.open')}`}
            closeLabel={t(lang, 'misc.close')}
            class="block w-full overflow-hidden rounded-2xl shadow-lg transition-transform duration-300 motion-safe:hover:scale-[1.01]"
          >
            <img
              src="/images/portfolio/ims/dashboard-admin.webp"
              alt={t(lang, 'portfolio.ims.gallery.dashboard')}
              loading="eager"
              width="1248"
              height="731"
              class="aspect-video w-full object-cover object-top"
            />
          </LightboxImage>
        </div>

        <!-- Zone 2: Secondary grid -->
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {secondaryScreenshots.map((img) => (
            <LightboxImage
              src={img.src}
              alt={t(lang, img.key)}
              caption={t(lang, img.key)}
              label={`${t(lang, img.key)} — ${t(lang, 'portfolio.ims.gallery.open')}`}
              closeLabel={t(lang, 'misc.close')}
              class="block w-full overflow-hidden rounded-2xl shadow-sm transition-transform duration-300 motion-safe:hover:scale-[1.02]"
            >
              <img
                src={img.src}
                alt={t(lang, img.key)}
                loading="lazy"
                class="aspect-video w-full object-cover object-top"
              />
            </LightboxImage>
          ))}
        </div>

        <!-- Zone 3: Mobile spotlight -->
        <div class="mt-12 flex flex-col items-center gap-10 sm:flex-row sm:justify-center">
          <div class="max-w-xs text-center sm:text-left">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-accent-violet/20 bg-accent-violet/10 px-2.5 py-1 font-mono text-[9px] uppercase tracking-[0.15em] text-accent-violet" aria-hidden="true">
              PWA
            </span>
            <h3 class="mt-3 font-display text-xl font-bold text-ink-900 dark:text-slate-200">
              {t(lang, 'portfolio.ims.gallery.mobileTitle')}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {t(lang, 'portfolio.ims.gallery.mobileDesc')}
            </p>
          </div>
          <LightboxImage
            src="/images/portfolio/ims/mobile-view.webp"
            alt={t(lang, 'portfolio.ims.gallery.mobile')}
            caption={t(lang, 'portfolio.ims.gallery.mobile')}
            label={`${t(lang, 'portfolio.ims.gallery.mobile')} — ${t(lang, 'portfolio.ims.gallery.open')}`}
            closeLabel={t(lang, 'misc.close')}
            class="group relative shrink-0 focus-visible:outline-offset-4"
          >
            <PhoneMockup
              src="/images/portfolio/ims/mobile-view.webp"
              alt={t(lang, 'portfolio.ims.gallery.mobile')}
              glowClass="group-hover:shadow-accent-violet/20"
            />
          </LightboxImage>
        </div>
      </div>
    </section>

  </div>
</Layout>
