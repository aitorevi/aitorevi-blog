---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/shared/Button.astro';
import Tag from '@/components/shared/Tag.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';
import DecisionCard from './DecisionCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const repoUrl = 'https://github.com/aitorevi/docu-ai-flow';

const solutionKeys = ['watcher', 'ai', 'export', 'dispatch'] as const;
const decisions = ['hexagonal', 'extraction', 'result', 'agents'] as const;
const workflowKeys = ['orchestrator', 'agents', 'skills', 'tdd'] as const;

const stack = {
  backend: ['.NET 10', 'C#', 'Hexagonal', 'Result/Error', 'SQLite', 'Google Document AI', 'Resend', 'Polly'],
  tests: ['xUnit', 'NSubstitute', 'WireMock.Net', 'NetArchTest'],
  workflow: ['Claude Code', 'Agents', 'Skills', 'TDD'],
};

const githubIcon =
  'M12 .5C5.37.5 0 5.87 0 12.5a12 12 0 0 0 8.21 11.41c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.33-1.78-1.33-1.78-1.08-.74.08-.73.08-.73 1.2.08 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.24-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.24a11.4 11.4 0 0 1 6 0c2.29-1.56 3.3-1.24 3.3-1.24.66 1.66.24 2.88.12 3.18.77.85 1.23 1.92 1.23 3.24 0 4.62-2.81 5.65-5.49 5.94.43.38.82 1.12.82 2.26v3.35c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z';
---

<Layout
  title={t(lang, 'portfolio.docuaiflow.title')}
  description={t(lang, 'portfolio.docuaiflow.subtitle')}
  lang={lang}
>
  <div class="relative bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">

    <!-- Hero -->
    <section class="relative overflow-hidden py-8 pt-24 sm:py-12 sm:pt-28" aria-labelledby="daf-hero">
      <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 to-transparent dark:from-emerald-400/5" aria-hidden="true" />
      <div class="relative mx-auto max-w-5xl px-6 text-center">
        <Tag variant="raw" label={t(lang, 'portfolio.docuaiflow.tag')} class="border-emerald-500/20 bg-emerald-500/10 text-emerald-700 dark:border-emerald-400/30 dark:bg-emerald-400/10 dark:text-emerald-400" />
        <h1 id="daf-hero" class="mt-6 font-display text-4xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-5xl">
          {t(lang, 'portfolio.docuaiflow.title')}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.docuaiflow.hero.intro')}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <Button href={repoUrl} target="_blank" tone="emerald" variant="gradient">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d={githubIcon} />
            </svg>
            <span>{t(lang, 'portfolio.docuaiflow.hero.cta.repo')}</span>
          </Button>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-problem">
      <div class="mx-auto max-w-3xl px-6">
        <h2
          id="daf-problem"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.docuaiflow.problem.title')}
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-center text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.docuaiflow.problem.text')}
        </p>
      </div>
    </section>

    <!-- Solution -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-solution">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="daf-solution"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.docuaiflow.solution.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {solutionKeys.map((key) => (
            <li class="rounded-xl border border-slate-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.04]">
              <h3 class="font-display text-base font-semibold text-ink-900 dark:text-slate-100">
                {t(lang, `portfolio.docuaiflow.solution.${key}`)}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                {t(lang, `portfolio.docuaiflow.solution.${key}.desc`)}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-stack">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="daf-stack"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.docuaiflow.stack.title')}
        </h2>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {Object.entries(stack).map(([category, items]) => (
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-white/10 dark:bg-white/[0.04]">
              <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.15em] text-emerald-700 dark:text-emerald-400">
                {t(lang, `portfolio.docuaiflow.stack.${category}`)}
              </h3>
              <ul class="mt-3 flex flex-wrap gap-2">
                {items.map((item) => (
                  <li><Tag label={item} variant="accent" /></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Technical Decisions -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-decisions">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="daf-decisions"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.docuaiflow.decisions.title')}
        </h2>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {decisions.map((key) => (
            <DecisionCard
              heading={t(lang, `portfolio.docuaiflow.decisions.${key}.heading`)}
              text={t(lang, `portfolio.docuaiflow.decisions.${key}.text`)}
            />
          ))}
        </ul>
      </div>
    </section>

    <!-- Built with Claude Code -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-workflow">
      <div class="mx-auto max-w-5xl px-6">
        <h2
          id="daf-workflow"
          class="text-center font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
        >
          {t(lang, 'portfolio.docuaiflow.workflow.title')}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.docuaiflow.workflow.intro')}
        </p>
        <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {workflowKeys.map((key) => (
            <li class="rounded-xl border border-emerald-200 bg-emerald-50/50 p-5 dark:border-emerald-400/20 dark:bg-emerald-400/[0.04]">
              <h3 class="font-display text-base font-semibold text-emerald-800 dark:text-emerald-300">
                {t(lang, `portfolio.docuaiflow.workflow.${key}`)}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                {t(lang, `portfolio.docuaiflow.workflow.${key}.desc`)}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 sm:py-24" aria-labelledby="daf-cta">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 id="daf-cta" class="font-display text-2xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-3xl">
          {t(lang, 'portfolio.docuaiflow.cta.title')}
        </h2>
        <p class="mx-auto mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-400">
          {t(lang, 'portfolio.docuaiflow.cta.text')}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <Button href={repoUrl} target="_blank" tone="emerald" variant="gradient">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d={githubIcon} />
            </svg>
            <span>{t(lang, 'portfolio.docuaiflow.cta.repo')}</span>
          </Button>
        </div>
      </div>
    </section>

  </div>
</Layout>
