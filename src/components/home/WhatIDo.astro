---
/**
 * WhatIDo — six glassmorphism cards that reveal with a stagger as the
 * section enters the viewport. The first row covers technical areas
 * (backend, frontend, infra) and the second row covers craft practices
 * (clean architecture, TDD, AI-assisted dev), making explicit that I work
 * across the whole stack.
 *
 * Uses IntersectionObserver + CSS custom properties (--stagger-delay) to
 * avoid JS animation loops. Respects prefers-reduced-motion.
 */
import type { Lang } from '@/i18n/types';
import { t } from '@/i18n/utils';
import ServiceCard from './ServiceCard.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// First row = technical areas (what I build with), second row = practices
// (how I build). Six cards land as 1×6 on mobile, 2×3 on tablet, 3×2 on
// desktop. Gradients step through the palette so adjacent cards stay
// visually distinct.
const cards = [
  // Row 1 — areas
  {
    icon: '■',
    titleKey: 'home.cards.backend.title',
    descKey: 'home.cards.backend.desc',
    accent: 'from-emerald-400/20 to-transparent',
  },
  {
    icon: '●',
    titleKey: 'home.cards.frontend.title',
    descKey: 'home.cards.frontend.desc',
    accent: 'from-accent-sky/20 to-transparent',
  },
  {
    icon: '⬡',
    titleKey: 'home.cards.infra.title',
    descKey: 'home.cards.infra.desc',
    accent: 'from-cyan-400/20 to-transparent',
  },
  // Row 2 — practices
  {
    icon: '◆',
    titleKey: 'home.cards.clean.title',
    descKey: 'home.cards.clean.desc',
    accent: 'from-accent-blue/20 to-transparent',
  },
  {
    icon: '▲',
    titleKey: 'home.cards.tdd.title',
    descKey: 'home.cards.tdd.desc',
    accent: 'from-accent-violet/20 to-transparent',
  },
  {
    icon: '◇',
    titleKey: 'home.cards.ai.title',
    descKey: 'home.cards.ai.desc',
    accent: 'from-amber-400/20 to-transparent',
  },
];
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="what-i-do-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeader
      id="what-i-do-heading"
      title={t(lang, 'home.whatIDo.title')}
      subtitle={t(lang, 'home.whatIDo.subtitle')}
    />

    <ul
      class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
      data-stagger-root
    >
      {
        cards.map((card, i) => (
          <ServiceCard
            icon={card.icon}
            title={t(lang, card.titleKey)}
            desc={t(lang, card.descKey)}
            accent={card.accent}
            index={i}
          />
        ))
      }
    </ul>
  </div>
</section>

<style>
  [data-stagger-item] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--stagger-delay, 0ms);
  }
  [data-stagger-item].is-visible {
    opacity: 1;
    transform: translateY(0);
    /* Remove transform from transition so the tilt RAF can control it freely */
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-stagger-item] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initStagger() {
    const roots = document.querySelectorAll('[data-stagger-root]');
    if (roots.length === 0) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    roots.forEach((root) => {
      const items = Array.from(
        root.querySelectorAll<HTMLElement>('[data-stagger-item]')
      );
      if (items.length === 0) return;

      if (reducedMotion) {
        items.forEach((el) => el.classList.add('is-visible'));
        return;
      }

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );
      items.forEach((el) => io.observe(el));
    });
  }

  function initTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const LERP = 0.08;
    const MAX_ROT = 8;
    const MAX_LIFT = 6;

    document.querySelectorAll<HTMLElement>('[data-tilt-card]').forEach((card) => {
      let targetX = 0, targetY = 0, targetZ = 0;
      let currentX = 0, currentY = 0, currentZ = 0;
      let rafId = 0;
      let isHovered = false;

      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      function tick() {
        currentX = lerp(currentX, targetX, LERP);
        currentY = lerp(currentY, targetY, LERP);
        currentZ = lerp(currentZ, targetZ, LERP);
        card.style.transform = `perspective(800px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateZ(${currentZ}px)`;
        const settled =
          Math.abs(currentX - targetX) < 0.01 &&
          Math.abs(currentY - targetY) < 0.01 &&
          Math.abs(currentZ - targetZ) < 0.1;
        if (!settled) {
          rafId = requestAnimationFrame(tick);
        } else {
          rafId = 0;
          if (!isHovered) card.style.transform = '';
        }
      }

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        targetY =  ((e.clientX - rect.left) / rect.width  - 0.5) * 2 * MAX_ROT;
        targetX = -((e.clientY - rect.top)  / rect.height - 0.5) * 2 * (MAX_ROT * 0.75);
        targetZ = MAX_LIFT;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });

      card.addEventListener('mouseenter', () => { isHovered = true; });
      card.addEventListener('mouseleave', () => {
        isHovered = false;
        targetX = 0; targetY = 0; targetZ = 0;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });
    });
  }

  document.addEventListener('astro:page-load', () => { initStagger(); initTilt(); });
  document.addEventListener('astro:after-swap', () => { initStagger(); initTilt(); });
</script>
