---
/**
 * StatsCounter — three animated metrics triggered when the section enters
 * the viewport.
 *
 * Numeric values count from 0 to target over ~1400ms with an ease-out curve.
 * Non-numeric values (e.g. "∞") pulse into place.
 *
 * Single IntersectionObserver, one rAF loop per counter, cleans itself up.
 * Respects prefers-reduced-motion (shows final value immediately).
 */
import type { Lang } from '../../data/cv';
import { t } from '../../i18n/utils';
import StatCard from './StatCard.astro';
import SectionHeader from '../atoms/SectionHeader.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// The years stat is split into two honest buckets: professional software
// development (Lean Mind, Mar 2023 → today) and prior business leadership
// (Tiendas Zulima, 1998–2023). A single "20+ years of experience" card on a
// dev portfolio was being read as "20+ years coding", which misrepresented
// the actual timeline. Splitting the number tells the real story: a dev
// with a long product/business background underneath.
function yearsSince(year: number, month: number /* 1-based */): number {
  const now = new Date();
  const months = (now.getFullYear() - year) * 12 + (now.getMonth() + 1 - month);
  return Math.floor(months / 12);
}

const devYears = yearsSince(2023, 3);      // Lean Mind, March 2023
const productYears = yearsSince(1998, 1);  // Tiendas Zulima, 1998

const stats = [
  { value: String(devYears),     suffix: '+', labelKey: 'home.stats.dev' },
  { value: String(productYears), suffix: '+', labelKey: 'home.stats.product' },
  { value: '3',                  suffix: '+', labelKey: 'home.stats.stacks' },
];
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="stats-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeader
      id="stats-heading"
      title={t(lang, 'home.stats.title')}
      subtitle={t(lang, 'home.stats.subtitle')}
    />
  </div>

  <div
    class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-4 px-6 sm:grid-cols-3 sm:gap-6"
    data-stats-root
  >
    {
      stats.map((stat) => (
        <StatCard
          value={stat.value}
          suffix={stat.suffix}
          label={t(lang, stat.labelKey)}
          tilt
        />
      ))
    }
  </div>
</section>

<script>
  type StatEl = HTMLElement & {
    __animated?: boolean;
  };

  const EASE_OUT_CUBIC = (t: number) => 1 - Math.pow(1 - t, 3);
  const DURATION_MS = 1400;

  function animateNumeric(valueEl: HTMLElement, target: number, suffix: string) {
    const start = performance.now();
    const step = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(1, elapsed / DURATION_MS);
      const eased = EASE_OUT_CUBIC(progress);
      const current = Math.floor(target * eased);
      valueEl.textContent = `${current}${suffix}`;
      if (progress < 1) requestAnimationFrame(step);
      else valueEl.textContent = `${target}${suffix}`;
    };
    requestAnimationFrame(step);
  }

  function animateSymbol(valueEl: HTMLElement, symbol: string) {
    // Pulse scale for non-numeric values like "∞".
    valueEl.textContent = symbol;
    valueEl.animate(
      [
        { transform: 'scale(0.6)', opacity: 0 },
        { transform: 'scale(1.15)', opacity: 1, offset: 0.7 },
        { transform: 'scale(1)', opacity: 1 },
      ],
      { duration: 900, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'forwards' }
    );
  }

  function runStat(stat: StatEl) {
    if (stat.__animated) return;
    stat.__animated = true;
    const valueEl = stat.querySelector<HTMLElement>('[data-stat-value]');
    if (!valueEl) return;
    const rawTarget = stat.dataset.statTarget || '0';
    const suffix = stat.dataset.statSuffix || '';
    const numeric = Number(rawTarget);

    if (Number.isFinite(numeric) && !Number.isNaN(numeric)) {
      animateNumeric(valueEl, numeric, suffix);
    } else {
      animateSymbol(valueEl, rawTarget);
    }
  }

  function initStats() {
    const root = document.querySelector('[data-stats-root]');
    if (!root) return;
    const stats = Array.from(
      root.querySelectorAll<StatEl>('[data-stat]')
    );
    if (stats.length === 0) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      stats.forEach((stat) => {
        const valueEl = stat.querySelector<HTMLElement>('[data-stat-value]');
        if (!valueEl) return;
        valueEl.textContent = `${stat.dataset.statTarget || ''}${stat.dataset.statSuffix || ''}`;
      });
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runStat(entry.target as StatEl);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 }
    );
    stats.forEach((stat) => io.observe(stat));
  }

  function initTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const LERP = 0.08;
    const MAX_ROT = 8;
    const MAX_LIFT = 6;

    document.querySelectorAll<HTMLElement>('[data-tilt-stat]').forEach((card) => {
      let targetX = 0, targetY = 0, targetZ = 0;
      let currentX = 0, currentY = 0, currentZ = 0;
      let rafId = 0;
      let isHovered = false;

      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      function tick() {
        currentX = lerp(currentX, targetX, LERP);
        currentY = lerp(currentY, targetY, LERP);
        currentZ = lerp(currentZ, targetZ, LERP);
        card.style.transform = `perspective(800px) rotateX(${currentX}deg) rotateY(${currentY}deg) translateZ(${currentZ}px)`;
        const settled =
          Math.abs(currentX - targetX) < 0.01 &&
          Math.abs(currentY - targetY) < 0.01 &&
          Math.abs(currentZ - targetZ) < 0.1;
        if (!settled) {
          rafId = requestAnimationFrame(tick);
        } else {
          rafId = 0;
          if (!isHovered) card.style.transform = '';
        }
      }

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        targetY =  ((e.clientX - rect.left) / rect.width  - 0.5) * 2 * MAX_ROT;
        targetX = -((e.clientY - rect.top)  / rect.height - 0.5) * 2 * (MAX_ROT * 0.75);
        targetZ = MAX_LIFT;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });

      card.addEventListener('mouseenter', () => { isHovered = true; });
      card.addEventListener('mouseleave', () => {
        isHovered = false;
        targetX = 0; targetY = 0; targetZ = 0;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });
    });
  }

  document.addEventListener('astro:page-load', () => { initStats(); initTilt(); });
  document.addEventListener('astro:after-swap', () => { initStats(); initTilt(); });
</script>
