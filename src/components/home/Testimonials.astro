---
import { t } from '../../i18n/utils';
import type { Lang } from '../../data/cv';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const testimonials = lang === 'es'
  ? [
      {
        text: 'Trabajar con Aitor es una garantía de calidad. Su dominio del TDD y la arquitectura limpia se nota en cada línea de código que escribe.',
        author: 'Nombre Apellido',
        role: 'Senior Developer · Lean Mind',
      },
      {
        text: 'Aitor tiene una capacidad única para hacer que conceptos complejos parezcan evidentes. En los code reviews siempre aprendo algo nuevo, ya sea sobre diseño de dominio, sobre cómo nombrar bien las cosas o sobre cómo simplificar sin perder expresividad. Es el tipo de compañero que te hace mejor desarrollador solo con trabajar a su lado.',
        author: 'Nombre Apellido',
        role: 'Developer · Lean Mind',
      },
      {
        text: 'Lo que más destaca de Aitor es su compromiso con las buenas prácticas incluso bajo presión. Nunca toma atajos que comprometan la mantenibilidad del código.',
        author: 'Nombre Apellido',
        role: 'Tech Lead · Empresa',
      },
      {
        text: 'Aitor aporta una visión de producto muy valiosa además de sus habilidades técnicas. Entiende el negocio y eso se refleja en las soluciones que propone.',
        author: 'Adrián Carmona',
        role: 'Product Manager · Empresa',
      },
      {
        text: 'He tenido la oportunidad de trabajar con Aitor y he de decir que es una persona comprometida con aprender y resolver los problemas que se le ponen por delante. Siempre está dispuesto a escuchar para tener una visión más completa y resolver el problema en equipo. Es un gran profesional que ha sabido adaptarse al desarrollo de software viniendo de un mundo totalmente distinto.',
        author: 'Aitor Santana',
        role: 'Software Developer · Lean Mind',
        avatar: '/images/testimonials/aitor-santana.webp',
      },
    ]
  : [
      {
        text: 'Working with Aitor is a guarantee of quality. His mastery of TDD and clean architecture shows in every line of code he writes.',
        author: 'First Last',
        role: 'Senior Developer · Lean Mind',
      },
      {
        text: 'Aitor has a unique ability to make complex concepts feel obvious. In code reviews I always learn something new, whether about domain design, naming things well, or simplifying without losing expressiveness. He is the kind of colleague who makes you a better developer just by working alongside him.',
        author: 'First Last',
        role: 'Developer · Lean Mind',
      },
      {
        text: 'What stands out most about Aitor is his commitment to good practices even under pressure. He never takes shortcuts that compromise maintainability.',
        author: 'First Last',
        role: 'Tech Lead · Company',
      },
      {
        text: 'Aitor brings valuable product vision on top of his technical skills. He understands the business and that shows in the solutions he proposes.',
        author: 'First Last',
        role: 'Product Manager · Company',
      },
      {
        text: 'I had the opportunity to work with Aitor and I have to say he is someone truly committed to learning and solving the problems in front of him. He is always willing to listen to get a fuller picture and tackle the problem as a team. He is a great professional who has managed to adapt to software development coming from a completely different world.',
        author: 'Aitor Santana',
        role: 'Software Developer · Lean Mind',
        avatar: '/images/testimonials/aitor-santana.webp',
      },
    ];
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="testimonials-heading"
>
  <div class="mb-14 text-center">
    <h2
      id="testimonials-heading"
      class="font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
    >
      {t(lang, 'home.testimonials.title')}
    </h2>
    <p class="mt-3 font-mono text-xs uppercase tracking-[0.3em] text-secondary/70 dark:text-accent-blue/50">
      {t(lang, 'home.testimonials.subtitle')}
    </p>
  </div>

  <div class="carousel-wrapper mx-auto max-w-[640px] px-6" aria-label="Testimonials">
    <!-- Cards stacked in the same grid cell -->
    <div class="carousel-track">
      {testimonials.map((item, i) => {
        const initials = item.author.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();
        return (
          <div
            class:list={[
              'carousel-slide relative overflow-hidden rounded-xl border border-secondary/15 bg-white px-7 py-8 dark:border-accent-violet/20 dark:bg-ink-800',
              i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none',
            ]}
            aria-hidden={i !== 0 ? 'true' : undefined}
          >
            <!-- Top gradient overlay -->
            <div
              class="pointer-events-none absolute inset-x-0 -top-20 h-40 bg-gradient-to-b from-secondary/10 to-transparent opacity-60 dark:from-accent-violet/10"
              aria-hidden="true"
            />
            <!-- Decorative quote mark -->
            <span
              class="pointer-events-none absolute right-5 top-2 select-none font-display text-7xl font-black leading-none text-secondary/10 dark:text-accent-violet/10"
              aria-hidden="true"
            >
              "
            </span>
            <!-- Quote -->
            <blockquote class="relative z-10">
              <p class="text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                "{item.text}"
              </p>
            </blockquote>
            <!-- Author -->
            <footer class="relative z-10 mt-6 flex items-center gap-3">
              {item.avatar
                ? <img src={item.avatar} alt={item.author} class="h-8 w-8 shrink-0 rounded-full object-cover" />
                : <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-xs font-bold text-secondary dark:bg-accent-violet/15 dark:text-accent-violet" aria-hidden="true">{initials}</div>
              }
              <div>
                <p class="text-sm font-semibold text-ink-900 dark:text-slate-100">{item.author}</p>
                <p class="font-mono text-[11px] text-secondary/60 dark:text-accent-violet/50 whitespace-nowrap">{item.role}</p>
              </div>
            </footer>
          </div>
        );
      })}
    </div>

    <!-- Dots -->
    <div class="mt-8 flex items-center justify-center gap-3" role="tablist" aria-label="Testimonials navigation">
      {testimonials.map((item, i) => (
        <button
          class:list={['dot', i === 0 ? 'active' : '']}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={item.author}
          data-index={i}
        >
          <span class="dot-fill" />
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  /* Stack all cards in the same grid cell */
  .carousel-track {
    display: grid;
  }
  .carousel-slide {
    grid-column: 1;
    grid-row: 1;
    transition: opacity 0.7s ease;
  }

  /* Dot base */
  .dot {
    position: relative;
    height: 8px;
    width: 8px;
    border-radius: 9999px;
    background-color: currentColor;
    opacity: 0.2;
    overflow: hidden;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: width 0.3s ease, height 0.3s ease, border-radius 0.3s ease, opacity 0.3s ease;
  }

  /* Active dot — becomes a pill with progress bar */
  .dot.active {
    opacity: 1;
    width: 3rem;
    height: 4px;
    border-radius: 9999px;
  }

  /* Progress fill — only animates inside the active dot */
  .dot-fill {
    position: absolute;
    inset: 0;
    background-color: rgb(var(--color-secondary, 94 58 238));
    transform: scaleX(0);
    transform-origin: left;
  }

  .dot.active .dot-fill {
    animation: dot-progress 6s linear forwards;
  }

  .carousel-wrapper:hover .dot.active .dot-fill {
    animation-play-state: paused;
  }

  @keyframes dot-progress {
    to { transform: scaleX(1); }
  }
</style>

<script>
  function initFadeCarousel() {
    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    const dots   = document.querySelectorAll<HTMLElement>('.dot');
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setTimeout> | null = null;
    let paused = false;
    let slideStartedAt = Date.now();
    const DURATION = 6000;

    function goTo(index: number) {
      // Hide current
      slides[current].classList.replace('opacity-100', 'opacity-0');
      slides[current].classList.add('pointer-events-none');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('active');
      dots[current].setAttribute('aria-selected', 'false');

      current = (index + slides.length) % slides.length;

      // Show next
      slides[current].classList.replace('opacity-0', 'opacity-100');
      slides[current].classList.remove('pointer-events-none');
      slides[current].removeAttribute('aria-hidden');

      // Re-trigger dot animation by removing and re-adding the class
      const dot = dots[current];
      dot.classList.remove('active');
      dot.setAttribute('aria-selected', 'true');
      // Force reflow so animation restarts
      dot.offsetWidth;
      dot.classList.add('active');
    }

    function startTimer(remaining = DURATION) {
      if (timer) clearTimeout(timer);
      slideStartedAt = Date.now() - (DURATION - remaining);
      timer = setTimeout(() => {
        if (!paused) {
          goTo(current + 1);
          startTimer();
        }
      }, remaining);
    }

    // Dot clicks
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goTo(i);
        startTimer();
      });
    });

    // Pause on hover
    const wrapper = document.querySelector('.carousel-wrapper');
    let remainingWhenPaused = DURATION;

    wrapper?.addEventListener('mouseenter', () => {
      paused = true;
      if (timer) clearTimeout(timer);
      remainingWhenPaused = Math.max(0, DURATION - (Date.now() - slideStartedAt));
    });
    wrapper?.addEventListener('mouseleave', () => {
      paused = false;
      startTimer(remainingWhenPaused);
    });

    // Respect prefers-reduced-motion — dots still work, no autoplay
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    startTimer();
  }

  document.addEventListener('astro:page-load', initFadeCarousel);
  document.addEventListener('astro:after-swap', initFadeCarousel);
  initFadeCarousel();
</script>
