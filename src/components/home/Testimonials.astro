---
import { t } from '../../i18n/utils';
import type { Lang } from '../../data/cv';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Replace placeholder text with real testimonials when received
const testimonials = lang === 'es'
  ? [
      {
        text: 'Trabajar con Aitor es una garantía de calidad. Su dominio del TDD y la arquitectura limpia se nota en cada línea de código que escribe.',
        author: 'Nombre Apellido',
        role: 'Senior Developer · Lean Mind',
      },
      {
        text: 'Aitor tiene una capacidad única para hacer que conceptos complejos parezcan evidentes. En los code reviews siempre aprendo algo nuevo, ya sea sobre diseño de dominio, sobre cómo nombrar bien las cosas o sobre cómo simplificar sin perder expresividad. Es el tipo de compañero que te hace mejor desarrollador solo con trabajar a su lado.',
        author: 'Nombre Apellido',
        role: 'Developer · Lean Mind',
      },
      {
        text: 'Lo que más destaca de Aitor es su compromiso con las buenas prácticas incluso bajo presión. Nunca toma atajos que comprometan la mantenibilidad del código.',
        author: 'Nombre Apellido',
        role: 'Tech Lead · Empresa',
      },
      {
        text: 'Aitor aporta una visión de producto muy valiosa además de sus habilidades técnicas. Entiende el negocio y eso se refleja en las soluciones que propone.',
        author: 'Adrián Carmona',
        role: 'Product Manager · Empresa',
      },
      {
        text: 'He tenido la oportunidad de trabajar con Aitor y he de decir que es una persona comprometida con aprender y resolver los problemas que se le ponen por delante. Siempre está dispuesto a escuchar para tener una visión más completa y resolver el problema en equipo. Es un gran profesional que ha sabido adaptarse al desarrollo de software viniendo de un mundo totalmente distinto.',
        author: 'Aitor Santana',
        role: 'Junior Developer · Lean Mind',
        avatar: '/images/testimonials/aitor-santana.webp',
      },
    ]
  : [
      {
        text: 'Working with Aitor is a guarantee of quality. His mastery of TDD and clean architecture shows in every line of code he writes.',
        author: 'First Last',
        role: 'Senior Developer · Lean Mind',
      },
      {
        text: 'Aitor has a unique ability to make complex concepts feel obvious. In code reviews I always learn something new, whether about domain design, naming things well, or simplifying without losing expressiveness. He is the kind of colleague who makes you a better developer just by working alongside him.',
        author: 'First Last',
        role: 'Developer · Lean Mind',
      },
      {
        text: 'What stands out most about Aitor is his commitment to good practices even under pressure. He never takes shortcuts that compromise maintainability.',
        author: 'First Last',
        role: 'Tech Lead · Company',
      },
      {
        text: 'Aitor brings valuable product vision on top of his technical skills. He understands the business and that shows in the solutions he proposes.',
        author: 'First Last',
        role: 'Product Manager · Company',
      },
      {
        text: 'I had the opportunity to work with Aitor and I have to say he is someone truly committed to learning and solving the problems in front of him. He is always willing to listen to get a fuller picture and tackle the problem as a team. He is a great professional who has managed to adapt to software development coming from a completely different world.',
        author: 'Aitor Santana',
        role: 'Junior Developer · Lean Mind',
        avatar: '/images/testimonials/aitor-santana.webp',
      },
    ];
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="testimonials-heading"
>
  <div class="mb-14 text-center">
    <h2
      id="testimonials-heading"
      class="font-display text-3xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-4xl"
    >
      {t(lang, 'home.testimonials.title')}
    </h2>
    <p class="mt-3 font-mono text-xs uppercase tracking-[0.3em] text-secondary/70 dark:text-accent-blue/50">
      {t(lang, 'home.testimonials.subtitle')}
    </p>
  </div>

  <!-- Marquee: full-width, faded edges -->
  <div class="marquee-container" aria-label="Testimonials">
    <ul class="marquee-track">
      <!-- Original set -->
      {testimonials.map((item) => {
        const initials = item.author.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();
        return (
          <li class="marquee-card">
            <div class="group relative overflow-hidden rounded-xl border border-secondary/15 bg-white px-7 py-8 dark:border-accent-violet/20 dark:bg-ink-800" data-tilt-testimonial>
              <!-- Top gradient overlay -->
              <div
                class="pointer-events-none absolute inset-x-0 -top-20 h-40 bg-gradient-to-b from-secondary/10 to-transparent opacity-60 dark:from-accent-violet/10"
                aria-hidden="true"
              />
              <!-- Decorative quote mark -->
              <span
                class="pointer-events-none absolute right-5 top-2 select-none font-display text-7xl font-black leading-none text-secondary/10 dark:text-accent-violet/10"
                aria-hidden="true"
              >
                "
              </span>
              <!-- Quote -->
              <blockquote class="relative z-10">
                <p class="text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                  "{item.text}"
                </p>
              </blockquote>
              <!-- Author -->
              <footer class="relative z-10 mt-6 flex items-center gap-3">
                {item.avatar
                  ? <img src={item.avatar} alt={item.author} class="h-8 w-8 shrink-0 rounded-full object-cover" aria-hidden="true" />
                  : <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-xs font-bold text-secondary dark:bg-accent-violet/15 dark:text-accent-violet" aria-hidden="true">{initials}</div>
                }
                <div>
                  <p class="text-sm font-semibold text-ink-900 dark:text-slate-100">{item.author}</p>
                  <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-secondary/60 dark:text-accent-violet/50">{item.role}</p>
                </div>
              </footer>
            </div>
          </li>
        );
      })}
      <!-- Clones are added by JS to cover any viewport width -->
    </ul>
  </div>
</section>

<style>
  /* Fade edges */
  .marquee-container {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
  }

  /* Infinite scroll track */
  .marquee-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: marquee 28s linear infinite;
    padding: 0.5rem 0;
  }

  /* Pause on hover */
  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }

  /* Card fixed width */
  .marquee-card {
    width: 22rem;
    flex-shrink: 0;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-1 * var(--marquee-offset, 50%))); }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
    .marquee-container {
      -webkit-mask-image: none;
      mask-image: none;
      overflow-x: auto;
    }
  }
</style>

<script>
  function initTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const LERP = 0.08, MAX_ROT = 8, MAX_LIFT = 6;

    document.querySelectorAll<HTMLElement>('[data-tilt-testimonial]').forEach((card) => {
      let tx = 0, ty = 0, tz = 0, cx = 0, cy = 0, cz = 0, rafId = 0, hovered = false;
      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      function tick() {
        cx = lerp(cx, tx, LERP); cy = lerp(cy, ty, LERP); cz = lerp(cz, tz, LERP);
        card.style.transform = `perspective(800px) rotateX(${cx}deg) rotateY(${cy}deg) translateZ(${cz}px)`;
        const settled = Math.abs(cx - tx) < 0.01 && Math.abs(cy - ty) < 0.01 && Math.abs(cz - tz) < 0.1;
        if (!settled) { rafId = requestAnimationFrame(tick); }
        else { rafId = 0; if (!hovered) card.style.transform = ''; }
      }

      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        ty =  ((e.clientX - r.left) / r.width  - 0.5) * 2 * MAX_ROT;
        tx = -((e.clientY - r.top)  / r.height - 0.5) * 2 * (MAX_ROT * 0.75);
        tz = MAX_LIFT;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });
      card.addEventListener('mouseenter', () => { hovered = true; });
      card.addEventListener('mouseleave', () => {
        hovered = false; tx = 0; ty = 0; tz = 0;
        if (!rafId) rafId = requestAnimationFrame(tick);
      });
    });
  }

  function initMarquee() {
    const track = document.querySelector<HTMLElement>('.marquee-track');
    if (!track) return;

    // Mark originals on first run, remove clones on subsequent runs
    const existingClones = track.querySelectorAll('[data-clone]');
    existingClones.forEach(el => el.remove());

    const origItems = Array.from(
      track.querySelectorAll<HTMLElement>('[data-original]')
    );
    if (origItems.length === 0) {
      // First run: mark all current children as originals
      Array.from(track.children).forEach(el => el.setAttribute('data-original', ''));
      origItems.push(...Array.from(track.querySelectorAll<HTMLElement>('[data-original]')));
    }

    const origCount = origItems.length;

    // Clone until track is at least 2× the viewport width
    while (track.scrollWidth < window.innerWidth * 2) {
      origItems.forEach(item => {
        const clone = item.cloneNode(true) as HTMLElement;
        clone.setAttribute('aria-hidden', 'true');
        clone.setAttribute('data-clone', '');
        clone.removeAttribute('data-original');
        track.appendChild(clone);
      });
    }

    // One loop = exact distance from track start to first clone's left edge
    // (includes card widths + all gaps, no rounding error)
    const trackLeft = track.getBoundingClientRect().left;
    const firstCloneLeft = (track.children[origCount] as HTMLElement).getBoundingClientRect().left;
    const loopWidth = firstCloneLeft - trackLeft;
    track.style.setProperty('--marquee-offset', `${loopWidth}px`);

    // Restart animation so it picks up the new offset cleanly
    track.style.animation = 'none';
    track.offsetHeight; // force reflow
    track.style.animation = '';
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { initMarquee(); initTilt(); }, 150);
  }

  function init() {
    initMarquee();
    initTilt();
    window.removeEventListener('resize', onResize);
    window.addEventListener('resize', onResize, { passive: true });
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:after-swap', init);
  init();
</script>
