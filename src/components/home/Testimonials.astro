---
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';
import TestimonialCard from './TestimonialCard.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import Carousel from '@/components/shared/Carousel.astro';
import { testimonials as allTestimonials } from '@/data/testimonials';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const testimonials = allTestimonials.map((item) => ({
  text: item.text[lang],
  author: item.author,
  role: item.role,
  avatar: item.avatar,
  url: item.url,
}));
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="testimonials-heading"
>
  <div class="mb-14 text-center">
    <SectionHeader
      id="testimonials-heading"
      title={t(lang, 'home.testimonials.title')}
      subtitle={t(lang, 'home.testimonials.subtitle')}
    />
  </div>

  <Carousel
    items={testimonials.map((item) => ({ label: item.author }))}
    ariaLabel={t(lang, 'home.testimonials.navigation')}
  >
    {testimonials.map((item, i) => (
      <TestimonialCard
        text={item.text}
        author={item.author}
        role={item.role}
        avatar={item.avatar}
        url={item.url}
        index={i}
        active={i === 0}
      />
    ))}
  </Carousel>
</section>
