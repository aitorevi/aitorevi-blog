---
/**
 * HomeContent — orchestrator for the redesigned home page.
 *
 * Composes the home sections in order. The home respects the site-wide
 * light/dark theme toggle: every section declares both light and dark
 * variants, and the Layout/Nav behave normally over the top. Individual
 * sections handle their own animations, parallax and IntersectionObservers.
 */
import type { Lang } from '@/i18n/types';
import HeroParallax from './HeroParallax.astro';
import WhatIDo from './WhatIDo.astro';
import StatsCounter from './StatsCounter.astro';
import TechStack from './TechStack.astro';
import LatestPosts from './LatestPosts.astro';
import Portfolio from './Portfolio.astro';
import Talks from './Talks.astro';
import Testimonials from './Testimonials.astro';
import ContactSection from './ContactSection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="home-redesign relative isolate bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">
  <HeroParallax lang={lang} />
  <WhatIDo lang={lang} />
  <TechStack lang={lang} />
  <LatestPosts lang={lang} />
  <StatsCounter lang={lang} />
  <Portfolio lang={lang} />
  <Talks lang={lang} />
  <Testimonials lang={lang} />
  <ContactSection lang={lang} />
</div>

<style is:global>
  /* Make the page background follow the theme on the home. Layout.astro
     already applies `bg-white dark:bg-[#0f1419]` to the body, but we tune
     it on the home so the transition between sections feels continuous. */
  body:has(.home-redesign) {
    background-color: #f8fafc;
    background-image: none;
  }
  body:has(.home-redesign) main {
    background-color: #f8fafc;
  }
  html.dark body:has(.home-redesign),
  html.dark body:has(.home-redesign) main {
    background-color: theme(colors.ink.900);
  }
</style>
