---
import type { Lang } from '@/i18n/types';
import HeroParallax from './HeroParallax.astro';
import WhatIDo from './WhatIDo.astro';
import StatsCounter from './StatsCounter.astro';
import TechStack from './TechStack.astro';
import WorkPortal from './WorkPortal.astro';
import LatestPosts from './LatestPosts.astro';
import Talks from './Talks.astro';
import Practice from './Practice.astro';
import Testimonials from './Testimonials.astro';
import ContactSection from './ContactSection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="home-redesign relative isolate bg-slate-50 text-ink-900 dark:bg-ink-900 dark:text-slate-100">
  <HeroParallax lang={lang} />
  <WhatIDo lang={lang} />
  <TechStack lang={lang} />
  <StatsCounter lang={lang} />
  <WorkPortal lang={lang} />
  <LatestPosts lang={lang} />
  <Talks lang={lang} />
  <Practice lang={lang} />
  <Testimonials lang={lang} />
  <ContactSection lang={lang} />
</div>

<style is:global>
  body:has(.home-redesign) {
    background-color: #f8fafc;
    background-image: none;
  }
  body:has(.home-redesign) main {
    background-color: #f8fafc;
  }
  html.dark body:has(.home-redesign),
  html.dark body:has(.home-redesign) main {
    background-color: theme(colors.ink.900);
  }
</style>
