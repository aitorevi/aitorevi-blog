---
import type { Lang } from '../../i18n/types';
import { t } from '../../i18n/utils';
import { talks } from '../../data/talks';
import { formatDate, formatDateISO } from '../../lib/date';
import SectionHeader from '../atoms/SectionHeader.astro';
import EyebrowTag from '../atoms/EyebrowTag.astro';
import GlassCard from '../atoms/GlassCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const locale = lang === 'en' ? 'en-US' : 'es-ES';
const sorted = [...talks].sort((a, b) => (a.date < b.date ? 1 : -1));
const isSingle = sorted.length === 1;
const listClass = isSingle
  ? 'mt-14 flex justify-center'
  : 'mt-14 flex flex-wrap justify-center gap-5';
const itemSizingClass = isSingle
  ? 'w-full max-w-md'
  : 'basis-full sm:basis-[calc((100%-1.25rem)/2)] lg:basis-[calc((100%-2.5rem)/3)]';
---

<section
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="talks-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeader
      id="talks-heading"
      title={t(lang, 'home.talks.title')}
      subtitle={t(lang, 'home.talks.subtitle')}
    />

    <ul
      class={listClass}
      data-stagger-root
    >
      {sorted.map((talk, i) => {
        const articleUrl = talk.articleUrl?.[lang];
        return (
        <GlassCard accent="from-accent-violet/20 to-transparent" index={i} class={itemSizingClass}>

          <div class="relative flex h-full flex-col">
            <EyebrowTag label={t(lang, 'home.talks.tag.workshop')} class="mb-3" />

            <h3 class="font-display text-lg font-semibold text-ink-900 dark:text-slate-100">
              {articleUrl ? (
                <a
                  href={articleUrl}
                  class="after:absolute after:inset-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2"
                >
                  {talk.title[lang]}
                </a>
              ) : (
                talk.title[lang]
              )}
            </h3>

            {talk.coPresenters && talk.coPresenters.length > 0 && (
              <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                {t(lang, 'home.talks.with')} {talk.coPresenters.join(', ')}
              </p>
            )}

            <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.15em] text-secondary dark:text-accent-blue">
              {talk.event} · <time datetime={formatDateISO(talk.date)}>{formatDate(talk.date, locale)}</time>
            </p>

            <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {talk.description[lang]}
            </p>

            <div class="mt-4 flex flex-wrap gap-1.5">
              {talk.tags.map((tag) => (
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.1em] text-slate-600 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-400">
                  {tag}
                </span>
              ))}
            </div>

            {talk.githubUrl && (
              <p class="relative z-10 mt-4">
                <a
                  href={talk.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-secondary transition-colors hover:text-accent-violet focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 dark:text-accent-blue dark:hover:text-accent-violet"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
                    <path d="M12 .5C5.37.5 0 5.87 0 12.5a12 12 0 0 0 8.21 11.41c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.33-1.78-1.33-1.78-1.08-.74.08-.73.08-.73 1.2.08 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.24-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.24a11.4 11.4 0 0 1 6 0c2.29-1.56 3.3-1.24 3.3-1.24.66 1.66.24 2.88.12 3.18.77.85 1.23 1.92 1.23 3.24 0 4.62-2.81 5.65-5.49 5.94.43.38.82 1.12.82 2.26v3.35c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z" />
                  </svg>
                  <span>{t(lang, 'home.talks.repo')}</span>
                </a>
              </p>
            )}
          </div>
        </GlassCard>
        );
      })}
    </ul>
  </div>
</section>
