---
import GlassCard from '../shared/GlassCard.astro';

interface Props {
  icon: string;
  title: string;
  desc: string;
  accent: string;
  index: number;
}

const { icon, title, desc, accent, index } = Astro.props;
---

<GlassCard accent={accent} index={index} tilt>
  <div class="relative">
    <span
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-secondary/30 bg-secondary/5 font-mono text-lg text-secondary transition-colors duration-300 group-hover:border-secondary/70 group-hover:text-accent-violet dark:border-accent-blue/20 dark:bg-accent-blue/5 dark:text-accent-blue dark:group-hover:border-accent-blue/60 dark:group-hover:text-accent-violet"
      aria-hidden="true"
    >
      {icon}
    </span>
    <h3 class="mt-4 font-display text-lg font-semibold text-ink-900 dark:text-slate-100">
      {title}
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
      {desc}
    </p>
  </div>
</GlassCard>
