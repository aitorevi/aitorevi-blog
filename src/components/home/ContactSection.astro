---
/**
 * ContactSection — simple contact form section at the bottom of the home.
 *
 * Deliberately backend-free: the submit handler constructs a mailto: URL
 * from the form fields so the user's default email client opens with a
 * pre-filled draft. This keeps the site fully static and dependency-free.
 *
 * The section doubles as the anchor target for the hero's 'Contact' CTA
 * (id="contact").
 */
import { Icon } from 'astro-icon/components';
import type { Lang } from '@/i18n/types';
import { t } from '@/i18n/utils';
import Button from '@/components/shared/Button.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section
  id="contact"
  class="relative bg-slate-50 py-24 text-ink-900 dark:bg-ink-900 dark:text-slate-100 sm:py-32"
  aria-labelledby="contact-heading"
  data-contact-email="info@aitorevi.dev"
>
  <div class="mx-auto max-w-[640px] px-6">
    <div class="text-center">
      <SectionHeader
        id="contact-heading"
        title={t(lang, 'home.contact.title')}
        subtitle={t(lang, 'home.contact.subtitle')}
      />
      <p class="mx-auto mt-6 max-w-xl text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {t(lang, 'home.contact.intro')}
      </p>
    </div>

    <p role="note" class="mt-6 text-xs text-slate-600 dark:text-slate-300 text-center">
      {t(lang, 'home.contact.rateLimitNotice')}
    </p>

    <form
      class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-lg sm:p-8 dark:border-white/10 dark:bg-white/[0.04] dark:shadow-2xl dark:backdrop-blur-md"
      data-contact-form
      novalidate
      data-msg-name-required={t(lang, 'home.contact.validation.nameRequired')}
      data-msg-name-short={t(lang, 'home.contact.validation.nameTooShort')}
      data-msg-email-required={t(lang, 'home.contact.validation.emailRequired')}
      data-msg-email-invalid={t(lang, 'home.contact.validation.emailInvalid')}
      data-msg-subject-required={t(lang, 'home.contact.validation.subjectRequired')}
      data-msg-message-required={t(lang, 'home.contact.validation.messageRequired')}
      data-msg-message-short={t(lang, 'home.contact.validation.messageTooShort')}
      data-msg-consent-required={t(lang, 'home.contact.validation.consentRequired')}
      data-msg-success={t(lang, 'home.contact.status.success')}
      data-msg-too-many={t(lang, 'home.contact.status.tooMany')}
      data-msg-error={t(lang, 'home.contact.status.error')}
      data-msg-network-error={t(lang, 'home.contact.status.networkError')}
      data-lang={lang}
    >
      <!-- Honeypot: oculto para humanos, los bots lo rellenan -->
      <input
        type="text"
        name="_trap"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        style="position:absolute;left:-9999px;opacity:0;height:0;width:0;"
      />
      <p class="mb-4 font-mono text-[10px] text-secondary dark:text-accent-blue">
        <span aria-hidden="true">* </span>{t(lang, 'home.contact.required')}
      </p>

      <div class="grid gap-5 sm:grid-cols-2">
        <label for="contact-name" class="block">
          <span class="mb-1 block font-mono text-[10px] uppercase tracking-[0.2em] text-secondary dark:text-accent-blue">
            {t(lang, 'home.contact.name')}<span aria-hidden="true"> *</span>
          </span>
          <p id="contact-name-help" class="text-xs text-slate-600 dark:text-slate-300 mt-0.5 mb-2">
            {t(lang, 'home.contact.nameHelp')}
          </p>
          <input
            id="contact-name"
            type="text"
            name="name"
            required
            autocomplete="name"
            maxlength="100"
            data-field="name"
            aria-describedby="contact-name-help contact-name-error"
            class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-ink-900 placeholder-slate-700 transition-colors focus:border-secondary/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-100 dark:placeholder-slate-400 dark:focus:border-accent-blue/60"
            placeholder={t(lang, 'home.contact.namePlaceholder')}
          />
          <span id="contact-name-error" data-field-error="name" class="mt-1 hidden text-[11px] text-rose-400 font-mono" aria-live="polite"></span>
        </label>
        <label for="contact-email" class="block">
          <span class="mb-1 block font-mono text-[10px] uppercase tracking-[0.2em] text-secondary dark:text-accent-blue">
            {t(lang, 'home.contact.email')}<span aria-hidden="true"> *</span>
          </span>
          <p id="contact-email-help" class="text-xs text-slate-600 dark:text-slate-300 mt-0.5 mb-2">
            {t(lang, 'home.contact.emailHelp')}
          </p>
          <input
            id="contact-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            maxlength="254"
            data-field="email"
            aria-describedby="contact-email-help contact-email-error"
            class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-ink-900 placeholder-slate-700 transition-colors focus:border-secondary/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-100 dark:placeholder-slate-400 dark:focus:border-accent-blue/60"
            placeholder={t(lang, 'home.contact.emailPlaceholder')}
          />
          <span id="contact-email-error" data-field-error="email" class="mt-1 hidden text-[11px] text-rose-400 font-mono" aria-live="polite"></span>
        </label>
      </div>

      <label for="contact-subject" class="mt-5 block">
        <span class="mb-1 block font-mono text-[10px] uppercase tracking-[0.2em] text-secondary dark:text-accent-blue">
          {t(lang, 'home.contact.subject')}<span aria-hidden="true"> *</span>
        </span>
        <p id="contact-subject-help" class="text-xs text-slate-600 dark:text-slate-300 mt-0.5 mb-2">
          {t(lang, 'home.contact.subjectHelp')}
        </p>
        <input
          id="contact-subject"
          type="text"
          name="subject"
          required
          maxlength="200"
          data-field="subject"
          aria-describedby="contact-subject-help contact-subject-error"
          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-ink-900 placeholder-slate-700 transition-colors focus:border-secondary/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-100 dark:placeholder-slate-400 dark:focus:border-accent-blue/60"
          placeholder={t(lang, 'home.contact.subjectPlaceholder')}
        />
        <span id="contact-subject-error" data-field-error="subject" class="mt-1 hidden text-[11px] text-rose-400 font-mono" aria-live="polite"></span>
      </label>

      <label for="contact-message" class="mt-5 block">
        <span class="mb-1 block font-mono text-[10px] uppercase tracking-[0.2em] text-secondary dark:text-accent-blue">
          {t(lang, 'home.contact.message')}<span aria-hidden="true"> *</span>
        </span>
        <p id="contact-message-help" class="text-xs text-slate-600 dark:text-slate-300 mt-0.5 mb-2">
          {t(lang, 'home.contact.messageHelp')}
        </p>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="5"
          maxlength="5000"
          data-field="message"
          aria-describedby="contact-message-help contact-message-error"
          class="w-full resize-none rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-ink-900 placeholder-slate-700 transition-colors focus:border-secondary/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-100 dark:placeholder-slate-400 dark:focus:border-accent-blue/60"
          placeholder={t(lang, 'home.contact.messagePlaceholder')}
        ></textarea>
        <span id="contact-message-error" data-field-error="message" class="mt-1 hidden text-[11px] text-rose-400 font-mono" aria-live="polite"></span>
      </label>

      <!-- RGPD — cláusula informativa básica -->
      <section class="mt-6 border-t border-slate-200/70 pt-4 dark:border-white/5" aria-labelledby="contact-privacy-heading">
        <p id="contact-privacy-heading" class="mb-2 font-mono text-[10px] uppercase tracking-[0.2em] text-secondary dark:text-accent-blue">
          {t(lang, 'home.contact.privacy.heading')}
        </p>
        <p class="text-[11px] leading-relaxed text-slate-600 dark:text-slate-300">
          <span class="text-slate-600 dark:text-slate-400">{t(lang, 'home.contact.privacy.responsable')}</span> {t(lang, 'home.contact.privacy.responsableValue')}{' '}
          <span class="text-slate-600 dark:text-slate-400">{t(lang, 'home.contact.privacy.finalidad')}</span> {t(lang, 'home.contact.privacy.finalidadValue')}{' '}
          <span class="text-slate-600 dark:text-slate-400">{t(lang, 'home.contact.privacy.legitimacion')}</span> {t(lang, 'home.contact.privacy.legitimacionValue')}{' '}
          <span class="text-slate-600 dark:text-slate-400">{t(lang, 'home.contact.privacy.destinatarios')}</span> {t(lang, 'home.contact.privacy.destinatariosValue')}{' '}
          <span class="text-slate-600 dark:text-slate-400">{t(lang, 'home.contact.privacy.derechos')}</span> {t(lang, 'home.contact.privacy.derechosValue')}
        </p>
      </section>

      <!-- Consent checkbox — required -->
      <label class="mt-4 min-h-[44px] flex items-center gap-2 text-[11px] leading-relaxed text-slate-600 dark:text-slate-300" for="contact-consent">
        <input
          id="contact-consent"
          type="checkbox"
          name="consent"
          required
          data-field="consent"
          aria-describedby="contact-consent-error"
          class="mt-0.5 h-3.5 w-3.5 flex-shrink-0 rounded border border-slate-300 text-secondary accent-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/20 dark:accent-accent-violet"
        />
        <span>
          {t(lang, 'home.contact.consent.label')}
          {' '}
          <a href={t(lang, 'home.contact.privacy.url')} class="text-secondary underline underline-offset-2 hover:text-accent-violet dark:text-accent-blue dark:hover:text-accent-violet">
            {t(lang, 'home.contact.consent.linkLabel')}
          </a>
          <span aria-hidden="true"> *</span>
          <span class="ml-1 text-slate-600 dark:text-slate-300">
            {t(lang, 'home.contact.consent.required')}
          </span>
        </span>
      </label>
      <span id="contact-consent-error" data-field-error="consent" class="mt-1 ml-6 hidden text-[11px] text-rose-400 font-mono" aria-live="polite"></span>

      <div class="mt-6 flex justify-end">
        <Button type="submit" variant="gradient" tone="brand">
          <span>{t(lang, 'home.contact.submit')}</span>
          <span
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >→</span>
        </Button>
      </div>

      <p
        class="mt-4 hidden text-center text-xs text-secondary dark:text-accent-blue"
        data-contact-status
        role="status"
        aria-live="polite"
      >
      </p>
    </form>

    <section
      id="contact-review"
      hidden
      aria-live="polite"
      aria-labelledby="review-heading"
      class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-lg sm:p-8 dark:border-white/10 dark:bg-white/[0.04] dark:shadow-2xl dark:backdrop-blur-md space-y-4"
    >
      <h3 id="review-heading" tabindex="-1" class="font-semibold text-ink-900 dark:text-slate-100 focus:outline-none">
        {t(lang, 'home.contact.review.title')}
      </h3>
      <dl class="space-y-2 text-sm">
        <div class="flex gap-2">
          <dt class="text-slate-600 dark:text-slate-300 font-medium w-20 shrink-0">{t(lang, 'home.contact.name')}:</dt>
          <dd id="review-name" class="text-ink-900 dark:text-slate-100"></dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-slate-600 dark:text-slate-300 font-medium w-20 shrink-0">{t(lang, 'home.contact.email')}:</dt>
          <dd id="review-email" class="text-ink-900 dark:text-slate-100"></dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-slate-600 dark:text-slate-300 font-medium w-20 shrink-0">{t(lang, 'home.contact.subject')}:</dt>
          <dd id="review-subject" class="text-ink-900 dark:text-slate-100"></dd>
        </div>
        <div class="flex gap-2">
          <dt class="text-slate-600 dark:text-slate-300 font-medium w-20 shrink-0">{t(lang, 'home.contact.message')}:</dt>
          <dd id="review-message" class="text-ink-900 dark:text-slate-100 whitespace-pre-wrap"></dd>
        </div>
      </dl>
      <div class="flex gap-3 pt-2">
        <button
          type="button"
          id="contact-back-btn"
          class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-ink-900 transition-colors hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-100 dark:hover:bg-white/[0.06]"
        >
          {t(lang, 'home.contact.review.edit')}
        </button>
        <button
          type="button"
          id="contact-confirm-btn"
          class="inline-flex items-center rounded-lg bg-secondary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-secondary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/60 focus-visible:ring-offset-1 dark:bg-accent-blue dark:text-ink-900 dark:hover:bg-accent-blue/90"
        >
          {t(lang, 'home.contact.review.confirm')}
        </button>
      </div>
    </section>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-4 text-[11px] uppercase tracking-[0.2em] text-slate-600 dark:text-slate-400 font-mono">
      <a
        href="https://www.linkedin.com/in/aitor-reviriego-amor/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 transition-colors hover:text-secondary dark:hover:text-accent-blue"
      >
        <Icon name="linkedin" class="w-3.5 h-3.5" />
        LinkedIn
      </a>
      <a
        href="https://github.com/aitorevi"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 transition-colors hover:text-secondary dark:hover:text-accent-blue"
      >
        <Icon name="github" class="w-3.5 h-3.5" />
        GitHub
      </a>
    </div>
  </div>
</section>

<script>
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  interface Msgs {
    nameRequired: string;
    nameShort: string;
    emailRequired: string;
    emailInvalid: string;
    subjectRequired: string;
    messageRequired: string;
    messageShort: string;
    consentRequired: string;
    success: string;
    tooMany: string;
    error: string;
    networkError: string;
  }

  function validate(name: string, value: string, msgs: Msgs): string | null {
    if (name === 'name') {
      if (!value) return msgs.nameRequired;
      if (value.length < 2) return msgs.nameShort;
    }
    if (name === 'email') {
      if (!value) return msgs.emailRequired;
      if (!EMAIL_RE.test(value)) return msgs.emailInvalid;
    }
    if (name === 'subject') {
      if (!value) return msgs.subjectRequired;
    }
    if (name === 'message') {
      if (!value) return msgs.messageRequired;
      if (value.length < 20) return msgs.messageShort;
    }
    if (name === 'consent') {
      if (value !== 'true') return msgs.consentRequired;
    }
    return null;
  }

  function setFieldError(form: HTMLFormElement, fieldName: string, msg: string | null) {
    const input = form.querySelector<HTMLElement>(`[data-field="${fieldName}"]`);
    const errorEl = form.querySelector<HTMLElement>(`[data-field-error="${fieldName}"]`);
    if (!input || !errorEl) return;

    if (msg) {
      input.classList.add('!border-rose-400', 'dark:!border-rose-500');
      input.classList.remove('border-slate-300', 'dark:border-white/10');
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    } else {
      input.classList.remove('!border-rose-400', 'dark:!border-rose-500');
      input.classList.add('border-slate-300', 'dark:border-white/10');
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
  }

  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form) return;

    const reviewSection = document.getElementById('contact-review');
    const backBtn = document.getElementById('contact-back-btn');
    const confirmBtn = document.getElementById('contact-confirm-btn');
    const status = form.querySelector<HTMLElement>('[data-contact-status]');
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    const d = form.dataset;
    const msgs: Msgs = {
      nameRequired:    d.msgNameRequired    || '',
      nameShort:       d.msgNameShort       || '',
      emailRequired:   d.msgEmailRequired   || '',
      emailInvalid:    d.msgEmailInvalid    || '',
      subjectRequired: d.msgSubjectRequired || '',
      messageRequired: d.msgMessageRequired || '',
      messageShort:    d.msgMessageShort    || '',
      consentRequired: d.msgConsentRequired || '',
      success:         d.msgSuccess         || '',
      tooMany:         d.msgTooMany         || '',
      error:           d.msgError           || '',
      networkError:    d.msgNetworkError    || '',
    };

    const showStatus = (msg: string, isError: boolean) => {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove('hidden', 'text-rose-400', 'text-secondary', 'dark:text-accent-blue');
      if (isError) {
        status.classList.add('text-rose-400');
      } else {
        status.classList.add('text-secondary', 'dark:text-accent-blue');
      }
      status.classList.remove('hidden');
    };

    // Read the current value of any tracked field — checkbox or text.
    const readFieldValue = (el: HTMLElement): string => {
      if (el instanceof HTMLInputElement && el.type === 'checkbox') {
        return el.checked ? 'true' : '';
      }
      return (el as HTMLInputElement | HTMLTextAreaElement).value.trim();
    };

    // Validate on blur
    form.querySelectorAll<HTMLElement>('[data-field]').forEach((el) => {
      el.addEventListener('blur', () => {
        const fieldName = el.getAttribute('data-field')!;
        setFieldError(form, fieldName, validate(fieldName, readFieldValue(el), msgs));
      });
      // Clear error while typing / checking
      const clearEvent = el instanceof HTMLInputElement && el.type === 'checkbox' ? 'change' : 'input';
      el.addEventListener(clearEvent, () => {
        const fieldName = el.getAttribute('data-field')!;
        setFieldError(form, fieldName, null);
      });
    });

    // Collect current field values from the form.
    const collectFields = () => {
      const fd = new FormData(form);
      const consentEl = form.querySelector<HTMLInputElement>('[data-field="consent"]');
      return {
        name:    (fd.get('name')    || '').toString().trim(),
        email:   (fd.get('email')   || '').toString().trim(),
        subject: (fd.get('subject') || '').toString().trim(),
        message: (fd.get('message') || '').toString().trim(),
        consent: consentEl?.checked ? 'true' : '',
        lang:    form.dataset.lang ?? 'es',
      };
    };

    // Show the review section populated with current field values.
    const showReview = (fields: ReturnType<typeof collectFields>) => {
      const nameEl    = document.getElementById('review-name');
      const emailEl   = document.getElementById('review-email');
      const subjectEl = document.getElementById('review-subject');
      const messageEl = document.getElementById('review-message');
      if (nameEl)    nameEl.textContent    = fields.name;
      if (emailEl)   emailEl.textContent   = fields.email;
      if (subjectEl) subjectEl.textContent = fields.subject;
      if (messageEl) messageEl.textContent = fields.message;

      form.hidden = true;
      if (reviewSection) {
        reviewSection.hidden = false;
        // Move focus to the review heading for screen readers.
        const heading = reviewSection.querySelector<HTMLElement>('#review-heading');
        heading?.focus();
      }
    };

    // Send the actual POST request (3.3.6: after user confirmation).
    const sendForm = async (fields: ReturnType<typeof collectFields>) => {
      if (confirmBtn) (confirmBtn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(fields),
        });

        // Hide review, show form with status — data preserved on error (12.4).
        if (reviewSection) reviewSection.hidden = true;
        form.hidden = false;

        if (res.ok) {
          showStatus(msgs.success, false);
          form.reset();
        } else if (res.status === 429) {
          showStatus(msgs.tooMany, true);
        } else {
          showStatus(msgs.error, true);
        }
      } catch {
        if (reviewSection) reviewSection.hidden = true;
        form.hidden = false;
        showStatus(msgs.networkError, true);
      } finally {
        if (confirmBtn) (confirmBtn as HTMLButtonElement).disabled = false;
        if (submitBtn) submitBtn.disabled = false;
      }
    };

    // Step 1: validate → show review (submit button now labelled "Revisar"/"Review").
    const onSubmit = (e: SubmitEvent) => {
      e.preventDefault();
      const fields = collectFields();

      let firstInvalid: HTMLElement | null = null;
      for (const [fieldName, value] of Object.entries(fields)) {
        if (fieldName === 'lang') continue;
        const err = validate(fieldName, value, msgs);
        setFieldError(form, fieldName, err);
        if (err && !firstInvalid) {
          firstInvalid = form.querySelector(`[data-field="${fieldName}"]`);
        }
      }
      if (firstInvalid) {
        firstInvalid.focus();
        return;
      }

      showReview(fields);
    };

    // "Back to edit" — restore form, keep data intact.
    backBtn?.addEventListener('click', () => {
      if (reviewSection) reviewSection.hidden = true;
      form.hidden = false;
      submitBtn?.focus();
    });

    // "Confirm and send" — execute the real POST.
    confirmBtn?.addEventListener('click', () => {
      const fields = collectFields();
      sendForm(fields);
    });

    form.addEventListener('submit', onSubmit);
  }

  document.addEventListener('astro:page-load', initContactForm);
  document.addEventListener('astro:after-swap', initContactForm);
</script>
