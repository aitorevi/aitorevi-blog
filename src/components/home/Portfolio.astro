---
import type { Lang } from '@/i18n/types';
import { t } from '@/i18n/utils';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import EyebrowTag from '@/components/shared/EyebrowTag.astro';
import GlassCard from '@/components/shared/GlassCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const imsUrl = lang === 'en' ? '/en/portfolio/ims' : '/portfolio/ims';
const selfUrl = lang === 'en' ? '/en/portfolio/aitorevi-dev' : '/portfolio/aitorevi-dev';

const projects = [
  {
    name: 'Colorprof',
    url: 'https://www.colorprof.es',
    tagKey: 'home.portfolio.tag.landing',
    descKey: 'home.portfolio.colorprof.desc',
    tech: 'Astro 5, Tailwind CSS',
    accent: 'from-emerald-400/20 to-transparent',
    external: true,
  },
  {
    name: 'IRPH Calculator',
    url: 'https://www.perjuicioirph.com',
    tagKey: 'home.portfolio.tag.tool',
    descKey: 'home.portfolio.irph.desc',
    tech: 'Astro 5, Google Sheets API',
    accent: 'from-accent-sky/20 to-transparent',
    external: true,
  },
  {
    name: 'IMS',
    url: imsUrl,
    tagKey: 'home.portfolio.tag.saas',
    descKey: 'home.portfolio.ims.desc',
    tech: 'Astro 5, Supabase, PWA',
    accent: 'from-accent-violet/20 to-transparent',
    external: false,
  },
  {
    name: 'aitorevi.dev',
    url: selfUrl,
    tagKey: 'home.portfolio.tag.blog',
    descKey: 'home.portfolio.self.desc',
    tech: 'Astro 6, Keystatic, Tailwind',
    accent: 'from-accent-blue/20 to-transparent',
    external: false,
  },
];

// With exactly 4 cards, a 3-column grid leaves one orphan in the
// second row. Drop to 2 columns at lg so the layout splits 2+2.
// Other counts (3, 5, 6, …) keep the 3-column layout.
const itemBasisClass = projects.length === 4
  ? 'basis-full sm:basis-[calc((100%-1.25rem)/2)]'
  : 'basis-full sm:basis-[calc((100%-1.25rem)/2)] lg:basis-[calc((100%-2.5rem)/3)]';
---

<section
  class="relative bg-white py-24 text-ink-900 dark:bg-ink-900/50 dark:text-slate-100 sm:py-32"
  aria-labelledby="portfolio-heading"
>
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeader
      id="portfolio-heading"
      title={t(lang, 'home.portfolio.title')}
      subtitle={t(lang, 'home.portfolio.subtitle')}
    />

    <ul
      class="mt-14 flex flex-wrap justify-center gap-5"
      data-stagger-root
    >
      {projects.map((project, i) => (
        <GlassCard accent={project.accent} index={i} tilt class={itemBasisClass}>
          <div class="relative flex h-full flex-col">
            <EyebrowTag label={t(lang, project.tagKey)} class="mb-3" />

            <h3 class="font-display text-lg font-semibold text-ink-900 dark:text-slate-100">
              <a
                href={project.url}
                {...(project.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                class="after:absolute after:inset-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2"
              >
                {project.name}
              </a>
            </h3>

            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {t(lang, project.descKey)}
            </p>

            <p class="mt-3 font-mono text-[11px] text-secondary dark:text-accent-violet">
              {project.tech}
            </p>
          </div>
        </GlassCard>
      ))}
    </ul>
  </div>
</section>
