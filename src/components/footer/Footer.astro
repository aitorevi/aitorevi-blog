---
import {Icon} from "astro-icon/components";
import { t, getLangFromUrl, getLocalePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isES = lang === 'es';
const contactHref = `${getLocalePath('/', lang)}#contact`;

const legalLinks = isES
    ? [
        { label: 'Privacidad', href: '/privacidad' },
        { label: 'Cookies', href: '/cookies' },
        { label: 'Aviso Legal', href: '/aviso-legal' },
        { label: t(lang, 'legal.accessibility'), href: '/accesibilidad' },
      ]
    : [
        { label: 'Privacy', href: '/en/privacy' },
        { label: 'Cookies', href: '/en/cookies' },
        { label: 'Legal Notice', href: '/en/legal-notice' },
        { label: t(lang, 'legal.accessibility'), href: '/en/accessibility' },
      ];

const manageCookiesLabel = isES ? 'Gestionar cookies' : 'Manage cookies';
---
<footer class="relative flex flex-col w-full items-center justify-center gap-2 py-5 md:py-6 bg-white/90 dark:bg-ink-800/60 backdrop-blur-md border-t border-gray-200 dark:border-white/10 transition-colors duration-200">
    <div class="flex items-center justify-center gap-8">
        <a href="https://es.linkedin.com/in/aitor-reviriego-amor" target="_blank" rel="noopener noreferrer" aria-label={isES ? 'Visitar perfil de LinkedIn' : 'Visit LinkedIn profile'}>
            <Icon name="linkedin" class="w-[1.6rem] h-[1.6rem] md:w-[1.8rem] md:h-[1.8rem] inline-block text-quaternary hover:text-secondary transition ease-linear delay-50 duration-200" aria-hidden="true" />
        </a>
        <a href="https://github.com/aitorevi" target="_blank" rel="noopener noreferrer" aria-label={isES ? 'Ver repositorios en GitHub' : 'View GitHub repositories'}>
            <Icon name="github" class="p-0.5 w-[1.6rem] h-[1.6rem] md:w-[1.8rem] md:h-[1.8rem] inline-block text-quaternary hover:text-secondary transition ease-linear delay-50 duration-200" aria-hidden="true" />
        </a>
        <a href={contactHref} aria-label={isES ? 'Ir al formulario de contacto' : 'Go to contact form'}>
            <Icon name="mail" class="w-[1.6rem] h-[1.6rem] md:w-[1.9rem] md:h-[1.9rem] text-quaternary hover:text-secondary inline-block transition ease-linear delay-50 duration-200" aria-hidden="true" />
        </a>
    </div>
    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-600 dark:text-slate-400">
        &copy; {new Date().getFullYear()} aitorevi · Crafted with Astro
    </p>
    <nav class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 font-mono text-[10px] uppercase tracking-[0.2em] text-slate-600 dark:text-slate-400" aria-label={isES ? 'Enlaces legales' : 'Legal links'}>
        {legalLinks.map((link, i) => (
            <>
                {i > 0 && <span aria-hidden="true" class="select-none">·</span>}
                <a href={link.href} class="inline-block px-2 py-2 hover:text-secondary dark:hover:text-accent-blue transition-colors duration-200">
                    {link.label}
                </a>
            </>
        ))}
        <span aria-hidden="true" class="select-none">·</span>
        <button type="button" id="manage-cookies" class="inline-block px-2 py-2 uppercase tracking-[0.2em] hover:text-secondary dark:hover:text-accent-blue transition-colors duration-200">
            {manageCookiesLabel}
        </button>
    </nav>
    <div class="flex justify-center mt-1">
      <a
        href="https://www.w3.org/WAI/WCAG2AA-Conformance"
        title={isES ? 'Explicación del nivel de conformidad WCAG 2.2 AA' : 'Explanation of WCAG 2.2 Level AA Conformance'}
        class="mt-2 inline-flex items-center opacity-70 hover:opacity-100 transition-opacity duration-200"
      >
        <img
          src="/wcag2.2AA-blue.png"
          alt={isES ? 'Nivel AA de las Pautas de Accesibilidad para el Contenido Web 2.2, W3C-WAI' : 'Level AA of the Web Content Accessibility Guidelines 2.2, W3C-WAI'}
          width="88"
          height="31"
          loading="lazy"
        />
      </a>
    </div>
</footer>

<script is:inline>
    document.addEventListener('astro:page-load', function () {
        var btn = document.getElementById('manage-cookies');
        if (!btn) return;
        btn.addEventListener('click', function () {
            document.dispatchEvent(new CustomEvent('aitorevi:reopen-consent'));
        });
    });
</script>
