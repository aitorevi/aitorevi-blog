---
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';

interface Props {
  lang: Lang;
  sourceUrl: string;
  sourceName: string;
}

const { lang, sourceUrl, sourceName } = Astro.props;
---

<aside
  class="flex items-start gap-3 rounded-r-lg border-l-4 border-accent-violet bg-slate-50 px-4 py-3 text-sm text-slate-700 dark:bg-code-bg dark:text-slate-300"
  aria-label={t(lang, 'blog.republished.linkLabel')}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
    class="mt-0.5 h-4 w-4 shrink-0 text-violet-700 dark:text-accent-violet"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
  </svg>
  <p class="leading-snug">
    {t(lang, 'blog.republished.prefix')}{' '}
    <a
      href={sourceUrl}
      target="_blank"
      rel="canonical noopener external"
      class="font-medium text-violet-700 dark:text-accent-violet underline decoration-violet-700/40 dark:decoration-accent-violet/40 underline-offset-2 transition-colors hover:decoration-violet-700 dark:hover:decoration-accent-violet"
    >
      {sourceName}
    </a>
  </p>
</aside>
