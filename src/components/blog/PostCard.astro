---
/**
 * PostCard Molecule Component
 *
 * Displays a blog post preview card with image, metadata, and excerpt.
 *
 * Atomic Composition:
 * - Atoms: Tag, DateDisplay, ReadingTime
 * - Native: HTML5 semantic elements
 *
 * Accessibility Features:
 * - Semantic HTML5 (article, header, footer)
 * - Heading hierarchy maintained
 * - Image optimization with proper alt text
 * - High contrast ratios (WCAG AA)
 * - Keyboard navigation support
 * - Focus visible states
 *
 * Performance Optimizations:
 * - Zero JavaScript (no hydration)
 * - Lazy loading for below-the-fold images
 * - Aspect ratio boxes prevent layout shift (CLS)
 * - Minimal CSS via Tailwind utilities
 *
 * LCP Strategy:
 * - Priority loading for first 2-3 cards
 * - Lazy loading for remainder
 * - Optimized image formats (WebP/AVIF)
 */

import type { CollectionEntry } from 'astro:content';

import Tag from '@/components/shared/Tag.astro';
import DateDisplay from '@/components/shared/DateDisplay.astro';
import ReadingTime from '@/components/shared/ReadingTime.astro';
import { calculateReadingTime } from '@/lib/blog';
import { formatDate } from '@/lib/date';
import { t, getBlogSlugFromId } from '@/i18n/utils';

interface Props {
  /**
   * Blog post entry from Content Collection
   */
  post: CollectionEntry<'blog'>;

  /**
   * Priority loading for above-the-fold images
   * Set to true for first 2-3 cards on page
   * @default false
   */
  priority?: boolean;

  /**
   * Show featured badge
   * @default true
   */
  showFeaturedBadge?: boolean;

  /**
   * Show crosspost badge (only renders if post has canonicalUrl).
   * @default true
   */
  showCrosspostBadge?: boolean;

  /**
   * Language for locale-aware URLs
   * @default 'es'
   */
  lang?: 'es' | 'en';

  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  post,
  priority = false,
  showFeaturedBadge = true,
  showCrosspostBadge = true,
  lang = 'es',
  class: className = '',
} = Astro.props;

const { data, id, body = '' } = post;
const readingTime = calculateReadingTime(body, lang);

// Generate post URL - strip language prefix from content ID
const slug = getBlogSlugFromId(id);
const postUrl = lang === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;

---

<article
  class={`blog-mock group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-ink-800 to-ink-900 p-1 shadow-2xl ring-1 ring-accent-blue/40 ${className}`}
  itemscope
  itemtype="https://schema.org/BlogPosting"
>
  <!-- Featured Badge (conditionally rendered) -->
  {data.featured && showFeaturedBadge && (
    <div
      class="absolute left-4 top-4 z-[1] rounded-full border border-accent-violet/40 bg-accent-violet/20 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.18em] text-accent-violet shadow-md"
      aria-label={t(lang, 'blog.featured')}
    >
      {t(lang, 'blog.featured')}
    </div>
  )}

  <!-- Draft Badge (dev only) -->
  {data.draft && import.meta.env.DEV && (
    <div
      class="absolute right-4 top-4 z-[1] rounded-full bg-amber-400 px-3 py-1 text-xs font-semibold text-amber-900 shadow-md"
      aria-label={t(lang, 'blog.draft')}
    >
      {t(lang, 'blog.draft')}
    </div>
  )}

  <!-- Cover Image -->
  <a
    href={postUrl}
    class="relative aspect-video w-full overflow-hidden rounded-t-xl bg-ink-900"
    aria-label={`Read full post: ${data.title}`}
  >
    {data.coverImage ? (
      <img
        src={data.coverImage}
        alt={data.coverImageAlt || data.title}
        width="800"
        height="450"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 transform-gpu [backface-visibility:hidden]"
        loading={priority ? 'eager' : 'lazy'}
        decoding={priority ? 'sync' : 'async'}
        itemprop="image"
      />
    ) : (
      <div
        class="flex h-full w-full items-center justify-center bg-home-radial transition-transform duration-500 group-hover:scale-105 transform-gpu [backface-visibility:hidden]"
        role="img"
        aria-label={data.coverImageAlt || data.title}
        itemprop="image"
      >
        <span class="select-none font-display text-4xl font-black tracking-tight text-white md:text-5xl">
          aitorevi<span class="text-accent-violet">.</span>
        </span>
      </div>
    )}
  </a>

  <!-- Card Content -->
  <div class="flex flex-1 flex-col rounded-b-xl bg-ink-900 p-6 text-slate-100">
    <!-- Header: Tags + optional Crosspost badge -->
    <header class="mb-3 flex flex-wrap items-center gap-2">
      <ul class="flex flex-wrap gap-2 list-none p-0" aria-label={t(lang, 'blog.tags')}>
        {data.tags.slice(0, 3).map((tag) => (
          <li><Tag label={tag} variant="accent" /></li>
        ))}
      </ul>
      {data.canonicalUrl && showCrosspostBadge && (
        <Tag
          label={t(lang, 'blog.crosspost.label')}
          variant="crosspost"
        />
      )}
    </header>

    <!-- Main Content -->
    <div class="flex-1 overflow-hidden">
      <h2
        class="mb-3 text-xl font-display font-bold leading-tight text-slate-50 sm:text-2xl"
        itemprop="headline"
      >
        <a
          href={postUrl}
          class="block hover:text-accent-blue focus:text-accent-blue focus:outline-none focus-visible:underline transition-colors duration-200"
        >
          {data.title}
        </a>
      </h2>

      <p
        class="mb-4 line-clamp-5 text-sm leading-relaxed text-slate-400 sm:text-base"
        itemprop="description"
      >
        {data.description}
      </p>
    </div>

    <!-- Footer: Metadata -->
    <footer
      class="flex items-center justify-between border-t border-white/5 pt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-slate-400"
    >
      <DateDisplay
        date={data.publishDate}
        showIcon={true}
        short={true}
        lang={lang}
      />

      <ReadingTime text={readingTime.text} label={t(lang, 'blog.readingTime.label')} />

      {data.updatedDate && (
        <>
          <span class="text-slate-600" aria-hidden="true">•</span>
          <span class="normal-case tracking-normal text-xs text-slate-400">
            {t(lang, 'blog.updated')} {formatDate(data.updatedDate, lang === 'es' ? 'es-ES' : 'en-US')}
          </span>
        </>
      )}
    </footer>

    <!-- Schema.org metadata (invisible, for SEO) -->
    <meta itemprop="datePublished" content={data.publishDate.toISOString()} />
    {data.updatedDate && (
      <meta itemprop="dateModified" content={data.updatedDate.toISOString()} />
    )}
    <meta itemprop="author" content={data.author.name} />
  </div>
</article>

<style>
  .line-clamp-5 {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .blog-mock {
    transform: perspective(1400px) rotateX(1deg) rotateY(-2deg);
    transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .blog-mock:hover {
    transform: perspective(1400px) rotateX(0deg) rotateY(0deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-mock,
    .blog-mock:hover {
      transform: none;
      transition: none;
    }
  }
</style>
