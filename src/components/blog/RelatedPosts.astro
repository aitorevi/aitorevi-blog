---
import type { CollectionEntry } from 'astro:content';
import PostCard from '@/components/blog/PostCard.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/types';

interface Props {
  posts: CollectionEntry<'blog'>[];
  lang: Lang;
}

const { posts, lang } = Astro.props;
---

{posts.length > 0 && (
  <section
    aria-labelledby="related-heading"
    class="mx-auto w-full max-w-5xl px-6 py-16 sm:py-20"
  >
    <h2
      id="related-heading"
      class="mb-8 font-display text-2xl font-bold tracking-tight text-ink-900 dark:text-slate-200 sm:text-3xl"
    >
      {t(lang, 'blog.related.title')}
    </h2>
    <ul class="m-0 grid list-none grid-cols-1 gap-6 p-0 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <li><PostCard post={post} lang={lang} showFeaturedBadge={false} /></li>
      ))}
    </ul>
  </section>
)}
