---
/**
 * WorkCinematic — full-screen scroll-snap project showcase.
 *
 * Each project is its own viewport: sticky number + meta on the left,
 * visual mock on the right, scroll-driven reveals as the user moves
 * through the showcase. Snap scrolling makes the transitions decisive
 * instead of soft, mimicking a presentation deck.
 */
import { getCollection } from 'astro:content';
import type { Lang } from '@/i18n/types';
import { t } from '@/i18n/utils';
import Button from '@/components/shared/Button.astro';
import type { ButtonTone } from '@/components/shared/buttonStyles';
import ProjectMock from '@/components/work/ProjectMock.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const browserUrls: Record<string, string> = {
  ims: 'app.ims.dev/dashboard',
  self: 'aitorevi.dev',
  colorprof: 'colorprof.es',
  irph: 'perjuicioirph.com',
  fitkid: 'fitkid-schedule.vercel.app',
  opencleaner: 'github.com/aitorevi/open-cleaner',
};

const rawProjects = await getCollection('projects');
const projects = rawProjects
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    id: p.id,
    number: p.data.number,
    name: p.data.name,
    tagline: lang === 'es' ? p.data.taglineEs : p.data.taglineEn,
    descKey: p.data.descKey,
    tagKey: p.data.tagKey,
    year: p.data.year,
    stack: p.data.stack,
    accent: p.data.accent,
    href: lang === 'es' ? p.data.hrefEs : p.data.hrefEn,
    external: p.data.external,
    metric: {
      value: p.data.metric.value,
      label: lang === 'es' ? p.data.metric.labelEs : p.data.metric.labelEn,
    },
    mockType: p.data.mockType,
    browserUrl: browserUrls[p.id] ?? p.id,
  }));

const accentMap: Record<string, { text: string; textDark: string; bg: string; ring: string; glow: string; border: string; borderLight: string; bgLight: string; buttonTone: ButtonTone; sectionVar: string }> = {
  violet:  { text: 'text-violet-700 dark:text-accent-violet',   textDark: 'text-accent-violet',  bg: 'bg-accent-violet',  ring: 'ring-accent-violet/40',  glow: 'from-accent-violet/30', border: 'border-accent-violet/40',  borderLight: 'border-accent-violet/40', bgLight: 'bg-accent-violet/5',  buttonTone: 'violet', sectionVar: '--color-section-violet' },
  blue:    { text: 'text-blue-700 dark:text-accent-blue',       textDark: 'text-accent-blue',    bg: 'bg-accent-blue',    ring: 'ring-accent-blue/40',    glow: 'from-accent-blue/30',   border: 'border-accent-blue/40',    borderLight: 'border-accent-blue/40',   bgLight: 'bg-accent-blue/5',    buttonTone: 'blue',   sectionVar: '--color-section-blue' },
  emerald: { text: 'text-emerald-700 dark:text-accent-emerald', textDark: 'text-accent-emerald', bg: 'bg-accent-emerald', ring: 'ring-accent-emerald/40', glow: 'from-accent-emerald/25', border: 'border-accent-emerald/40', borderLight: 'border-accent-emerald/40', bgLight: 'bg-accent-emerald/5', buttonTone: 'emerald', sectionVar: '--color-section-emerald' },
  sky:     { text: 'text-sky-700 dark:text-accent-sky',         textDark: 'text-accent-sky',     bg: 'bg-accent-sky',     ring: 'ring-accent-sky/40',     glow: 'from-accent-sky/25',    border: 'border-accent-sky/40',     borderLight: 'border-accent-sky/40',    bgLight: 'bg-accent-sky/5',     buttonTone: 'blue',   sectionVar: '--color-section-sky' },
  zinc:    { text: 'text-zinc-700 dark:text-zinc-300',          textDark: 'text-zinc-300',       bg: 'bg-zinc-500',       ring: 'ring-zinc-500/40',       glow: 'from-zinc-500/20',      border: 'border-zinc-500/40',       borderLight: 'border-zinc-300',         bgLight: 'bg-zinc-50',          buttonTone: 'blue',   sectionVar: '--color-section-blue' },
};

const ctaLabel = t(lang, 'home.work.cta.case');
const externalLabel = t(lang, 'home.work.cta.external');
---

<section class="work-cinematic relative" aria-labelledby="work-heading">

  <!-- Intro / hero -->
  <header class="relative flex min-h-screen items-center justify-center px-6 pb-24 pt-32 text-center">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute left-1/2 top-1/2 hidden h-[40rem] w-[40rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-conic from-accent-violet/30 via-accent-blue/20 to-accent-sky/30 blur-[120px] dark:block"></div>
    </div>

    <div>
      <p class="font-mono text-xs uppercase tracking-[0.4em] text-secondary dark:text-accent-blue">
        {t(lang, 'home.work.hero.eyebrow')}
      </p>
      <h1
        id="work-heading"
        class="mt-6 font-display text-6xl font-black leading-none tracking-tight text-ink-900 dark:text-slate-50 sm:text-7xl md:text-8xl"
      >
        {t(lang, 'home.work.hero.title')}
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400 sm:text-lg">
        {t(lang, 'home.work.hero.desc')}
      </p>

      <div class="mt-12 flex flex-col items-center gap-3" aria-hidden="true">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-secondary dark:text-accent-blue">
          {t(lang, 'home.work.label.scroll')}
        </span>
        <div class="cinematic-scroll-line"></div>
      </div>
    </div>
  </header>

  <!-- Project sections -->
  {projects.map((p, i) => {
    const accent = accentMap[p.accent];
    const flip = i % 2 === 1;
    return (
      <article
        class="cinematic-section relative flex min-h-screen items-center px-6 py-24 md:py-32"
        data-cinematic-section
        style={`--cin-i:${i}; --cin-hover:rgb(var(${accent.sectionVar}))`}
        aria-labelledby={`proj-${p.id}`}
      >
        <!-- Per-section ambient glow -->
        <div aria-hidden="true" class={`pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br ${accent.glow} via-transparent to-transparent opacity-70`}></div>
        <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

        <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-12 md:grid-cols-12 md:gap-12 lg:gap-16">

          <!-- Left: sticky meta (flip moves it visually to the right on even-indexed sections) -->
          <div class={`md:col-span-5 lg:col-span-5 ${flip ? 'md:order-2' : ''}`} data-cinematic-meta>
            <div class="space-y-8">
              <div class="flex items-baseline gap-4">
                <span class={`font-display text-5xl font-black tracking-tighter ${accent.text} md:text-6xl`}>
                  {p.number}
                </span>
                <span class={`inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.25em] ${accent.text}`}>
                  <span class={`h-1.5 w-1.5 rounded-full ${accent.bg} animate-pulse`}></span>
                  {t(lang, p.tagKey)}
                </span>
              </div>

              <div>
                <h2
                  id={`proj-${p.id}`}
                  class="font-display text-4xl font-black tracking-tight text-ink-900 dark:text-slate-50 md:text-5xl lg:text-6xl"
                >
                  <a
                    href={p.href}
                    {...(p.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    class="proj-title-link transition-colors duration-200 focus:outline-none focus-visible:underline"
                  >
                    {p.name}
                  </a>
                </h2>
                <p class={`mt-3 font-display text-lg italic ${accent.text}`}>
                  {p.tagline}
                </p>
              </div>

              <p class="max-w-md text-sm leading-relaxed text-slate-700 dark:text-slate-300 md:text-base">
                {t(lang, p.descKey)}
              </p>

              <dl class="grid grid-cols-2 items-start gap-x-6 gap-y-3 font-mono text-[11px] uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
                <div>
                  <dt class="text-[9px]">{t(lang, 'home.work.label.year')}</dt>
                  <dd class="mt-1 text-slate-700 dark:text-slate-200 normal-case tracking-normal text-xs">
                    {p.year}
                  </dd>
                </div>
                <div>
                  <dt class="text-[9px]">{p.metric.label}</dt>
                  <dd class={`mt-1 font-display text-2xl font-black ${accent.text} normal-case tracking-tight`}>
                    {p.metric.value}
                  </dd>
                </div>
              </dl>

              <ul class="flex flex-wrap gap-2 font-mono text-[10px] uppercase tracking-[0.15em]">
                {p.stack.map((s) => (
                  <li class={`rounded-full border px-2.5 py-1 ${accent.borderLight} ${accent.bgLight} ${accent.text} dark:${accent.border} dark:bg-white/5 dark:${accent.textDark}`}>{s}</li>
                ))}
              </ul>

              <Button
                href={p.href}
                tone={accent.buttonTone}
                variant="ghost"
                {...(p.external ? { target: '_blank' } : {})}
              >
                {p.external ? externalLabel : ctaLabel}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">
                  {p.external ? <path d="M7 17 17 7M7 7h10v10" /> : <path d="M5 12h14M13 5l7 7-7 7" />}
                </svg>
              </Button>
            </div>
          </div>

          <!-- Right: visual mock -->
          <div class={`md:col-span-7 lg:col-span-7 ${flip ? 'md:order-1' : ''}`} data-cinematic-visual>
            <ProjectMock
              type={p.mockType}
              lang={lang}
              flip={flip}
              href={p.href}
              external={p.external}
              ring={accent.ring}
              browserUrl={p.browserUrl}
            />
            <p class="mt-4 text-right font-mono text-[10px] uppercase tracking-[0.25em] text-slate-500">
              {String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}
            </p>
          </div>
        </div>
      </article>
    );
  })}

  <!-- Outro -->
  <footer class="relative flex min-h-[45vh] items-center justify-center px-6 py-24 text-center">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-accent-violet/5 to-transparent"></div>
    </div>
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.4em] text-secondary dark:text-accent-blue">
        {t(lang, 'home.work.outro.eyebrow')}
      </p>
      <h2 class="mt-6 font-display text-4xl font-black tracking-tight text-ink-900 dark:text-slate-50 md:text-6xl">
        {t(lang, 'home.work.outro.title')}
      </h2>
    </div>
  </footer>
</section>

<style>
  /* Conic gradient util (used in hero) */
  .bg-gradient-conic {
    background: conic-gradient(from 180deg at 50% 50%, var(--tw-gradient-stops));
  }

  /* Section reveal */
  .cinematic-section [data-cinematic-meta] {
    opacity: 0;
    transition: opacity 700ms ease, transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
    transform: translate3d(0, 32px, 0);
  }
  .cinematic-section [data-cinematic-visual] {
    opacity: 0;
    transition: opacity 700ms ease;
    transition-delay: 100ms;
  }
  .cinematic-section.is-active [data-cinematic-meta] {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
  .cinematic-section.is-active [data-cinematic-visual] {
    opacity: 1;
  }

  /* Per-section title hover — color comes from --cin-hover set on the article */
  .cinematic-section .proj-title-link:hover,
  .cinematic-section .proj-title-link:focus-visible {
    color: var(--cin-hover);
  }

  /* Scroll snap — align each project section to the viewport top */
  .cinematic-section {
    scroll-snap-align: start;
  }

  /* Scroll hint line */
  .cinematic-scroll-line {
    position: relative;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, transparent, rgba(148, 163, 184, 0.5), transparent);
    overflow: hidden;
  }
  .cinematic-scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, currentColor, transparent);
    color: rgb(139, 92, 246);
    animation: cinematic-scroll-trail 2s ease-in-out infinite;
  }
  @keyframes cinematic-scroll-trail {
    0% { transform: translateY(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(100%); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cinematic-section [data-cinematic-meta],
    .cinematic-section [data-cinematic-visual] {
      opacity: 1;
      transition: none;
    }
    .cinematic-section [data-cinematic-meta] {
      transform: none;
    }
    .cinematic-scroll-line::after {
      animation: none;
    }
  }
</style>

<style is:global>
  /* scroll-snap-type must live on the scroll container (body).
     scroll-padding-top offsets the sticky nav so sections snap below it. */
  body:has(.work-cinematic) {
    scroll-snap-type: y mandatory;
    scroll-padding-top: 3.5rem; /* mobile nav height */
  }
  @media (min-width: 768px) {
    body:has(.work-cinematic) {
      scroll-padding-top: 5rem; /* desktop nav height */
    }
  }
  @media (prefers-reduced-motion: reduce) {
    body:has(.work-cinematic) {
      scroll-snap-type: none;
    }
  }
</style>

<script>
  function setupCinematicReveal() {
    const sections = document.querySelectorAll<HTMLElement>('[data-cinematic-section]');
    if (sections.length === 0) return;

    if (typeof IntersectionObserver === 'undefined') {
      sections.forEach((s) => s.classList.add('is-active'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-active');
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25, rootMargin: '0px 0px -5% 0px' },
    );

    sections.forEach((s) => {
      if (s.getBoundingClientRect().top < window.innerHeight) {
        s.classList.add('is-active');
      } else {
        observer.observe(s);
      }
    });

    document.addEventListener('astro:before-preparation', () => observer.disconnect(), { once: true });
  }

  setupCinematicReveal();
  document.addEventListener('astro:page-load', setupCinematicReveal);
</script>
