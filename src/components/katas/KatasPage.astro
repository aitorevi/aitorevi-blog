---
import KataCard from './KataCard.astro';
import KatasScrollReveal from './KatasScrollReveal.astro';
import DotField from '../atoms/DotField.astro';
import { katas } from '../../data/katas';
import type { Lang } from '../../data/cv';
import { t } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const sorted = [...katas].sort((a, b) => (a.date < b.date ? 1 : -1));

const techFrequency = new Map<string, number>();
for (const kata of sorted) {
  for (const label of kata.tech) {
    techFrequency.set(label, (techFrequency.get(label) ?? 0) + 1);
  }
}
const techs = [...techFrequency.entries()]
  .filter(([, count]) => count >= 2)
  .sort((a, b) => (b[1] - a[1]) || a[0].localeCompare(b[0]))
  .map(([name]) => name);
---

<div class="relative min-h-screen">
  <DotField position="fixed" />
  <KatasScrollReveal />

  <section class="katas-page mx-auto max-w-7xl mt-16 md:mt-24 mb-2 md:mb-4 p-6 sm:p-7 md:p-8 lg:px-20 lg:pt-10 lg:pb-20">
    <header class="reveal-fade mb-12 text-center">
      <h1 class="mb-4 pb-2 font-display text-5xl font-black tracking-tight text-ink-900 dark:bg-home-gradient-text dark:bg-clip-text dark:text-transparent sm:text-6xl lg:text-7xl">
        {t(lang, 'katas.title')}
      </h1>
      <p class="mx-auto mt-3 max-w-xl font-mono text-xs uppercase tracking-[0.3em] text-secondary/70 dark:text-accent-blue/50">
        {t(lang, 'katas.subtitle')}
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-base text-slate-600 dark:text-slate-300 sm:text-lg">
        {t(lang, 'katas.intro')}
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-500 dark:text-slate-400">
        {t(lang, 'katas.context')}
      </p>
    </header>

    <div
      class="reveal-fade mb-8 flex flex-wrap justify-center gap-2"
      role="group"
      aria-label={t(lang, 'katas.filter.groupLabel')}
      data-kata-filters
    >
      <button
        type="button"
        data-kata-filter="all"
        aria-pressed="true"
        class="kata-chip inline-flex items-center rounded-full border border-secondary/30 bg-secondary/10 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.15em] text-secondary transition hover:border-secondary/50 hover:bg-secondary/15 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 aria-pressed:bg-secondary aria-pressed:text-white dark:border-accent-blue/30 dark:bg-accent-blue/10 dark:text-accent-blue dark:hover:border-accent-blue/50 dark:hover:bg-accent-blue/20 dark:aria-pressed:bg-accent-blue dark:aria-pressed:text-ink-900 dark:focus-visible:ring-offset-ink-900"
      >
        {t(lang, 'katas.filter.all')}
      </button>
      {techs.map((tech) => (
        <button
          type="button"
          data-kata-filter={tech}
          aria-pressed="false"
          class="kata-chip inline-flex items-center rounded-full border border-slate-300 bg-white px-3 py-1 font-mono text-[11px] uppercase tracking-[0.15em] text-slate-600 transition hover:border-secondary/40 hover:text-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 aria-pressed:border-secondary aria-pressed:bg-secondary aria-pressed:text-white dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-300 dark:hover:border-accent-blue/40 dark:hover:text-accent-blue dark:aria-pressed:border-accent-blue dark:aria-pressed:bg-accent-blue dark:aria-pressed:text-ink-900 dark:focus-visible:ring-offset-ink-900"
        >
          {tech}
        </button>
      ))}
    </div>

    <div class="reveal-group grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-kata-grid>
      {sorted.map((kata) => <KataCard kata={kata} lang={lang} />)}
    </div>

    <aside class="mt-16 rounded-2xl border border-slate-200 bg-white/70 p-8 text-center shadow-lg backdrop-blur-md dark:border-white/10 dark:bg-white/[0.04] dark:shadow-2xl sm:p-10">
      <h2 class="font-display text-2xl font-bold tracking-tight text-ink-900 dark:text-slate-100 sm:text-3xl">
        {t(lang, 'katas.cta.heading')}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-slate-600 dark:text-slate-300 sm:text-base">
        {t(lang, 'katas.cta.description')}
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://github.com/aitorevi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-secondary bg-secondary px-5 py-2.5 font-mono text-xs uppercase tracking-[0.15em] text-white transition hover:bg-secondary/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 dark:border-accent-blue dark:bg-accent-blue dark:text-ink-900 dark:hover:bg-accent-blue/90 dark:focus-visible:ring-accent-blue dark:focus-visible:ring-offset-ink-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path d="M12 .5C5.37.5 0 5.87 0 12.5a12 12 0 0 0 8.21 11.41c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.33-1.78-1.33-1.78-1.08-.74.08-.73.08-.73 1.2.08 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.24-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.24a11.4 11.4 0 0 1 6 0c2.29-1.56 3.3-1.24 3.3-1.24.66 1.66.24 2.88.12 3.18.77.85 1.23 1.92 1.23 3.24 0 4.62-2.81 5.65-5.49 5.94.43.38.82 1.12.82 2.26v3.35c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z" />
          </svg>
          {t(lang, 'katas.cta.github')}
        </a>
        <a
          href="mailto:info@aitorevi.dev"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-5 py-2.5 font-mono text-xs uppercase tracking-[0.15em] text-slate-700 transition hover:border-secondary/60 hover:text-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 dark:border-white/15 dark:bg-white/[0.04] dark:text-slate-200 dark:hover:border-accent-blue/60 dark:hover:text-accent-blue dark:focus-visible:ring-accent-blue dark:focus-visible:ring-offset-ink-900"
        >
          {t(lang, 'katas.cta.contact')}
        </a>
      </div>
    </aside>
  </section>
</div>

<script>
  function setupKataFilters() {
    const root = document.querySelector<HTMLElement>('[data-kata-filters]');
    const cards = document.querySelectorAll<HTMLElement>('[data-kata-card]');
    if (!root || cards.length === 0) return;

    const buttons = root.querySelectorAll<HTMLButtonElement>('[data-kata-filter]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const active = btn.dataset.kataFilter ?? 'all';

        buttons.forEach((b) => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });

        cards.forEach((card) => {
          if (active === 'all') {
            card.hidden = false;
            card.classList.add('is-visible');
            return;
          }
          const tech = (card.dataset.tech ?? '').split('|');
          const match = tech.includes(active);
          card.hidden = !match;
          if (match) card.classList.add('is-visible');
        });
      });
    });
  }

  setupKataFilters();
  document.addEventListener('astro:page-load', setupKataFilters);
</script>

<style is:global>
  body:has(.katas-page) {
    background-color: #f8fafc;
    background-image: none;
  }
  html.dark body:has(.katas-page),
  html.dark body:has(.katas-page) main {
    background-color: #020617;
    background-image: radial-gradient(ellipse at 30% 20%, #0f172a 0%, #020617 55%, #000 100%);
    background-attachment: fixed;
    background-size: cover;
  }
  [data-kata-card][hidden] {
    display: none !important;
  }
</style>
