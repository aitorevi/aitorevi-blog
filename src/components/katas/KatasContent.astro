---
import KataCard from './KataCard.astro';
import KatasScrollReveal from './KatasScrollReveal.astro';
import Button from '@/components/shared/Button.astro';
import FilterChip from '@/components/atoms/FilterChip.astro';
import GlossaryTerm from '@/components/atoms/GlossaryTerm.astro';
import { sortedKatas } from '@/data/katas';
import { getDefinition } from '@/data/glossary';
import type { Lang } from '@/i18n/types';
import { getLocalePath, t } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const sorted = sortedKatas();
const kataDefinition = getDefinition('kata', lang) ?? '';

const techFrequency = new Map<string, number>();
for (const kata of sorted) {
  for (const label of kata.tech) {
    techFrequency.set(label, (techFrequency.get(label) ?? 0) + 1);
  }
}
const techs = [...techFrequency.entries()]
  .filter(([, count]) => count >= 2)
  .sort((a, b) => (b[1] - a[1]) || a[0].localeCompare(b[0]))
  .map(([name]) => name);
---

<div class="relative min-h-screen">
  <KatasScrollReveal />

  <section class="katas-page mx-auto max-w-7xl mt-16 md:mt-24 mb-2 md:mb-4 p-6 sm:p-7 md:p-8 lg:px-20 lg:pt-10 lg:pb-20">
    <header class="reveal-fade mb-12 text-center">
      <h1 class="mb-4 pb-2 font-display text-5xl font-black tracking-tight text-ink-900 dark:bg-home-gradient-text dark:bg-clip-text dark:text-transparent sm:text-6xl lg:text-7xl">
        {t(lang, 'katas.title')}
      </h1>
      <p class="mx-auto mt-3 max-w-xl font-mono text-xs uppercase tracking-[0.3em] text-secondary dark:text-accent-blue">
        {t(lang, 'katas.subtitle')}
      </p>
      {kataDefinition && (
        <p class="mx-auto mt-2 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
          <GlossaryTerm term={t(lang, 'katas.title')} definition={kataDefinition} />
        </p>
      )}
      <p class="mx-auto mt-4 max-w-2xl text-base text-slate-600 dark:text-slate-300 sm:text-lg">
        {t(lang, 'katas.intro')}
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-500 dark:text-slate-400">
        {t(lang, 'katas.context')}
      </p>
    </header>

    <div
      class="reveal-fade mb-8 flex flex-wrap justify-center gap-2"
      role="group"
      aria-label={t(lang, 'katas.filter.groupLabel')}
      data-kata-filters
    >
      <FilterChip variant="brand" pressed={true} data-kata-filter="all">
        {t(lang, 'katas.filter.all')}
      </FilterChip>
      {techs.map((tech) => (
        <FilterChip variant="neutral" pressed={false} data-kata-filter={tech}>
          {tech}
        </FilterChip>
      ))}
    </div>

    <div class="reveal-group flex flex-wrap justify-center gap-5" data-kata-grid>
      {sorted.map((kata) => <KataCard kata={kata} lang={lang} />)}
    </div>

    <div
      class="mt-12 text-center"
      data-kata-empty
      hidden
      role="status"
      aria-live="polite"
    >
      <p class="text-sm text-slate-600 dark:text-slate-300">
        {t(lang, 'katas.empty.title')}
      </p>
      <FilterChip variant="outlined" class="mt-4" data-kata-empty-reset>
        {t(lang, 'katas.empty.reset')}
      </FilterChip>
    </div>

    <div class="reveal-fade mt-24 md:mt-32 lg:mt-40">
      <h2 class="text-center font-display text-2xl font-bold tracking-tight text-ink-900 dark:text-slate-100 sm:text-3xl">
        {t(lang, 'katas.cta.heading')}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-center text-sm leading-relaxed text-slate-600 dark:text-slate-300 sm:text-base">
        {t(lang, 'katas.cta.description')}
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
        <Button href="https://github.com/aitorevi" target="_blank" tone="blue">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 transition-transform group-hover:-translate-y-0.5" aria-hidden="true">
            <path d="M12 .5C5.37.5 0 5.87 0 12.5a12 12 0 0 0 8.21 11.41c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.33-1.78-1.33-1.78-1.08-.74.08-.73.08-.73 1.2.08 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.24-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.24a11.4 11.4 0 0 1 6 0c2.29-1.56 3.3-1.24 3.3-1.24.66 1.66.24 2.88.12 3.18.77.85 1.23 1.92 1.23 3.24 0 4.62-2.81 5.65-5.49 5.94.43.38.82 1.12.82 2.26v3.35c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z" />
          </svg>
          <span>{t(lang, 'katas.cta.github')}</span>
        </Button>
        <Button href={`${getLocalePath('/', lang)}#contact`} tone="violet">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform group-hover:-translate-y-0.5" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" />
          </svg>
          <span>{t(lang, 'katas.cta.contact')}</span>
        </Button>
      </div>
    </div>
  </section>
</div>

<script>
  function setupKataFilters() {
    const root = document.querySelector<HTMLElement>('[data-kata-filters]');
    const cards = document.querySelectorAll<HTMLElement>('[data-kata-card]');
    if (!root || cards.length === 0) return;

    const buttons = root.querySelectorAll<HTMLButtonElement>('[data-kata-filter]');
    const empty = document.querySelector<HTMLElement>('[data-kata-empty]');
    const emptyReset = document.querySelector<HTMLButtonElement>('[data-kata-empty-reset]');
    const allChip = root.querySelector<HTMLButtonElement>('[data-kata-filter="all"]');

    const applyFilter = (btn: HTMLButtonElement) => {
      const active = btn.dataset.kataFilter ?? 'all';
      buttons.forEach((b) => {
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      });

      let visibleCount = 0;
      cards.forEach((card) => {
        if (active === 'all') {
          card.hidden = false;
          card.classList.add('is-visible');
          visibleCount++;
          return;
        }
        const tech = (card.dataset.tech ?? '').split('|');
        const match = tech.includes(active);
        card.hidden = !match;
        if (match) {
          card.classList.add('is-visible');
          visibleCount++;
        }
      });

      if (empty) empty.hidden = visibleCount > 0;
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => applyFilter(btn));
    });

    if (emptyReset && allChip) {
      emptyReset.addEventListener('click', () => applyFilter(allChip));
    }
  }

  setupKataFilters();
  document.addEventListener('astro:page-load', setupKataFilters);
</script>

<style is:global>
  [data-kata-card][hidden] {
    display: none !important;
  }
</style>
