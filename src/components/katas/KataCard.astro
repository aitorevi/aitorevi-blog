---
import { Icon } from 'astro-icon/components';
import Tag from '@/components/shared/Tag.astro';
import { GLASS_SURFACE_CLASSES } from '@/components/shared/glassCardStyles';
import type { Kata } from '@/data/katas';
import type { Lang } from '@/i18n/types';
import { t, getLangLocale } from '@/i18n/utils';

interface Props {
  kata: Kata;
  lang: Lang;
}

const { kata, lang } = Astro.props;

const dateLocale = getLangLocale(lang);
const formattedDate = new Date(kata.date).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'short',
});
---

<article
  class:list={[
    GLASS_SURFACE_CLASSES,
    'reveal-fade flex flex-col gap-4 basis-full sm:basis-[calc((100%-1.25rem)/2)] lg:basis-[calc((100%-2.5rem)/3)]',
  ]}
  data-kata-card
  data-tech={kata.tech.join('|')}
>
  <header class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-display text-xl font-bold tracking-tight text-ink-900 dark:text-slate-100">
        <a
          href={kata.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="after:absolute after:inset-0 after:rounded-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-ink-900"
        >
          {kata.title}
          <span class="sr-only"> — {t(lang, 'katas.card.openOnGithub')}</span>
        </a>
      </h3>
      <p class="mt-1 font-mono text-[11px] 2xl:text-[13px] uppercase tracking-[0.25em] text-secondary dark:text-accent-blue">
        {formattedDate}
      </p>
    </div>
  </header>

  <p class="relative text-sm leading-relaxed text-slate-600 dark:text-slate-300">
    {kata.description[lang]}
  </p>

  <div class="relative mt-auto flex flex-col gap-3">
    <div class="flex flex-wrap gap-2">
      {kata.tech.map((label) => <Tag label={label} variant="accent" />)}
    </div>
    {kata.concepts.length > 0 && (
      <ul class="flex flex-wrap gap-x-3 gap-y-1 font-mono text-[11px] 2xl:text-[13px] tracking-wide text-quaternary/80 dark:text-slate-400">
        {kata.concepts.map((label) => (
          <li class="before:mr-0.5 before:text-secondary before:content-['#'] dark:before:text-accent-blue/60">
            {label}
          </li>
        ))}
      </ul>
    )}
  </div>

  <span class="pointer-events-none absolute right-4 top-4 text-quaternary opacity-60 transition-opacity duration-200 md:opacity-0 md:group-hover:opacity-100 md:group-focus-within:opacity-100 dark:text-slate-400">
    <Icon name="github" class="w-5 h-5" aria-hidden="true" />
  </span>
</article>
