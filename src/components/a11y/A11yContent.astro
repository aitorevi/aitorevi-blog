---
import Layout from '@/layouts/Layout.astro';
import EyebrowTag from '@/components/shared/EyebrowTag.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import type { Lang } from '@/i18n/types';
import { t } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isEs = lang === 'es';
const title = `${t(lang, 'a11y.badge')} — aitorevi.dev`;
const description = t(lang, 'a11y.subtitle');
const canonicalUrl = `https://www.aitorevi.dev${isEs ? '/accesibilidad' : '/en/accessibility'}`;
const alternateUrl = `https://www.aitorevi.dev${isEs ? '/en/accessibility' : '/accesibilidad'}`;

const implKeys = [
  'a11y.impl.skip',
  'a11y.impl.focus',
  'a11y.impl.scroll',
  'a11y.impl.motion',
  'a11y.impl.links',
  'a11y.impl.semantic',
  'a11y.impl.aria',
  'a11y.impl.images',
  'a11y.impl.forms',
  'a11y.impl.lang',
  'a11y.impl.contrast',
  'a11y.impl.dialog',
] as const;
---

<Layout
  title={title}
  lang={lang}
  description={description}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  variant="dark-radial"
>
  <main class="mx-auto max-w-5xl px-6 pt-28 pb-16 space-y-20 text-ink-900 dark:text-slate-100">

    <!-- Header -->
    <section class="space-y-4">
      <EyebrowTag label={t(lang, 'a11y.badge')} />
      <h1 class="font-display text-4xl font-black text-fg sm:text-5xl">{t(lang, 'a11y.title')}</h1>
      <p class="font-mono text-sm text-fg-muted max-w-xl">{t(lang, 'a11y.subtitle')}</p>
    </section>

    <!-- Stats -->
    <section aria-label={isEs ? 'Métricas de accesibilidad' : 'Accessibility metrics'}>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.contrast.value')}<span class="text-2xl">{t(lang, 'a11y.stats.contrast.suffix')}</span>
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.contrast.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.touch.value')}<span class="text-2xl">{t(lang, 'a11y.stats.touch.suffix')}</span>
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.touch.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.pages.value')}
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.pages.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.violations.value')}
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.violations.label')}
          </div>
        </div>
      </div>
    </section>

    <!-- Pillars -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.pillars.heading')} subtitle={t(lang, 'a11y.pillars.subtitle')} />
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Perceivable -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.perceivable.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.perceivable.desc')}</p>
        </div>
        <!-- Operable -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.operable.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.operable.desc')}</p>
        </div>
        <!-- Robust -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.robust.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.robust.desc')}</p>
        </div>
      </div>
    </section>

    <!-- Implementation checklist -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.impl.heading')} subtitle={t(lang, 'a11y.impl.subtitle')} />
      <ul class="grid gap-3 sm:grid-cols-2" role="list">
        {implKeys.map((key) => (
          <li class="flex gap-2 items-start">
            <svg aria-hidden="true" class="w-4 h-4 flex-shrink-0 mt-0.5 text-emerald-600 dark:text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="font-mono text-sm text-fg-muted">{t(lang, key)}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Tools -->
    <section class="space-y-6">
      <SectionHeader title={t(lang, 'a11y.tools.heading')} subtitle={t(lang, 'a11y.tools.subtitle')} />
      <p class="font-mono text-sm text-fg-muted max-w-2xl">{t(lang, 'a11y.tools.desc')}</p>
      <div class="rounded-lg bg-slate-900 dark:bg-ink-800 border border-slate-700 p-4 overflow-x-auto">
        <pre class="font-mono text-sm text-emerald-400">$ {t(lang, 'a11y.tools.command')}</pre>
      </div>
      <span class="block font-mono text-xs text-fg-muted">{t(lang, 'a11y.tools.scope')}</span>
    </section>

  </main>
</Layout>
