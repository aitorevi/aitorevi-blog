---
import Layout from '@/layouts/Layout.astro';
import EyebrowTag from '@/components/shared/EyebrowTag.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import type { Lang } from '@/i18n/types';
import { t, getLocalePath } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isEs = lang === 'es';
const title = `${t(lang, 'a11y.badge')} — aitorevi.dev`;
const description = t(lang, 'a11y.subtitle');
const canonicalUrl = `https://www.aitorevi.dev${isEs ? '/accesibilidad' : '/en/accessibility'}`;
const alternateUrl = `https://www.aitorevi.dev${isEs ? '/en/accessibility' : '/accesibilidad'}`;
const caseStudyHref = getLocalePath('/work/aitorevi-dev', lang);

const contrastPairs = [
  { labelKey: 'a11y.contrast.body',   light: { fg: '#151b27', bg: '#ffffff', ratio: '18.1' }, dark: { fg: '#f1f5f9', bg: '#0f1419', ratio: '15.8' } },
  { labelKey: 'a11y.contrast.accent', light: { fg: '#5e3aee', bg: '#ffffff', ratio: '5.3'  }, dark: { fg: '#ac91fc', bg: '#0f1419', ratio: '7.2'  } },
  { labelKey: 'a11y.contrast.muted',  light: { fg: '#64748b', bg: '#ffffff', ratio: '4.7'  }, dark: { fg: '#94a3b8', bg: '#0f1419', ratio: '5.9'  } },
] as const;

const verifiedPages = [
  { path: '/',          labelKey: 'a11y.pages.home' },
  { path: '/blog',      labelKey: 'a11y.pages.blog' },
  { path: '/work',      labelKey: 'a11y.pages.work' },
  { path: '/cv',        labelKey: 'a11y.pages.cv'   },
  { path: '/en',        labelKey: 'a11y.pages.home' },
  { path: '/en/blog',   labelKey: 'a11y.pages.blog' },
  { path: '/en/work',   labelKey: 'a11y.pages.work' },
  { path: '/en/cv',     labelKey: 'a11y.pages.cv'   },
] as const;

const implKeys = [
  'a11y.impl.skip',
  'a11y.impl.focus',
  'a11y.impl.scroll',
  'a11y.impl.motion',
  'a11y.impl.links',
  'a11y.impl.semantic',
  'a11y.impl.aria',
  'a11y.impl.images',
  'a11y.impl.forms',
  'a11y.impl.lang',
  'a11y.impl.contrast',
  'a11y.impl.dialog',
] as const;
---

<Layout
  title={title}
  lang={lang}
  description={description}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  variant="dark-radial"
>
  <main class="mx-auto max-w-5xl px-6 pt-28 pb-16 space-y-20 text-ink-900 dark:text-slate-100">

    <!-- Header -->
    <section class="space-y-3">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <EyebrowTag label={t(lang, 'a11y.badge')} />
        <a
          href={caseStudyHref}
          class="group inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[0.25em] text-accent focus:outline-none focus-visible:underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform duration-500 group-hover:-translate-x-1" aria-hidden="true">
            <path d="M19 12H5M11 5l-7 7 7 7" />
          </svg>
          <span class="relative h-px w-10 bg-accent transition-all duration-500 group-hover:w-16"></span>
          <span>{t(lang, 'a11y.backLink')}</span>
        </a>
      </div>
      <h1 class="font-display text-4xl font-black text-fg sm:text-5xl">{t(lang, 'a11y.title')}</h1>
      <p class="font-mono text-sm text-fg-muted max-w-xl">{t(lang, 'a11y.subtitle')}</p>
    </section>

    <!-- Stats -->
    <section aria-label={isEs ? 'Métricas de accesibilidad' : 'Accessibility metrics'}>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.contrast.value')}<span class="text-2xl">{t(lang, 'a11y.stats.contrast.suffix')}</span>
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.contrast.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.touch.value')}<span class="text-2xl">{t(lang, 'a11y.stats.touch.suffix')}</span>
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.touch.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.pages.value')}
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.pages.label')}
          </div>
        </div>
        <div class="rounded-xl border border-accent/15 bg-slate-50/30 dark:bg-ink-800 px-6 py-8 text-center">
          <div class="bg-home-gradient-text-light dark:bg-home-gradient-text bg-clip-text font-display text-4xl font-black leading-none text-transparent tabular-nums">
            {t(lang, 'a11y.stats.violations.value')}
          </div>
          <div class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-accent">
            {t(lang, 'a11y.stats.violations.label')}
          </div>
        </div>
      </div>
    </section>

    <!-- Who benefits -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.users.heading')} subtitle={t(lang, 'a11y.users.subtitle')} />
      <div class="grid gap-6 sm:grid-cols-2">
        <!-- Screen readers -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.users.screenreader.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.users.screenreader.desc')}</p>
        </div>
        <!-- Keyboard only -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.users.keyboard.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.users.keyboard.desc')}</p>
        </div>
        <!-- Low vision -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.users.lowvision.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.users.lowvision.desc')}</p>
        </div>
        <!-- Color blindness -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.users.colorblind.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.users.colorblind.desc')}</p>
        </div>
      </div>
    </section>

    <!-- Pillars -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.pillars.heading')} subtitle={t(lang, 'a11y.pillars.subtitle')} />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Perceivable -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.perceivable.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.perceivable.desc')}</p>
        </div>
        <!-- Operable -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.operable.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.operable.desc')}</p>
        </div>
        <!-- Understandable -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.understandable.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.understandable.desc')}</p>
        </div>
        <!-- Robust -->
        <div class="rounded-xl border border-accent/15 p-6 dark:bg-ink-800">
          <svg aria-hidden="true" class="w-8 h-8 mb-3 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <h3 class="font-display text-lg font-bold">{t(lang, 'a11y.pillars.robust.title')}</h3>
          <p class="font-mono text-sm text-fg-muted mt-2">{t(lang, 'a11y.pillars.robust.desc')}</p>
        </div>
      </div>
    </section>

    <!-- Implementation checklist -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.impl.heading')} subtitle={t(lang, 'a11y.impl.subtitle')} />
      <ul class="grid gap-3 sm:grid-cols-2" role="list">
        {implKeys.map((key) => (
          <li class="flex gap-2 items-start">
            <svg aria-hidden="true" class="w-4 h-4 flex-shrink-0 mt-0.5 text-emerald-600 dark:text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="font-mono text-sm text-fg-muted">{t(lang, key)}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Color contrast -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.contrast.heading')} subtitle={t(lang, 'a11y.contrast.subtitle')} />
      <div class="overflow-x-auto rounded-xl border border-accent/15 dark:bg-ink-800">
        <table class="w-full text-left font-mono text-sm">
          <thead>
            <tr class="border-b border-accent/15">
              <th class="px-5 py-3 text-[11px] uppercase tracking-[0.25em] text-fg-muted font-semibold w-1/3"></th>
              <th class="px-5 py-3 text-[11px] uppercase tracking-[0.25em] text-fg-muted font-semibold">{t(lang, 'a11y.contrast.light')}</th>
              <th class="px-5 py-3 text-[11px] uppercase tracking-[0.25em] text-fg-muted font-semibold">{t(lang, 'a11y.contrast.dark')}</th>
            </tr>
          </thead>
          <tbody>
            {contrastPairs.map((pair) => (
              <tr class="border-b border-accent/10 last:border-0">
                <td class="px-5 py-4 text-[11px] uppercase tracking-[0.2em] text-fg-muted">{t(lang, pair.labelKey)}</td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-7 w-7 flex-shrink-0 rounded border border-slate-200" style={`background:${pair.light.bg}`}>
                      <span class="m-auto text-[10px] font-black leading-none" style={`color:${pair.light.fg}`}>Aa</span>
                    </span>
                    <span class="text-xs text-fg-muted">{pair.light.ratio}:1</span>
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">{t(lang, 'a11y.contrast.passes')}</span>
                  </div>
                </td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-7 w-7 flex-shrink-0 rounded border border-slate-700" style={`background:${pair.dark.bg}`}>
                      <span class="m-auto text-[10px] font-black leading-none" style={`color:${pair.dark.fg}`}>Aa</span>
                    </span>
                    <span class="text-xs text-fg-muted">{pair.dark.ratio}:1</span>
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">{t(lang, 'a11y.contrast.passes')}</span>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Verified pages -->
    <section class="space-y-8">
      <SectionHeader title={t(lang, 'a11y.pages.heading')} subtitle={t(lang, 'a11y.pages.subtitle')} />
      <ul class="grid grid-cols-2 gap-3 sm:grid-cols-4" role="list">
        {verifiedPages.map((page) => (
          <li class="flex items-center gap-2.5 rounded-lg border border-accent/15 bg-slate-50/30 px-4 py-3 dark:bg-ink-800">
            <svg aria-hidden="true" class="h-4 w-4 flex-shrink-0 text-emerald-600 dark:text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <div>
              <p class="font-mono text-xs text-fg-muted">{page.path}</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-accent">{t(lang, page.labelKey)}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Tools -->
    <section class="space-y-6">
      <SectionHeader title={t(lang, 'a11y.tools.heading')} subtitle={t(lang, 'a11y.tools.subtitle')} />
      <p class="font-mono text-sm text-fg-muted max-w-2xl">{t(lang, 'a11y.tools.desc')}</p>
      <div class="rounded-lg bg-slate-900 dark:bg-ink-800 border border-slate-700 p-4 overflow-x-auto">
        <pre class="font-mono text-sm text-emerald-400">$ {t(lang, 'a11y.tools.command')}</pre>
      </div>
      <span class="block font-mono text-xs text-fg-muted">{t(lang, 'a11y.tools.scope')}</span>
    </section>

    <!-- Back to case study -->
    <section class="flex justify-end">
      <a
        href={caseStudyHref}
        class="group inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[0.25em] text-accent focus:outline-none focus-visible:underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transition-transform duration-500 group-hover:-translate-x-1" aria-hidden="true">
          <path d="M19 12H5M11 5l-7 7 7 7" />
        </svg>
        <span class="relative h-px w-10 bg-accent transition-all duration-500 group-hover:w-16"></span>
        <span>{t(lang, 'a11y.backLink')}</span>
      </a>
    </section>

  </main>
</Layout>
